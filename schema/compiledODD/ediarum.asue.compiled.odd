        </valItem>
        <valItem ident="darkgoldenrod">
          <desc>Hex: #b8860b / RGB: 184,134,11</desc>
        </valItem>
        <valItem ident="darkgray">
          <desc>Hex: #a9a9a9 / RGB: 169,169,169</desc>
        </valItem>
