                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">gesperrt</a:documentation>
                     <value>#k</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Kapitälchen</a:documentation>
                     <value>#i</value>
                     <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">kursiv</a:documentation>
