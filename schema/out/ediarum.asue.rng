   </define>
   <define name="mei_artic">
      <element name="artic" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(articulation) – An indication of how to play a note or chord.</a:documentation>
         <empty/>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.artic.log.attributes"/>
         <ref name="tei_mei_att.artic.vis.attributes"/>
         <ref name="tei_mei_att.artic.ges.attributes"/>
         <ref name="tei_mei_att.artic.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_chord">
      <element name="chord" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A simultaneous sounding of two or more notes in the same layer *with the same duration*.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.chordPart"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.sylLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
               <ref name="tei_mei_model.verseLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.chord.log.attributes"/>
         <ref name="tei_mei_att.chord.vis.attributes"/>
         <ref name="tei_mei_att.chord.ges.attributes"/>
         <ref name="tei_mei_att.chord.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_clef">
      <element name="clef" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indication of the exact location of a particular note on the staff and, therefore, the other notes as well.</a:documentation>
         <empty/>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-clef-Clef_position_lines-constraint-rule-48">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:clef[ancestor::mei:staffDef[@lines]]">
               <sch:let name="thisstaff" value="ancestor::mei:staffDef/@n"/>
               <sch:assert test="number(@line) &lt;= number(ancestor::mei:staffDef[@n=$thisstaff and @lines][1]/@lines)">The clef position must be less than or equal to the number of lines of an ancestor
            staff.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-clef-Clef_position_nolines-constraint-rule-49">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:clef[ancestor::mei:staffDef[not(@lines)]]">
               <sch:let name="thisstaff" value="ancestor::mei:staffDef/@n"/>
               <sch:assert test="number(@line) &lt;= number(preceding::mei:staffDef[@n=$thisstaff and @lines][1]/@lines)">The clef position must be less than or equal to the number of lines of a preceding
            staff.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.event.attributes"/>
         <ref name="tei_mei_att.clef.anl.attributes"/>
         <ref name="tei_mei_att.clef.ges.attributes"/>
         <ref name="tei_mei_att.clef.log.attributes"/>
         <ref name="tei_mei_att.clef.vis.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_dir">
      <element name="dir" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(directive) – An instruction expressed as a combination of text and symbols — such as segno and coda symbols, fermatas over a bar line, etc., typically above, below, or between staves, but not on the staff — that is not encoded elsewhere in more specific elements, like <code xmlns="http://www.w3.org/1999/xhtml">&lt;tempo&gt;</code> or <code xmlns="http://www.w3.org/1999/xhtml">&lt;dynam&gt;</code>.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike.limited"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-dir-dir_start-type_attributes_required-constraint-rule-50">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:dir[not(ancestor::mei:syllable)]">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.dir.log.attributes"/>
         <ref name="tei_mei_att.dir.vis.attributes"/>
         <ref name="tei_mei_att.dir.ges.attributes"/>
         <ref name="tei_mei_att.dir.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_label">
      <element name="label" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A container for document text that identifies the feature to which it is attached. For a "tool tip" or other generated label, use the <code xmlns="http://www.w3.org/1999/xhtml">@label</code> attribute.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike.limited"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.source.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_layer">
      <element name="layer" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">An independent stream of events on a staff.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.annotLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.layerPart"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.basic.attributes"/>
         <ref name="tei_mei_att.labelled.attributes"/>
         <ref name="tei_mei_att.linking.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.nInteger.attributes"/>
         <ref name="tei_mei_att.responsibility.attributes"/>
         <ref name="tei_mei_att.typed.attributes"/>
         <ref name="tei_mei_att.layer.log.attributes"/>
         <ref name="tei_mei_att.layer.vis.attributes"/>
         <ref name="tei_mei_att.layer.ges.attributes"/>
         <ref name="tei_mei_att.layer.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_lb">
      <element name="lb" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(line beginning) – An empty formatting element that forces text to begin on a new line.</a:documentation>
         <empty/>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.source.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_mdiv">
      <element name="mdiv" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(musical division) – Contains a subdivision of the body of a musical text.</a:documentation>
         <choice>
            <group>
               <optional>
                  <ref name="tei_mei_model.scoreLike"/>
               </optional>
               <optional>
                  <ref name="tei_mei_model.partsLike"/>
               </optional>
            </group>
            <zeroOrMore>
               <ref name="tei_mei_model.mdivLike"/>
            </zeroOrMore>
         </choice>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.mdiv.anl.attributes"/>
         <ref name="tei_mei_att.mdiv.ges.attributes"/>
         <ref name="tei_mei_att.mdiv.log.attributes"/>
         <ref name="tei_mei_att.mdiv.vis.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_note">
      <element name="note" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A single pitched event. </a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.noteModifierLike"/>
               <ref name="tei_mei_model.verseLike"/>
               <ref name="tei_mei_model.sylLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.note.log.attributes"/>
         <ref name="tei_mei_att.note.vis.attributes"/>
         <ref name="tei_mei_att.note.ges.attributes"/>
         <ref name="tei_mei_att.note.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_rend">
      <element name="rend" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(render) – A formatting element indicating special visual rendering, e.g., bold or italicized, of a text word or phrase.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.color.attributes"/>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.horizontalAlign.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.textRendition.attributes"/>
         <ref name="tei_mei_att.typography.attributes"/>
         <ref name="tei_mei_att.verticalAlign.attributes"/>
         <ref name="tei_mei_att.whitespace.attributes"/>
         <ref name="tei_mei_att.extSym.attribute.glyph.auth"/>
         <optional>
            <attribute name="rotation">
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A positive value for rotation rotates the text in a counter-clockwise fashion, while negative values produce clockwise rotation.</a:documentation>
               <ref name="mei_data.DEGREES"/>
            </attribute>
         </optional>
         <empty/>
      </element>
   </define>
   <define name="mei_rest">
      <element name="rest" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A non-sounding event found in the source being transcribed.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-rest-Check_restline-constraint-rule-51">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:rest[@line]">
               <sch:let name="thisstaff" value="ancestor::mei:staff/@n"/>
               <sch:assert test="number(@line) &lt;= number(preceding::mei:staffDef[@n=$thisstaff and @lines][1]/@lines)">The value of @line must be less than or equal to the number of lines on the
            staff.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.rest.log.attributes"/>
         <ref name="tei_mei_att.rest.vis.attributes"/>
         <ref name="tei_mei_att.rest.ges.attributes"/>
         <ref name="tei_mei_att.rest.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_sb">
      <element name="sb" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(system beginning) – An empty formatting element that forces musical notation to begin on a new line.</a:documentation>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.source.attributes"/>
         <ref name="tei_mei_att.sb.anl.attributes"/>
         <ref name="tei_mei_att.sb.ges.attributes"/>
         <ref name="tei_mei_att.sb.log.attributes"/>
         <ref name="tei_mei_att.sb.vis.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_score">
      <element name="score" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Full score view of the musical content.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.annotLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.relationLike"/>
               <ref name="tei_mei_model.scoreDefLike"/>
               <ref name="tei_mei_model.scorePart"/>
               <ref name="tei_mei_model.staffDefLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.score.log.attributes"/>
         <ref name="tei_mei_att.score.vis.attributes"/>
         <ref name="tei_mei_att.score.ges.attributes"/>
         <ref name="tei_mei_att.score.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_scoreDef">
      <element name="scoreDef" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(score definition) – Container for score meta-information.</a:documentation>
         <optional>
            <ref name="tei_mei_model.symbolTableLike"/>
         </optional>
         <optional>
            <ref name="tei_mei_model.keySigLike"/>
         </optional>
         <optional>
            <ref name="tei_mei_model.meterSigLike"/>
         </optional>
         <optional>
            <ref name="tei_mei_model.staffGrpLike"/>
         </optional>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.scoreDef.log.attributes"/>
         <ref name="tei_mei_att.scoreDef.vis.attributes"/>
         <ref name="tei_mei_att.scoreDef.ges.attributes"/>
         <ref name="tei_mei_att.scoreDef.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_section">
      <element name="section" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Segment of music data.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.annotLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.relationLike"/>
               <ref name="tei_mei_model.sectionPart"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-section-Check_sectionexpansion-constraint-rule-52">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:section[mei:expansion]">
               <sch:assert test="descendant::mei:section|descendant::mei:ending|descendant::mei:rdg">A
            section containing an expansion element must have descendant section, ending, or rdg
            elements.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.pointing.attributes"/>
         <ref name="tei_mei_att.section.anl.attributes"/>
         <ref name="tei_mei_att.section.ges.attributes"/>
         <ref name="tei_mei_att.section.log.attributes"/>
         <ref name="tei_mei_att.section.vis.attributes"/>
         <ref name="tei_mei_att.targetEval.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_space">
      <element name="space" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A placeholder used to fill an incomplete measure, layer, etc. most often so that the combined duration of the events equals the number of beats in the measure.</a:documentation>
         <empty/>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.space.log.attributes"/>
         <ref name="tei_mei_att.space.vis.attributes"/>
         <ref name="tei_mei_att.space.ges.attributes"/>
         <ref name="tei_mei_att.space.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_staff">
      <element name="staff" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A group of equidistant horizontal lines on which notes are placed in order to represent pitch or a grouping element for individual 'strands' of notes, rests, etc. that may or may not actually be rendered on staff lines; that is, both diastematic and non-diastematic signs.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.annotLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.relationLike"/>
               <ref name="tei_mei_model.staffDefLike"/>
               <ref name="tei_mei_model.staffPart"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staff-checkStaff_n-constraint-rule-53">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staff[@n]">
               <sch:let name="thisstaff" value="@n"/>
               <sch:assert test="preceding::mei:staffDef[@n=$thisstaff] or preceding::mei:staff[@n=$thisstaff]/mei:staffDef or mei:staffDef">There must be a preceding staffDef with a matching value of @n, a preceding staff with
            a matching @n value containing a staffDef, or a staffDef child element.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.basic.attributes"/>
         <ref name="tei_mei_att.labelled.attributes"/>
         <ref name="tei_mei_att.linking.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.nInteger.attributes"/>
         <ref name="tei_mei_att.responsibility.attributes"/>
         <ref name="tei_mei_att.typed.attributes"/>
         <ref name="tei_mei_att.staff.log.attributes"/>
         <ref name="tei_mei_att.staff.vis.attributes"/>
         <ref name="tei_mei_att.staff.ges.attributes"/>
         <ref name="tei_mei_att.staff.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_staffDef">
      <element name="staffDef" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(staff definition) – Container for staff meta-information.</a:documentation>
         <zeroOrMore>
            <ref name="tei_mei_model.labelLike"/>
         </zeroOrMore>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.instrDefLike"/>
               <ref name="tei_mei_model.layerDefLike"/>
               <ref name="tei_mei_model.staffDefPart"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_staffDefn-constraint-rule-54">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[not(ancestor::mei:staff)]">
               <sch:let name="thisstaff" value="@n"/>
               <sch:assert test="@n">StaffDef must have an n attribute.</sch:assert>
               <sch:assert test="@lines or preceding::mei:staffDef[@n=$thisstaff and @lines]"> Either
            @lines must be present or a preceding staffDef with the same value for @n and @lines
            must exist.</sch:assert>
               <sch:assert test="count(mei:clef) + count(mei:clefGrp) &lt; 2">Only one clef or clefGrp is
            permitted.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_ancestor_staff-constraint-rule-55">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[ancestor::mei:staff and @n]">
               <sch:let name="thisstaff" value="@n"/>
               <sch:assert test="ancestor::mei:staff/@n eq $thisstaff">@n must have the same value as the
            current staff.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_ancestor_staff_lines-constraint-rule-56">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[ancestor::mei:staff and not(@n)]">
               <sch:let name="thisstaff" value="ancestor::mei:staff/@n"/>
               <sch:assert test="@lines or preceding::mei:staffDef[@n=$thisstaff and @lines]"> Either
            @lines must be present or a preceding staffDef with matching @n value and @lines must
            exist.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_clef_position_staffDef-constraint-rule-57">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[@clef.line and @lines]">
               <sch:assert test="number(@clef.line) &lt;= number(@lines)">The clef position must be less
            than or equal to the number of lines on the staff.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_clef_position_staffDef_nolines-constraint-rule-58">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[@clef.line and not(@lines)]">
               <sch:let name="thisstaff" value="@n"/>
               <sch:let name="stafflines"
                        value="preceding::mei:staffDef[@n=$thisstaff and @lines][1]/@lines"/>
               <sch:assert test="number(@clef.line) &lt;= number($stafflines)">The clef position must be
            less than or equal to the number of lines on the staff.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_tab_strings_lines-constraint-rule-59">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[@tab.strings and @lines]">
               <sch:let name="countTokens"
                        value="count(tokenize(normalize-space(@tab.strings), '\s'))"/>
               <sch:assert test="$countTokens = @lines">The tab.strings attribute must have the same
            number of values as there are staff lines.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffDef-Check_tab_strings_nolines-constraint-rule-60">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffDef[@tab.strings and not(@lines)]">
               <sch:let name="countTokens"
                        value="count(tokenize(normalize-space(@tab.strings), '\s'))"/>
               <sch:let name="thisstaff" value="@n"/>
               <sch:assert test="$countTokens = preceding::mei:staffDef[@n=$thisstaff and @lines][1]/@lines">The
            tab.strings attribute must have the same number of values as there are staff
            lines.</sch:assert>
            </sch:rule>
         </pattern>
         <sch:pattern xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0">
            <sch:rule context="mei:staffDef[@lines.color and @lines]">
               <sch:let name="countTokens"
                        value="count(tokenize(normalize-space(@lines.color), '\s'))"/>
               <sch:assert test="$countTokens = 1 or $countTokens = @lines">The lines.color attribute
              must have either 1) a single value or 2) the same number of values as there are staff
              lines.</sch:assert>
            </sch:rule>
            <sch:rule context="mei:staffDef[@lines.color and not(@lines)]">
               <sch:let name="countTokens"
                        value="count(tokenize(normalize-space(@lines.color), '\s'))"/>
               <sch:let name="thisstaff" value="@n"/>
               <sch:assert test="$countTokens = 1 or $countTokens = preceding::mei:staffDef[@n=$thisstaff and @lines][1]/@lines">The lines.color attribute must have either 1) a single value or 2) the same number of
              values as there are staff lines.</sch:assert>
            </sch:rule>
         </sch:pattern>
         <sch:pattern xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0">
            <sch:rule context="mei:staffDef[@ppq][ancestor::mei:scoreDef[@ppq]]">
               <sch:let name="staffPPQ" value="@ppq"/>
               <sch:let name="scorePPQ" value="ancestor::mei:scoreDef[@ppq][1]/@ppq"/>
               <sch:assert test="($scorePPQ mod $staffPPQ) = 0">The value of ppq must be a factor of
              the value of ppq on an ancestor scoreDef.</sch:assert>
            </sch:rule>
         </sch:pattern>
         <sch:pattern xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0">
            <sch:rule context="mei:staffDef[@ppq][preceding::mei:scoreDef[@ppq]]">
               <sch:let name="staffPPQ" value="@ppq"/>
               <sch:let name="scorePPQ" value="preceding::mei:scoreDef[@ppq][1]/@ppq"/>
               <sch:assert test="($scorePPQ mod $staffPPQ) = 0">The value of ppq must be a factor of
              the value of ppq on a preceding scoreDef.</sch:assert>
            </sch:rule>
         </sch:pattern>
         <ref name="tei_mei_att.basic.attributes"/>
         <ref name="tei_mei_att.labelled.attributes"/>
         <ref name="tei_mei_att.linking.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.nInteger.attributes"/>
         <ref name="tei_mei_att.responsibility.attributes"/>
         <ref name="tei_mei_att.typed.attributes"/>
         <ref name="tei_mei_att.staffDef.log.attributes"/>
         <ref name="tei_mei_att.staffDef.vis.attributes"/>
         <ref name="tei_mei_att.staffDef.ges.attributes"/>
         <ref name="tei_mei_att.staffDef.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_staffGrp">
      <element name="staffGrp" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(staff group) – A group of bracketed or braced staves.</a:documentation>
         <zeroOrMore>
            <ref name="tei_mei_model.labelLike"/>
         </zeroOrMore>
         <zeroOrMore>
            <ref name="tei_mei_model.instrDefLike"/>
         </zeroOrMore>
         <oneOrMore>
            <choice>
               <ref name="tei_mei_model.staffGrpLike"/>
               <ref name="tei_mei_model.staffDefLike"/>
            </choice>
         </oneOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-staffGrp-Check_staffGrp_unique_staff_n_values-constraint-rule-65">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:staffGrp">
               <sch:let name="countstaves" value="count(descendant::mei:staffDef)"/>
               <sch:let name="countuniqstaves"
                        value="count(distinct-values(descendant::mei:staffDef/@n))"/>
               <sch:assert test="$countstaves eq $countuniqstaves">Each staffDef must have a unique value
            for the n attribute.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.staffGrp.log.attributes"/>
         <ref name="tei_mei_att.staffGrp.vis.attributes"/>
         <ref name="tei_mei_att.staffGrp.ges.attributes"/>
         <ref name="tei_mei_att.staffGrp.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_syl">
      <element name="syl" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(syllable) – Individual lyric syllable.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike.limited"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.syl.log.attributes"/>
         <ref name="tei_mei_att.syl.vis.attributes"/>
         <ref name="tei_mei_att.syl.ges.attributes"/>
         <ref name="tei_mei_att.syl.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_tempo">
      <element name="tempo" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Text and symbols descriptive of tempo, mood, or style, e.g., "allarg.", "a tempo", "cantabile", "Moderato", "♩=60", "Moderato ♩ =60").</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike.limited"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-tempo-tempo_start-type_attributes_required-constraint-rule-66">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:tempo[not(ancestor::mei:syllable) and not(ancestor::mei:work) and not(ancestor::mei:expression) and not(count(ancestor::mei:*) = 0)]">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.bibl.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.tempo.log.attributes"/>
         <ref name="tei_mei_att.tempo.vis.attributes"/>
         <ref name="tei_mei_att.tempo.ges.attributes"/>
         <ref name="tei_mei_att.tempo.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="tei_mei_att.beam.log.attributes">
      <ref name="tei_mei_att.event.attributes"/>
      <ref name="tei_mei_att.beamedWith.attributes"/>
   </define>
   <define name="tei_mei_att.beamedWith.attributes">
      <ref name="tei_mei_att.beamedWith.attribute.beam.with"/>
   </define>
   <define name="tei_mei_att.beamedWith.attribute.beam.with">
      <optional>
         <attribute name="beam.with">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">In the case of cross-staff beams, the beam.with attribute is used to indicate which staff the beam is connected to; that is, the staff above or the staff below.</a:documentation>
            <ref name="mei_data.OTHERSTAFF"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beaming.log.attributes">
      <ref name="tei_mei_att.beaming.log.attribute.beam.group"/>
      <ref name="tei_mei_att.beaming.log.attribute.beam.rests"/>
   </define>
   <define name="tei_mei_att.beaming.log.attribute.beam.group">
      <optional>
         <attribute name="beam.group">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Provides an example of how automated beaming (including secondary beams) is to be performed.</a:documentation>
            <data type="string"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beaming.log.attribute.beam.rests">
      <optional>
         <attribute name="beam.rests">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates whether automatically-drawn beams should include rests shorter than a quarter note duration.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beamPresent.attributes">
      <ref name="tei_mei_att.beamPresent.attribute.beam"/>
   </define>
   <define name="tei_mei_att.beamPresent.attribute.beam">
      <optional>
         <attribute name="beam">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates that this event is "under a beam".</a:documentation>
            <list>
               <oneOrMore>
                  <ref name="mei_data.BEAM"/>
               </oneOrMore>
            </list>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beamRend.attributes">
      <ref name="tei_mei_att.beamRend.attribute.form"/>
      <ref name="tei_mei_att.beamRend.attribute.place"/>
      <ref name="tei_mei_att.beamRend.attribute.slash"/>
      <ref name="tei_mei_att.beamRend.attribute.slope"/>
   </define>
   <define name="tei_mei_att.beamRend.attribute.form">
      <optional>
         <attribute name="form">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Captures whether a beam is "feathered" and in which direction.</a:documentation>
            <choice>
               <value>acc</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(accelerando) indicates that the secondary beams get progressively closer together toward the end of the beam.</a:documentation>
               <value>mixed</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(mixed acc and rit) for beams that are "feathered" in both directions.</a:documentation>
               <value>rit</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(ritardando) means that the secondary beams become progressively more distant toward the end of the beam.</a:documentation>
               <value>norm</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(normal) indicates that the secondary beams are equidistant along the course of the beam.</a:documentation>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beamRend.attribute.place">
      <optional>
         <attribute name="place">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the placement of the beam relative to the events it affects.</a:documentation>
            <ref name="mei_data.BEAMPLACE"/>
         </attribute>
      </optional>
   </define>
   <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
            id="asue-mei_att.beamRend-place-check_beam_place-constraint-rule-67">
      <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                xmlns:telota="http://www.telota.de"
                xmlns:rng="http://relaxng.org/ns/structure/1.0"
                xmlns:mei="http://www.music-encoding.org/ns/mei"
                xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                xmlns="http://www.tei-c.org/ns/1.0"
                context="mei:beam[@place eq 'mixed' and not(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'][@staff != ./@staff] or descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'][@staff != ancestor::mei:staff/@n])]">
         <sch:assert test="count(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'][@stem.dir]) = count(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'])">Stem direction must be specified for all notes and chords under the
                beam.</sch:assert>
         <sch:assert test="count(distinct-values(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord']/@stem.dir)) &gt; 1">Opposing stem directions are required for a beam with @place="mixed".</sch:assert>
      </sch:rule>
      <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                xmlns:telota="http://www.telota.de"
                xmlns:rng="http://relaxng.org/ns/structure/1.0"
                xmlns:mei="http://www.music-encoding.org/ns/mei"
                xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                xmlns="http://www.tei-c.org/ns/1.0"
                context="mei:beam[@place eq 'mixed' and (descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'][@staff != ./@staff] or descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'][@staff != ancestor::mei:staff/@n])                 and count(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'][@stem.dir]) = count(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord'])]">
         <sch:assert test="count(distinct-values(descendant::mei:*[local-name() eq 'note' or local-name() eq 'chord']/@stem.dir)) &gt; 1">Opposing stem directions are required for a beam with @place="mixed".</sch:assert>
      </sch:rule>
   </pattern>
   <define name="tei_mei_att.beamRend.attribute.slash">
      <optional>
         <attribute name="slash">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates presence of slash through the beam.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beamRend.attribute.slope">
      <optional>
         <attribute name="slope">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the slope of the beam.</a:documentation>
            <data type="decimal"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beamSecondary.attributes">
      <ref name="tei_mei_att.beamSecondary.attribute.breaksec"/>
   </define>
   <define name="tei_mei_att.beamSecondary.attribute.breaksec">
      <optional>
         <attribute name="breaksec">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Presence of this attribute indicates that the secondary beam should be broken following this note/chord. The value of the attribute records the number of beams which should remain unbroken.</a:documentation>
            <data type="positiveInteger"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.bracketSpan.log.attributes">
      <ref name="tei_mei_att.controlEvent.attributes"/>
      <ref name="tei_mei_att.duration.additive.attributes"/>
      <ref name="tei_mei_att.startEndId.attributes"/>
      <ref name="tei_mei_att.timestamp2.logical.attributes"/>
   </define>
   <define name="tei_mei_att.chord.anl.cmn.attributes">
      <ref name="tei_mei_att.beamPresent.attributes"/>
      <ref name="tei_mei_att.fermataPresent.attributes"/>
      <ref name="tei_mei_att.lvPresent.attributes"/>
      <ref name="tei_mei_att.ornamPresent.attributes"/>
      <ref name="tei_mei_att.slurPresent.attributes"/>
      <ref name="tei_mei_att.tiePresent.attributes"/>
      <ref name="tei_mei_att.tupletPresent.attributes"/>
   </define>
   <define name="tei_mei_att.chord.ges.cmn.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.chord.log.cmn.attributes">
      <ref name="tei_mei_att.graced.attributes"/>
   </define>
   <define name="tei_mei_att.chord.vis.cmn.attributes">
      <ref name="tei_mei_att.beamSecondary.attributes"/>
   </define>
   <define name="tei_mei_att.cutout.attributes">
      <ref name="tei_mei_att.cutout.attribute.cutout"/>
   </define>
   <define name="tei_mei_att.cutout.attribute.cutout">
      <optional>
         <attribute name="cutout">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">"Cut-out" style.</a:documentation>
            <choice>
               <value>cutout</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">The staff lines should not be drawn.</a:documentation>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.glissPresent.attributes">
      <ref name="tei_mei_att.glissPresent.attribute.gliss"/>
   </define>
   <define name="tei_mei_att.glissPresent.attribute.gliss">
      <optional>
         <attribute name="gliss">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates that this element participates in a glissando. If visual information about the glissando needs to be recorded, then a <code xmlns="http://www.w3.org/1999/xhtml">&lt;gliss&gt;</code> element should be employed instead.</a:documentation>
            <ref name="mei_data.GLISSANDO"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.graced.attributes">
      <ref name="tei_mei_att.graced.attribute.grace"/>
      <ref name="tei_mei_att.graced.attribute.grace.time"/>
   </define>
   <define name="tei_mei_att.graced.attribute.grace">
      <optional>
         <attribute name="grace">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Marks a note or chord as a "grace" (without a definite performed duration) and records from which other note/chord it should "steal" time.</a:documentation>
            <ref name="mei_data.GRACE"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.graced.attribute.grace.time">
      <optional>
         <attribute name="grace.time">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the amount of time to be "stolen" from a non-grace note/chord.</a:documentation>
            <ref name="mei_data.PERCENT"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.hairpin.log.attributes">
      <ref name="tei_mei_att.controlEvent.attributes"/>
      <ref name="tei_mei_att.duration.additive.attributes"/>
      <ref name="tei_mei_att.startEndId.attributes"/>
      <ref name="tei_mei_att.timestamp2.logical.attributes"/>
      <ref name="tei_mei_att.hairpin.log.attribute.form"/>
      <ref name="tei_mei_att.hairpin.log.attribute.niente"/>
   </define>
   <define name="tei_mei_att.hairpin.log.attribute.form">
      <attribute name="form">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Captures the visual rendition and function of the hairpin; that is, whether it indicates an increase or a decrease in volume.</a:documentation>
         <choice>
            <value>cres</value>
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Crescendo; i.e., louder.</a:documentation>
            <value>dim</value>
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Diminuendo; i.e., softer.</a:documentation>
         </choice>
      </attribute>
   </define>
   <define name="tei_mei_att.hairpin.log.attribute.niente">
      <optional>
         <attribute name="niente">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates that the hairpin starts from or ends in silence. Often rendered as a small circle attached to the closed end of the hairpin. See Gould, p. 108.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.lvPresent.attributes">
      <ref name="tei_mei_att.lvPresent.attribute.lv"/>
   </define>
   <define name="tei_mei_att.lvPresent.attribute.lv">
      <optional>
         <attribute name="lv">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates the attachment of an l.v. (laissez vibrer) sign to this element.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.measure.log.attributes">
      <ref name="tei_mei_att.meterConformance.bar.attributes"/>
      <ref name="tei_mei_att.measure.log.attribute.left"/>
      <ref name="tei_mei_att.measure.log.attribute.right"/>
   </define>
   <define name="tei_mei_att.measure.log.attribute.left">
      <optional>
         <attribute name="left">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates the visual rendition of the left bar line. It is present here only for facilitation of translation from legacy encodings which use it. Usually, it can be safely ignored.</a:documentation>
            <ref name="mei_data.BARRENDITION"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.measure.log.attribute.right">
      <optional>
         <attribute name="right">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates the function of the right bar line and is structurally important.</a:documentation>
            <ref name="mei_data.BARRENDITION"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.mSpace.log.attributes">
      <ref name="tei_mei_att.duration.additive.attributes"/>
      <ref name="tei_mei_att.event.attributes"/>
   </define>
   <define name="tei_mei_att.note.anl.cmn.attributes">
      <ref name="tei_mei_att.beamPresent.attributes"/>
      <ref name="tei_mei_att.fermataPresent.attributes"/>
      <ref name="tei_mei_att.glissPresent.attributes"/>
      <ref name="tei_mei_att.lvPresent.attributes"/>
      <ref name="tei_mei_att.ornamPresent.attributes"/>
      <ref name="tei_mei_att.slurPresent.attributes"/>
      <ref name="tei_mei_att.sylText.attributes"/>
      <ref name="tei_mei_att.tiePresent.attributes"/>
      <ref name="tei_mei_att.tupletPresent.attributes"/>
   </define>
   <define name="tei_mei_att.note.log.cmn.attributes">
      <ref name="tei_mei_att.graced.attributes"/>
   </define>
   <define name="tei_mei_att.note.vis.cmn.attributes">
      <ref name="tei_mei_att.beamSecondary.attributes"/>
   </define>
   <define name="tei_mei_att.numberPlacement.attributes">
      <ref name="tei_mei_att.numberPlacement.attribute.num.place"/>
      <ref name="tei_mei_att.numberPlacement.attribute.num.visible"/>
   </define>
   <define name="tei_mei_att.numberPlacement.attribute.num.place">
      <optional>
         <attribute name="num.place">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">States where the tuplet number will be placed in relation to the note heads.</a:documentation>
            <ref name="mei_data.STAFFREL.basic"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.numberPlacement.attribute.num.visible">
      <optional>
         <attribute name="num.visible">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Determines if the tuplet number is visible.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.pianoPedals.attributes">
      <ref name="tei_mei_att.pianoPedals.attribute.pedal.style"/>
   </define>
   <define name="tei_mei_att.pianoPedals.attribute.pedal.style">
      <optional>
         <attribute name="pedal.style">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Determines whether piano pedal marks should be rendered as lines or as terms.</a:documentation>
            <choice>
               <value>line</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Continuous line with start and end positions rendered by vertical bars and bounces shown by upward-pointing "blips".</a:documentation>
               <value>pedstar</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Pedal down and half pedal rendered with "Ped.", pedal up rendered by "*", pedal "bounce" rendered with "* Ped.".</a:documentation>
               <value>altpedstar</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Pedal up and down indications same as with "pedstar", but bounce is rendered with "Ped." only.</a:documentation>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.rehearsal.attributes">
      <ref name="tei_mei_att.rehearsal.attribute.reh.enclose"/>
   </define>
   <define name="tei_mei_att.rehearsal.attribute.reh.enclose">
      <optional>
         <attribute name="reh.enclose">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Describes the enclosing shape for rehearsal marks.</a:documentation>
            <choice>
               <value>box</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Enclosed by box.</a:documentation>
               <value>circle</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Enclosed by circle.</a:documentation>
               <value>none</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">No enclosing shape.</a:documentation>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.rest.anl.cmn.attributes">
      <ref name="tei_mei_att.beamPresent.attributes"/>
      <ref name="tei_mei_att.fermataPresent.attributes"/>
      <ref name="tei_mei_att.tupletPresent.attributes"/>
   </define>
   <define name="tei_mei_att.rest.log.cmn.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.rest.vis.cmn.attributes">
      <ref name="tei_mei_att.beamSecondary.attributes"/>
   </define>
   <define name="tei_mei_att.scoreDef.log.cmn.attributes">
      <ref name="tei_mei_att.beaming.log.attributes"/>
   </define>
