   <define name="tei_mei_att.ornamentAccid.attributes">
      <ref name="tei_mei_att.ornamentAccid.attribute.accidupper"/>
      <ref name="tei_mei_att.ornamentAccid.attribute.accidlower"/>
   </define>
   <define name="tei_mei_att.ornamentAccid.attribute.accidupper">
      <optional>
         <attribute name="accidupper">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the written accidental associated with an upper neighboring note.</a:documentation>
            <ref name="mei_data.ACCIDENTAL.WRITTEN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.ornamentAccid.attribute.accidlower">
      <optional>
         <attribute name="accidlower">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the written accidental associated with a lower neighboring note.</a:documentation>
            <ref name="mei_data.ACCIDENTAL.WRITTEN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.ornamPresent.attributes">
      <ref name="tei_mei_att.ornamPresent.attribute.ornam"/>
   </define>
   <define name="tei_mei_att.ornamPresent.attribute.ornam">
      <optional>
         <attribute name="ornam">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates that this element has an attached ornament. If visual information about the ornament is needed, then one of the elements that represents an ornament (mordent, trill, or turn) should be employed.</a:documentation>
            <list>
               <oneOrMore>
                  <ref name="mei_data.ORNAM.cmn"/>
               </oneOrMore>
            </list>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.trill.log.attributes">
      <ref name="tei_mei_att.controlEvent.attributes"/>
      <ref name="tei_mei_att.duration.additive.attributes"/>
      <ref name="tei_mei_att.ornamentAccid.attributes"/>
      <ref name="tei_mei_att.startEndId.attributes"/>
      <ref name="tei_mei_att.timestamp2.logical.attributes"/>
   </define>
   <define name="tei_mei_model.ornamentLike.cmn">
      <choice>
         <ref name="mei_trill"/>
      </choice>
   </define>
   <define name="tei_mei_model.ornamentLike.cmn_alternation">
      <choice>
         <ref name="mei_trill"/>
      </choice>
   </define>
   <define name="tei_mei_model.ornamentLike.cmn_sequence">
      <ref name="mei_trill"/>
   </define>
   <define name="tei_mei_model.ornamentLike.cmn_sequenceOptional">
      <optional>
         <ref name="mei_trill"/>
      </optional>
   </define>
   <define name="tei_mei_model.ornamentLike.cmn_sequenceOptionalRepeatable">
      <zeroOrMore>
         <ref name="mei_trill"/>
      </zeroOrMore>
   </define>
   <define name="tei_mei_model.ornamentLike.cmn_sequenceRepeatable">
      <oneOrMore>
         <ref name="mei_trill"/>
      </oneOrMore>
   </define>
   <define name="mei_trill">
      <element name="trill" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Rapid alternation of a note with another (usually at the interval of a second above).</a:documentation>
         <empty/>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-trill-trill_start-type_attributes_required-constraint-rule-77">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:trill">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.trill.log.attributes"/>
         <ref name="tei_mei_att.trill.vis.attributes"/>
         <ref name="tei_mei_att.trill.ges.attributes"/>
         <ref name="tei_mei_att.trill.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="tei_mei_att.edit.attributes">
      <ref name="tei_mei_att.source.attributes"/>
      <ref name="tei_mei_att.evidence.attributes"/>
   </define>
   <define name="tei_mei_att.trans.attributes">
      <ref name="tei_mei_att.handIdent.attributes"/>
      <ref name="tei_mei_att.metadataPointing.attributes"/>
      <ref name="tei_mei_att.sequence.attributes"/>
   </define>
   <define name="tei_mei_model.editLike">
      <choice>
         <ref name="mei_subst"/>
      </choice>
   </define>
   <define name="tei_mei_model.editTransPart">
      <choice>
         <ref name="tei_mei_model.sylLike"/>
         <ref name="tei_mei_model.editTransPart.music"/>
         <ref name="tei_mei_model.editTransPart.text"/>
      </choice>
   </define>
   <define name="tei_mei_model.editTransPart.music">
      <choice>
         <ref name="tei_mei_model.controlEventLike"/>
         <ref name="tei_mei_model.layerLike"/>
         <ref name="tei_mei_model.controlEventLike.cmn"/>
         <ref name="tei_mei_model.verseLike"/>
      </choice>
   </define>
   <define name="tei_mei_model.editTransPart.text">
      <choice>
         <ref name="tei_mei_model.textComponentLike"/>
         <ref name="tei_mei_model.textPhraseLike.limited"/>
      </choice>
   </define>
   <define name="tei_mei_model.transcriptionLike">
      <choice>
         <ref name="mei_add"/>
         <ref name="mei_del"/>
      </choice>
   </define>
   <define name="mei_add">
      <element name="add" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(addition) – Marks an addition to the text.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.editTransPart"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.keyAccidLike"/>
               <ref name="tei_mei_model.layerPart"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.sectionPart"/>
               <ref name="tei_mei_model.staffGrpLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
               <ref name="tei_mei_model.noteModifierLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.edit.attributes"/>
         <ref name="tei_mei_att.extent.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.trans.attributes"/>
         <optional>
            <attribute name="place">
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Location of the addition.</a:documentation>
               <list>
                  <oneOrMore>
                     <choice>
                        <value>across</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Hinzufügung durch Überschreibung des zu korrigierenden Textes.</a:documentation>
                        <value>intralinear</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung innerhalb der Textzeile, jedoch ohne bestehenden Text zu überschreiben.</a:documentation>
                        <value>superlinear</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung über der Zeile.</a:documentation>
                        <value>sublinear</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung unter der Zeile.</a:documentation>
                        <value>left</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung am linken Rand.</a:documentation>
                        <value>right</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung am rechten Rand.</a:documentation>
                        <value>mTop</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung am oberen Rand.</a:documentation>
                        <value>mBottom</value>
                        <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Einfügung am unteren Rand.</a:documentation>
                     </choice>
                  </oneOrMore>
               </list>
            </attribute>
         </optional>
         <empty/>
      </element>
   </define>
   <define name="mei_del">
      <element name="del" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(deletion) – Contains information deleted, marked as deleted, or otherwise indicated as superfluous or spurious in the copy text by an author, scribe, annotator, or corrector.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.editTransPart"/>
               <ref name="tei_mei_model.keyAccidLike"/>
               <ref name="tei_mei_model.layerPart"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.sectionPart"/>
               <ref name="tei_mei_model.staffGrpLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
               <ref name="tei_mei_model.noteModifierLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.edit.attributes"/>
         <ref name="tei_mei_att.extent.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.textRendition.attributes"/>
         <ref name="tei_mei_att.trans.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_subst">
      <element name="subst" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(substitution) – Groups transcriptional elements when the combination is to be regarded as a single intervention in the text.</a:documentation>
         <ref name="tei_mei_model.transcriptionLike"/>
         <oneOrMore>
            <ref name="tei_mei_model.transcriptionLike"/>
         </oneOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.edit.attributes"/>
         <ref name="tei_mei_att.trans.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="tei_mei_att.accidental.gestural.attributes">
      <ref name="tei_mei_att.accidental.gestural.attribute.accid.ges"/>
   </define>
   <define name="tei_mei_att.accidental.gestural.attribute.accid.ges">
      <optional>
         <attribute name="accid.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the performed pitch inflection.</a:documentation>
            <ref name="mei_data.ACCIDENTAL.GESTURAL"/>
         </attribute>
      </optional>
   </define>
   <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
            id="asue-mei_att.accidental.gestural-accid.ges-check_accid_duplication-constraint-rule-78">
      <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                xmlns:telota="http://www.telota.de"
                xmlns:rng="http://relaxng.org/ns/structure/1.0"
                xmlns:mei="http://www.music-encoding.org/ns/mei"
                xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                xmlns="http://www.tei-c.org/ns/1.0"
                context="@accid.ges">
         <sch:assert role="warning" test="not(. eq ../@accid)">The value of @accid.ges should
                not duplicate the value of @accid.</sch:assert>
      </sch:rule>
   </pattern>
   <define name="tei_mei_att.artic.ges.attributes">
      <ref name="tei_mei_att.articulation.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.articulation.gestural.attributes">
      <ref name="tei_mei_att.articulation.gestural.attribute.artic.ges"/>
   </define>
   <define name="tei_mei_att.articulation.gestural.attribute.artic.ges">
      <optional>
         <attribute name="artic.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records performed articulation that differs from the written value.</a:documentation>
            <list>
               <oneOrMore>
                  <ref name="mei_data.ARTICULATION"/>
               </oneOrMore>
            </list>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beam.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.bracketSpan.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.chord.ges.attributes">
      <ref name="tei_mei_att.articulation.gestural.attributes"/>
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.chord.ges.cmn.attributes"/>
   </define>
   <define name="tei_mei_att.clef.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.mdiv.ges.attributes">
      <ref name="tei_mei_att.mdiv.ges.attribute.attacca"/>
   </define>
   <define name="tei_mei_att.mdiv.ges.attribute.attacca">
      <optional>
         <attribute name="attacca">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates that the performance of the next musical division should begin immediately following this one.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.dir.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.duration.gestural.attributes">
      <ref name="tei_mei_att.duration.gestural.attribute.dur.ges"/>
      <ref name="tei_mei_att.duration.gestural.attribute.dots.ges"/>
      <ref name="tei_mei_att.duration.gestural.attribute.dur.metrical"/>
      <ref name="tei_mei_att.duration.gestural.attribute.dur.ppq"/>
      <ref name="tei_mei_att.duration.gestural.attribute.dur.real"/>
      <ref name="tei_mei_att.duration.gestural.attribute.dur.recip"/>
   </define>
   <define name="tei_mei_att.duration.gestural.attribute.dur.ges">
      <optional>
         <attribute name="dur.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records performed duration information that differs from the written duration.</a:documentation>
            <ref name="mei_data.DURATION.gestural"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.duration.gestural.attribute.dots.ges">
      <optional>
         <attribute name="dots.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Number of dots required for a gestural duration when different from that of the written duration.</a:documentation>
            <ref name="mei_data.AUGMENTDOT"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.duration.gestural.attribute.dur.metrical">
      <optional>
         <attribute name="dur.metrical">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Duration as a count of units provided in the time signature denominator.</a:documentation>
            <data type="decimal">
               <param name="pattern">\d+(\.\d+)?</param>
            </data>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.duration.gestural.attribute.dur.ppq">
      <optional>
         <attribute name="dur.ppq">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Duration recorded as pulses-per-quarter note, e.g. MIDI clicks or MusicXML divisions.</a:documentation>
            <data type="nonNegativeInteger"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.duration.gestural.attribute.dur.real">
      <optional>
         <attribute name="dur.real">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Duration in seconds, e.g. '1.732'.</a:documentation>
            <data type="decimal">
               <param name="pattern">\d+(\.\d+)?</param>
            </data>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.duration.gestural.attribute.dur.recip">
      <optional>
         <attribute name="dur.recip">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Duration as an optionally dotted Humdrum *recip value.</a:documentation>
            <data type="token">
               <param name="pattern">\d+(\.)*</param>
            </data>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.hairpin.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.layer.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.line.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.measure.ges.attributes">
      <ref name="tei_mei_att.timestamp.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.mSpace.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.note.ges.attributes">
      <ref name="tei_mei_att.accidental.gestural.attributes"/>
      <ref name="tei_mei_att.articulation.gestural.attributes"/>
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.note.ges.attribute.extremis"/>
      <ref name="tei_mei_att.note.ges.attribute.oct.ges"/>
      <ref name="tei_mei_att.note.ges.attribute.pname.ges"/>
      <ref name="tei_mei_att.note.ges.attribute.pnum"/>
   </define>
   <define name="tei_mei_att.note.ges.attribute.extremis">
      <optional>
         <attribute name="extremis">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates an extreme, indefinite performed pitch.</a:documentation>
            <choice>
               <value>highest</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Highest note the performer can play.</a:documentation>
               <value>lowest</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Lowest note the performer can play.</a:documentation>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.note.ges.attribute.oct.ges">
      <optional>
         <attribute name="oct.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records performed octave information that differs from the written value.</a:documentation>
            <ref name="mei_data.OCTAVE"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.note.ges.attribute.pname.ges">
      <optional>
         <attribute name="pname.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Contains a performed pitch name that differs from the written value.</a:documentation>
            <ref name="mei_data.PITCHNAME.GES"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.note.ges.attribute.pnum">
      <optional>
         <attribute name="pnum">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Holds a pitch-to-number mapping, a base-40 or MIDI note number, for example.</a:documentation>
            <ref name="mei_data.PITCHNUMBER"/>
         </attribute>
      </optional>
   </define>
   <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
            id="asue-mei_att.note.ges-extremis_disallows_gestural_pitch-constraint-rule-79">
      <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                xmlns:telota="http://www.telota.de"
                xmlns:rng="http://relaxng.org/ns/structure/1.0"
                xmlns:mei="http://www.music-encoding.org/ns/mei"
                xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                xmlns="http://www.tei-c.org/ns/1.0"
                context="mei:note[@extremis]">
         <sch:assert test="not(@pname.ges) and not(@oct.ges)">When the @extremis attribute is used,
            the @pname.ges and @oct.ges attributes are not allowed.</sch:assert>
      </sch:rule>
   </pattern>
   <define name="tei_mei_att.rest.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.sb.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.score.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.scoreDef.ges.attributes">
      <ref name="tei_mei_att.mmTempo.attributes"/>
      <ref name="tei_mei_att.scoreDef.ges.attribute.tune.pname"/>
      <ref name="tei_mei_att.scoreDef.ges.attribute.tune.Hz"/>
      <ref name="tei_mei_att.scoreDef.ges.attribute.tune.temper"/>
   </define>
   <define name="tei_mei_att.scoreDef.ges.attribute.tune.pname">
      <optional>
         <attribute name="tune.pname">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Holds the pitch name of a tuning reference pitch.</a:documentation>
            <ref name="mei_data.PITCHNAME"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.scoreDef.ges.attribute.tune.Hz">
      <optional>
         <attribute name="tune.Hz">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Holds a value for cycles per second, i.e., Hertz, for a tuning reference pitch.</a:documentation>
            <data type="decimal"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.scoreDef.ges.attribute.tune.temper">
      <optional>
         <attribute name="tune.temper">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Provides an indication of the tuning system, 'just', for example.</a:documentation>
            <ref name="mei_data.TEMPERAMENT"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.section.ges.attributes">
      <ref name="tei_mei_att.section.ges.attribute.attacca"/>
   </define>
   <define name="tei_mei_att.section.ges.attribute.attacca">
      <optional>
         <attribute name="attacca">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates that the performance of the next section should begin immediately following this one.</a:documentation>
            <ref name="mei_data.BOOLEAN"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.slur.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.space.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.staff.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.staffDef.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.staffGrp.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.syl.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.tempo.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.tie.ges.attributes">
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.timestamp.gestural.attributes">
      <ref name="tei_mei_att.timestamp.gestural.attribute.tstamp.ges"/>
      <ref name="tei_mei_att.timestamp.gestural.attribute.tstamp.real"/>
   </define>
   <define name="tei_mei_att.timestamp.gestural.attribute.tstamp.ges">
      <optional>
         <attribute name="tstamp.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Encodes the onset time in terms of musical time, i.e., beats[.fractional beat part], as expressed in the written time signature.</a:documentation>
            <ref name="mei_data.BEAT"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.timestamp.gestural.attribute.tstamp.real">
      <optional>
         <attribute name="tstamp.real">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the onset time in terms of ISO time.</a:documentation>
            <ref name="mei_data.ISOTIME"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.timestamp2.gestural.attributes">
      <ref name="tei_mei_att.timestamp2.gestural.attribute.tstamp2.ges"/>
      <ref name="tei_mei_att.timestamp2.gestural.attribute.tstamp2.real"/>
   </define>
   <define name="tei_mei_att.timestamp2.gestural.attribute.tstamp2.ges">
      <optional>
         <attribute name="tstamp2.ges">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Encodes the ending point of an event, i.e., a count of measures plus a beat location in the ending measure.</a:documentation>
            <ref name="mei_data.MEASUREBEAT"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.timestamp2.gestural.attribute.tstamp2.real">
      <optional>
         <attribute name="tstamp2.real">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Records the ending point of an event in terms of ISO time.</a:documentation>
            <ref name="mei_data.ISOTIME"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.trill.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
      <ref name="tei_mei_att.timestamp2.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.tuplet.ges.attributes">
      <ref name="tei_mei_att.duration.gestural.attributes"/>
   </define>
   <define name="tei_mei_att.verse.ges.attributes">
      <empty/>
   </define>
   <define name="tei_mei_att.verse.log.attributes">
      <empty/>
   </define>
   <define name="tei_mei_model.verseLike">
      <choice>
         <ref name="mei_verse"/>
      </choice>
   </define>
   <define name="tei_mei_model.verseLike_alternation">
      <choice>
         <ref name="mei_verse"/>
      </choice>
   </define>
   <define name="tei_mei_model.verseLike_sequence">
      <ref name="mei_verse"/>
   </define>
   <define name="tei_mei_model.verseLike_sequenceOptional">
      <optional>
         <ref name="mei_verse"/>
      </optional>
   </define>
   <define name="tei_mei_model.verseLike_sequenceOptionalRepeatable">
      <zeroOrMore>
         <ref name="mei_verse"/>
      </zeroOrMore>
   </define>
   <define name="tei_mei_model.verseLike_sequenceRepeatable">
      <oneOrMore>
         <ref name="mei_verse"/>
      </oneOrMore>
   </define>
   <define name="mei_verse">
      <element name="verse" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Division of a poem or song lyrics, sometimes having a fixed length, meter or rhyme scheme; a stanza.</a:documentation>
         <zeroOrMore>
            <ref name="mei_label"/>
         </zeroOrMore>
         <zeroOrMore>
            <choice>
               <ref name="mei_dir"/>
               <ref name="mei_tempo"/>
               <ref name="mei_space"/>
            </choice>
         </zeroOrMore>
         <oneOrMore>
            <choice>
               <ref name="tei_mei_model.sylLike"/>
            </choice>
         </oneOrMore>
         <zeroOrMore>
            <ref name="tei_mei_model.lbLike"/>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.lang.attributes"/>
         <ref name="tei_mei_att.verse.log.attributes"/>
         <ref name="tei_mei_att.verse.vis.attributes"/>
         <ref name="tei_mei_att.verse.ges.attributes"/>
         <ref name="tei_mei_att.verse.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="tei_mei_att.altSym.attributes">
      <ref name="tei_mei_att.altSym.attribute.altsym"/>
   </define>
   <define name="tei_mei_att.altSym.attribute.altsym">
      <optional>
         <attribute name="altsym">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Provides a way of pointing to a user-defined symbol. It must contain a reference to an ID of a <code xmlns="http://www.w3.org/1999/xhtml">&lt;symbolDef&gt;</code> element elsewhere in the document.</a:documentation>
            <ref name="mei_data.URI"/>
         </attribute>
      </optional>
   </define>
   <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
            id="asue-mei_att.altSym-altsym-check_altsymTarget-constraint-rule-80">
      <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                xmlns:telota="http://www.telota.de"
                xmlns:rng="http://relaxng.org/ns/structure/1.0"
                xmlns:mei="http://www.music-encoding.org/ns/mei"
                xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                xmlns="http://www.tei-c.org/ns/1.0"
                context="@altsym">
         <sch:assert role="warning" test="not(normalize-space(.) eq '')">@altsym attribute
                should have content.</sch:assert>
         <sch:assert role="warning"
                     test="every $i in tokenize(., '\s+') satisfies substring($i,2)=//mei:symbolDef/@xml:id">The value in @altsym should correspond to the @xml:id attribute of a symbolDef
                element.</sch:assert>
         <sch:assert test="not(substring(., 2) eq ancestor::mei:symbolDef/@xml:id)">The value
                in @altsym must not correspond to the @xml:id attribute of a symbolDef
                ancestor.</sch:assert>
      </sch:rule>
   </pattern>
   <define name="tei_mei_att.line.log.attributes">
      <ref name="tei_mei_att.controlEvent.attributes"/>
      <ref name="tei_mei_att.duration.additive.attributes"/>
      <ref name="tei_mei_att.startEndId.attributes"/>
      <ref name="tei_mei_att.timestamp2.logical.attributes"/>
      <ref name="tei_mei_att.line.log.attribute.func"/>
   </define>
   <define name="tei_mei_att.line.log.attribute.func">
      <optional>
         <attribute name="func">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates the function of the line.
Suggested values include: 1] coloration; 2] ligature; 3] unknown</a:documentation>
            <choice>
               <value>coloration</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates coloration in material transcribed from a source originally in mensural notation.</a:documentation>
               <value>ligature</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Marks a ligature in material transcribed from a source originally in mensural notation.</a:documentation>
               <value>unknown</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">The function of the line is unknown.</a:documentation>
               <data type="NMTOKEN"/>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_model.graphicPrimitiveLike">
      <choice>
         <ref name="mei_line"/>
      </choice>
   </define>
   <define name="tei_mei_model.symbolTableLike">
      <notAllowed/>
   </define>
   <define name="mei_line">
      <element name="line" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A visual line that cannot be represented by a more specific; i.e., semantic, element.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike.limited"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-line-line_start-_and_end-type_attributes_required-constraint-rule-81">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:line[ancestor::mei:symbolDef]">
               <sch:assert test="@startid or (@x and @y)">When used in the symbolDef context, must have
            either a startid attribute or x and y attributes.</sch:assert>
               <sch:assert test="@endid or (@x2 and @y2)">When used in the symbolDef context, must have
            either an endid attribute or both x2 and y2 attributes.</sch:assert>
            </sch:rule>
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:line[not(ancestor::mei:symbolDef)]">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real or (@x and @y)">When
            used in the score context, must have a startid, tstamp, tstamp.ges or tstamp.real
            attribute or both x and y attributes.</sch:assert>
               <sch:assert test="@dur or @dur.ges or @endid or @tstamp2 or (@x2 and @y2)">When used in
            the score context, must have an endid, dur, dur.ges, or tstamp2 attribute or both x2 and
            y2 attributes.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.line.anl.attributes"/>
         <ref name="tei_mei_att.line.ges.attributes"/>
         <ref name="tei_mei_att.line.log.attributes"/>
         <ref name="tei_mei_att.line.vis.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="tei_mei_att.artic.vis.attributes">
      <ref name="tei_mei_att.altSym.attributes"/>
      <ref name="tei_mei_att.color.attributes"/>
      <ref name="tei_mei_att.enclosingChars.attributes"/>
      <ref name="tei_mei_att.extSym.attributes"/>
      <ref name="tei_mei_att.placement.attributes"/>
      <ref name="tei_mei_att.staffLoc.attributes"/>
      <ref name="tei_mei_att.staffLoc.pitched.attributes"/>
      <ref name="tei_mei_att.typography.attributes"/>
      <ref name="tei_mei_att.visualOffset.attributes"/>
      <ref name="tei_mei_att.xy.attributes"/>
   </define>
   <define name="tei_mei_att.beam.vis.attributes">
      <ref name="tei_mei_att.color.attributes"/>
      <ref name="tei_mei_att.cue.attributes"/>
      <ref name="tei_mei_att.beamRend.attributes"/>
   </define>
   <define name="tei_mei_att.beaming.vis.attributes">
      <ref name="tei_mei_att.beaming.vis.attribute.beam.color"/>
      <ref name="tei_mei_att.beaming.vis.attribute.beam.rend"/>
      <ref name="tei_mei_att.beaming.vis.attribute.beam.slope"/>
   </define>
   <define name="tei_mei_att.beaming.vis.attribute.beam.color">
      <optional>
         <attribute name="beam.color">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Color of beams, including those associated with tuplets.</a:documentation>
            <ref name="mei_data.COLOR"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beaming.vis.attribute.beam.rend">
      <optional>
         <attribute name="beam.rend">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Encodes whether a beam is "feathered" and in which direction.</a:documentation>
            <choice>
               <value>acc</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Beam lines grow farther apart from left to right.</a:documentation>
               <value>rit</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Beam lines grow closer together from left to right.</a:documentation>
               <value>norm</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Beam lines are equally-spaced over the entire length of the beam.</a:documentation>
            </choice>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.beaming.vis.attribute.beam.slope">
      <optional>
         <attribute name="beam.slope">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Captures beam slope.</a:documentation>
            <data type="decimal"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.bracketSpan.vis.attributes">
      <ref name="tei_mei_att.altSym.attributes"/>
      <ref name="tei_mei_att.color.attributes"/>
      <ref name="tei_mei_att.extSym.attributes"/>
      <ref name="tei_mei_att.lineRend.attributes"/>
      <ref name="tei_mei_att.typography.attributes"/>
      <ref name="tei_mei_att.visualOffset.attributes"/>
      <ref name="tei_mei_att.visualOffset2.attributes"/>
      <ref name="tei_mei_att.xy.attributes"/>
      <ref name="tei_mei_att.xy2.attributes"/>
   </define>
   <define name="tei_mei_att.chord.vis.attributes">
      <ref name="tei_mei_att.altSym.attributes"/>
      <ref name="tei_mei_att.color.attributes"/>
      <ref name="tei_mei_att.enclosingChars.attributes"/>
      <ref name="tei_mei_att.extSym.attributes"/>
