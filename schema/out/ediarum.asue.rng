   </define>
   <define name="tei_mei_att.slurRend.attribute.slur.lform">
      <optional>
         <attribute name="slur.lform">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
            <ref name="mei_data.LINEFORM"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.slurRend.attribute.slur.lwidth">
      <optional>
         <attribute name="slur.lwidth">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
            <ref name="mei_data.LINEWIDTH"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.space.anl.cmn.attributes">
      <ref name="tei_mei_att.beamPresent.attributes"/>
      <ref name="tei_mei_att.fermataPresent.attributes"/>
      <ref name="tei_mei_att.tupletPresent.attributes"/>
   </define>
   <define name="tei_mei_att.staffDef.log.cmn.attributes">
      <ref name="tei_mei_att.beaming.log.attributes"/>
   </define>
   <define name="tei_mei_att.staffDef.vis.cmn.attributes">
      <ref name="tei_mei_att.beaming.vis.attributes"/>
      <ref name="tei_mei_att.pianoPedals.attributes"/>
      <ref name="tei_mei_att.rehearsal.attributes"/>
      <ref name="tei_mei_att.slurRend.attributes"/>
      <ref name="tei_mei_att.tieRend.attributes"/>
   </define>
   <define name="tei_mei_att.stems.cmn.attributes">
      <ref name="tei_mei_att.stems.cmn.attribute.stem.with"/>
   </define>
   <define name="tei_mei_att.stems.cmn.attribute.stem.with">
      <optional>
         <attribute name="stem.with">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Contains an indication of which staff a note or chord that logically belongs to the current staff should be visually placed on; that is, the one above or the one below.</a:documentation>
            <ref name="mei_data.OTHERSTAFF"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.tie.log.attributes">
      <ref name="tei_mei_att.controlEvent.attributes"/>
      <ref name="tei_mei_att.startEndId.attributes"/>
      <ref name="tei_mei_att.timestamp2.logical.attributes"/>
   </define>
   <define name="tei_mei_att.tieRend.attributes">
      <ref name="tei_mei_att.tieRend.attribute.tie.lform"/>
      <ref name="tei_mei_att.tieRend.attribute.tie.lwidth"/>
   </define>
   <define name="tei_mei_att.tieRend.attribute.tie.lform">
      <optional>
         <attribute name="tie.lform">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
            <ref name="mei_data.LINEFORM"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.tieRend.attribute.tie.lwidth">
      <optional>
         <attribute name="tie.lwidth">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0"/>
            <ref name="mei_data.LINEWIDTH"/>
         </attribute>
      </optional>
   </define>
   <define name="tei_mei_att.tuplet.log.attributes">
      <ref name="tei_mei_att.beamedWith.attributes"/>
      <ref name="tei_mei_att.duration.additive.attributes"/>
      <ref name="tei_mei_att.duration.ratio.attributes"/>
      <ref name="tei_mei_att.event.attributes"/>
      <ref name="tei_mei_att.startEndId.attributes"/>
   </define>
   <define name="tei_mei_model.controlEventLike.cmn">
      <choice>
         <ref name="mei_bracketSpan"/>
         <ref name="mei_hairpin"/>
         <ref name="mei_slur"/>
         <ref name="mei_tie"/>
         <ref name="tei_mei_model.ornamentLike.cmn"/>
      </choice>
   </define>
   <define name="tei_mei_model.controlEventLike.cmn_alternation">
      <choice>
         <ref name="mei_bracketSpan"/>
         <ref name="mei_hairpin"/>
         <ref name="mei_slur"/>
         <ref name="mei_tie"/>
         <ref name="tei_mei_model.ornamentLike.cmn_alternation"/>
      </choice>
   </define>
   <define name="tei_mei_model.controlEventLike.cmn_sequence">
      <ref name="mei_bracketSpan"/>
      <ref name="mei_hairpin"/>
      <ref name="mei_slur"/>
      <ref name="mei_tie"/>
      <ref name="tei_mei_model.ornamentLike.cmn_sequence"/>
   </define>
   <define name="tei_mei_model.controlEventLike.cmn_sequenceOptional">
      <optional>
         <ref name="mei_bracketSpan"/>
      </optional>
      <optional>
         <ref name="mei_hairpin"/>
      </optional>
      <optional>
         <ref name="mei_slur"/>
      </optional>
      <optional>
         <ref name="mei_tie"/>
      </optional>
      <optional>
         <ref name="tei_mei_model.ornamentLike.cmn_sequenceOptional"/>
      </optional>
   </define>
   <define name="tei_mei_model.controlEventLike.cmn_sequenceOptionalRepeatable">
      <zeroOrMore>
         <ref name="mei_bracketSpan"/>
      </zeroOrMore>
      <zeroOrMore>
         <ref name="mei_hairpin"/>
      </zeroOrMore>
      <zeroOrMore>
         <ref name="mei_slur"/>
      </zeroOrMore>
      <zeroOrMore>
         <ref name="mei_tie"/>
      </zeroOrMore>
      <zeroOrMore>
         <ref name="tei_mei_model.ornamentLike.cmn_sequenceOptionalRepeatable"/>
      </zeroOrMore>
   </define>
   <define name="tei_mei_model.controlEventLike.cmn_sequenceRepeatable">
      <oneOrMore>
         <ref name="mei_bracketSpan"/>
      </oneOrMore>
      <oneOrMore>
         <ref name="mei_hairpin"/>
      </oneOrMore>
      <oneOrMore>
         <ref name="mei_slur"/>
      </oneOrMore>
      <oneOrMore>
         <ref name="mei_tie"/>
      </oneOrMore>
      <oneOrMore>
         <ref name="tei_mei_model.ornamentLike.cmn_sequenceRepeatable"/>
      </oneOrMore>
   </define>
   <define name="tei_mei_model.eventLike.cmn">
      <choice>
         <ref name="mei_beam"/>
         <ref name="mei_tuplet"/>
      </choice>
   </define>
   <define name="tei_mei_model.eventLike.cmn_alternation">
      <choice>
         <ref name="mei_beam"/>
         <ref name="mei_tuplet"/>
      </choice>
   </define>
   <define name="tei_mei_model.eventLike.cmn_sequence">
      <ref name="mei_beam"/>
      <ref name="mei_tuplet"/>
   </define>
   <define name="tei_mei_model.eventLike.cmn_sequenceOptional">
      <optional>
         <ref name="mei_beam"/>
      </optional>
      <optional>
         <ref name="mei_tuplet"/>
      </optional>
   </define>
   <define name="tei_mei_model.eventLike.cmn_sequenceOptionalRepeatable">
      <zeroOrMore>
         <ref name="mei_beam"/>
      </zeroOrMore>
      <zeroOrMore>
         <ref name="mei_tuplet"/>
      </zeroOrMore>
   </define>
   <define name="tei_mei_model.eventLike.cmn_sequenceRepeatable">
      <oneOrMore>
         <ref name="mei_beam"/>
      </oneOrMore>
      <oneOrMore>
         <ref name="mei_tuplet"/>
      </oneOrMore>
   </define>
   <define name="tei_mei_model.eventLike.measureFilling">
      <choice>
         <ref name="mei_mSpace"/>
      </choice>
   </define>
   <define name="tei_mei_model.eventLike.measureFilling_alternation">
      <choice>
         <ref name="mei_mSpace"/>
      </choice>
   </define>
   <define name="tei_mei_model.eventLike.measureFilling_sequence">
      <ref name="mei_mSpace"/>
   </define>
   <define name="tei_mei_model.eventLike.measureFilling_sequenceOptional">
      <optional>
         <ref name="mei_mSpace"/>
      </optional>
   </define>
   <define name="tei_mei_model.eventLike.measureFilling_sequenceOptionalRepeatable">
      <zeroOrMore>
         <ref name="mei_mSpace"/>
      </zeroOrMore>
   </define>
   <define name="tei_mei_model.eventLike.measureFilling_sequenceRepeatable">
      <oneOrMore>
         <ref name="mei_mSpace"/>
      </oneOrMore>
   </define>
   <define name="tei_mei_model.layerPart.cmn">
      <choice>
         <ref name="tei_mei_model.eventLike.cmn"/>
         <ref name="tei_mei_model.eventLike.measureFilling"/>
      </choice>
   </define>
   <define name="tei_mei_model.measureLike">
      <choice>
         <ref name="mei_measure"/>
      </choice>
   </define>
   <define name="tei_mei_model.measureLike_alternation">
      <choice>
         <ref name="mei_measure"/>
      </choice>
   </define>
   <define name="tei_mei_model.measureLike_sequence">
      <ref name="mei_measure"/>
   </define>
   <define name="tei_mei_model.measureLike_sequenceOptional">
      <optional>
         <ref name="mei_measure"/>
      </optional>
   </define>
   <define name="tei_mei_model.measureLike_sequenceOptionalRepeatable">
      <zeroOrMore>
         <ref name="mei_measure"/>
      </zeroOrMore>
   </define>
   <define name="tei_mei_model.measureLike_sequenceRepeatable">
      <oneOrMore>
         <ref name="mei_measure"/>
      </oneOrMore>
   </define>
   <define name="tei_mei_model.measurePart">
      <choice>
         <ref name="tei_mei_model.controlEventLike"/>
         <ref name="tei_mei_model.staffLike"/>
         <ref name="tei_mei_model.controlEventLike.cmn"/>
         <ref name="tei_mei_model.ossiaLike"/>
      </choice>
   </define>
   <define name="tei_mei_model.ossiaLike">
      <notAllowed/>
   </define>
   <define name="tei_mei_model.sectionPart.cmn">
      <choice>
         <ref name="tei_mei_model.measureLike"/>
      </choice>
   </define>
   <define name="mei_beam">
      <element name="beam" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A container for a series of explicitly beamed events that begins and ends entirely within a measure.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.eventLike"/>
               <ref name="tei_mei_model.eventLike.cmn"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-beam-When_not_copyof_beam_content-constraint-rule-69">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:beam[not(@copyof)]">
               <sch:assert test="count(descendant::*[local-name()='note' or local-name()='rest' or               local-name()='chord' or local-name()='space']) &gt; 1">A beam without a copyof attribute must have at least 2 note, rest, chord, or space
            descendants.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.beam.log.attributes"/>
         <ref name="tei_mei_att.beam.vis.attributes"/>
         <ref name="tei_mei_att.beam.ges.attributes"/>
         <ref name="tei_mei_att.beam.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_bracketSpan">
      <element name="bracketSpan" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Marks a sequence of notational events grouped by a bracket.</a:documentation>
         <zeroOrMore>
            <choice>
               <text/>
               <ref name="tei_mei_model.textPhraseLike.limited"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-bracketSpan-bracketSpan_start-_and_end-type_attributes_required-constraint-rule-70">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:bracketSpan">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
               <sch:assert test="@dur or @dur.ges or @endid or @tstamp2">Must have one of the attributes:
            dur, dur.ges, endid, or tstamp2.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.bracketSpan.log.attributes"/>
         <ref name="tei_mei_att.bracketSpan.vis.attributes"/>
         <ref name="tei_mei_att.bracketSpan.ges.attributes"/>
         <ref name="tei_mei_att.bracketSpan.anl.attributes"/>
         <attribute name="func">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Describes the function of the bracketed event sequence.
Suggested values include: 1] coloration; 2] cross-rhythm; 3] ligature</a:documentation>
            <choice>
               <value>coloration</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Represents coloration in the mensural notation source material.</a:documentation>
               <value>cross-rhythm</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Marks a sequence which does not match the current meter.</a:documentation>
               <value>ligature</value>
               <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Represents a ligature in the mensural notation source material.</a:documentation>
               <data type="NMTOKENS"/>
            </choice>
         </attribute>
         <empty/>
      </element>
   </define>
   <define name="mei_hairpin">
      <element name="hairpin" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indicates continuous dynamics expressed on the score as wedge-shaped graphics, e.g. &lt; and &gt;.</a:documentation>
         <empty/>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-hairpin-hairpin_start-_and_end-type_attributes_required-constraint-rule-71">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:hairpin">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
               <sch:assert test="@dur or @dur.ges or @endid or @tstamp2">Must have one of the attributes:
            dur, dur.ges, endid, or tstamp2.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.hairpin.log.attributes"/>
         <ref name="tei_mei_att.hairpin.vis.attributes"/>
         <ref name="tei_mei_att.hairpin.ges.attributes"/>
         <ref name="tei_mei_att.hairpin.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_measure">
      <element name="measure" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Unit of musical time consisting of a fixed number of note values of a given type, as determined by the prevailing meter, and delimited in musical notation by bar lines.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.annotLike"/>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.graphicPrimitiveLike"/>
               <ref name="tei_mei_model.measurePart"/>
               <ref name="tei_mei_model.milestoneLike.music"/>
               <ref name="tei_mei_model.relationLike"/>
               <ref name="tei_mei_model.staffDefLike"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.metadataPointing.attributes"/>
         <ref name="tei_mei_att.pointing.attributes"/>
         <ref name="tei_mei_att.measure.anl.attributes"/>
         <ref name="tei_mei_att.measure.ges.attributes"/>
         <ref name="tei_mei_att.measure.log.attributes"/>
         <ref name="tei_mei_att.measure.vis.attributes"/>
         <ref name="tei_mei_att.targetEval.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_mSpace">
      <element name="mSpace" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">(measure space) – A measure containing only empty space in any meter.</a:documentation>
         <empty/>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.mSpace.log.attributes"/>
         <ref name="tei_mei_att.mSpace.vis.attributes"/>
         <ref name="tei_mei_att.mSpace.ges.attributes"/>
         <ref name="tei_mei_att.mSpace.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_slur">
      <element name="slur" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">Indication of 1) a "unified melodic idea" or 2) performance technique.</a:documentation>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-slur-slur_start-_and_end-type_attributes_required-constraint-rule-72">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:slur">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
               <sch:assert test="@dur or @dur.ges or @endid or @tstamp2">Must have one of the attributes:
            dur, dur.ges, endid, or tstamp2.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-slur-slur_containing_curve-constraint-rule-73">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:slur[mei:curve[@bezier or @bulge or @curvedir or @lform or @lwidth or              @ho or @startho or @endho or @to or @startto or @endto or @vo or @startvo or @endvo or              @x or @y or @x2 or @y2]]">
               <sch:assert test="not(@bezier or @bulge or @curvedir or @lform or @lwidth or @ho or @startho or                @endho or @to or @startto or @endto or @vo or @startvo or @endvo or @x or @y or @x2 or @y2)"
                           role="warning">The visual attributes of the slur (@bezier, @bulge, @curvedir, @lform,
            @lwidth, @ho, @startho, @endho, @to, @startto, @endto, @vo, @startvo, @endvo, @x, @y,
            @x2, and @y2) will be overridden by visual attributes of the contained curve
            elements.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.slur.log.attributes"/>
         <ref name="tei_mei_att.slur.vis.attributes"/>
         <ref name="tei_mei_att.slur.ges.attributes"/>
         <ref name="tei_mei_att.slur.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_tie">
      <element name="tie" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">An indication that two notes of the same pitch form a single note with their combined rhythmic values.</a:documentation>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-tie-tie_start-_and_end-type_attributes_required-constraint-rule-74">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:tie">
               <sch:assert test="@startid or @tstamp or @tstamp.ges or @tstamp.real">Must have one of the
            attributes: startid, tstamp, tstamp.ges or tstamp.real.</sch:assert>
               <sch:assert test="@dur or @dur.ges or @endid or @tstamp2">Must have one of the attributes:
            dur, dur.ges, endid, or tstamp2.</sch:assert>
            </sch:rule>
         </pattern>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-tie-tie_containing_curve-constraint-rule-75">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:tie[mei:curve[@bezier or @bulge or @curvedir or @lform or @lwidth or              @ho or @startho or @endho or @to or @startto or @endto or @vo or @startvo or              @endvo or @x or @y or @x2 or @y2]]">
               <sch:assert test="not(@bezier or @bulge or @curvedir or @lform or @lwidth or @ho or @startho or                @endho or @to or @startto or @endto or @vo or @startvo or @endvo or @x or @y or @x2 or @y2)"
                           role="warning">The visual attributes of the tie (@bezier, @bulge, @curvedir, @lform,
            @lwidth, @ho, @startho, @endho, @to, @startto, @endto, @vo, @startvo, @endvo, @x, @y,
            @x2, and @y2) will be overridden by visual attributes of the contained curve
            elements.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.tie.log.attributes"/>
         <ref name="tei_mei_att.tie.vis.attributes"/>
         <ref name="tei_mei_att.tie.ges.attributes"/>
         <ref name="tei_mei_att.tie.anl.attributes"/>
         <empty/>
      </element>
   </define>
   <define name="mei_tuplet">
      <element name="tuplet" ns="http://www.music-encoding.org/ns/mei">
         <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">A group of notes with "irregular" (sometimes called "irrational") rhythmic values, for example, three notes in the time normally occupied by two or nine in the time of five.</a:documentation>
         <zeroOrMore>
            <choice>
               <ref name="tei_mei_model.editLike"/>
               <ref name="tei_mei_model.eventLike"/>
               <ref name="tei_mei_model.eventLike.cmn"/>
               <ref name="tei_mei_model.transcriptionLike"/>
            </choice>
         </zeroOrMore>
         <pattern xmlns="http://purl.oclc.org/dsdl/schematron"
                  id="asue-tuplet-When_not_copyof_tuplet_content-constraint-rule-76">
            <sch:rule xmlns:xi="http://www.w3.org/2001/XInclude"
                      xmlns:telota="http://www.telota.de"
                      xmlns:rng="http://relaxng.org/ns/structure/1.0"
                      xmlns:mei="http://www.music-encoding.org/ns/mei"
                      xmlns:sch="http://purl.oclc.org/dsdl/schematron"
                      xmlns="http://www.tei-c.org/ns/1.0"
                      context="mei:tuplet[not(@copyof)]">
               <sch:assert test="count(descendant::*[local-name()='note' or local-name()='rest' or               local-name()='chord']) &gt; 1">A tuplet without a copyof attribute must have at least 2 note, rest, or chord
            descendants.</sch:assert>
            </sch:rule>
         </pattern>
         <ref name="tei_mei_att.common.attributes"/>
         <ref name="tei_mei_att.tuplet.log.attributes"/>
         <ref name="tei_mei_att.tuplet.vis.attributes"/>
