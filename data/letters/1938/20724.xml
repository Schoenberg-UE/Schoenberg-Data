    <text>
        <body>
            <div type="letter">
                <div type="writingSession" n="1" hand="#author">
                    <pb n="1" xml:id="p.1"/>
                    <opener>
                        <stamp sameAs="stamp.45">
                            <orgName key="org.1">Universal-Edition·A. G.</orgName>
                            <lb/>WIEN·I·<placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                            <lb/>Musikvereinsgebäude</stamp>
                        <address>
                            <addrLine>Herrn Professor</addrLine>
                            <addrLine>
                                <persName key="pers.3263">Arnold Schoenberg</persName>
                            </addrLine>
                            <addrLine>
                                <placeName key="place.15.7.3.1">116 N. Rockingham Ave.</placeName>
                            </addrLine>
                            <addrLine>Brentwood Park</addrLine>
                            <addrLine>
                                <hi rendition="#g">Los Angeles</hi>
                            </addrLine>
                            <addrLine>California</addrLine>
                        </address>
                        <pb n="2" xml:id="p.2"/>
                        <persName key="pers.3065">Dr. R</persName>/<persName key="pers.1740">Ks.</persName>
                        <dateline>
                            <placeName key="place.9.11">Wien</placeName>, <date when="1938-04-01">1.
                                April 1938</date>.</dateline>
                        <address>
                            <addrLine>Herrn Professor</addrLine>
                            <addrLine>
                                <persName key="pers.3263">Arnold Schoenberg</persName>
                            </addrLine>
                            <addrLine>
                                <hi rendition="#u">
                                    <placeName key="place.15.7">Los Angeles</placeName>.</hi>
                            </addrLine>
                        </address>
                    </opener>
                    <salute>Sehr verehrter <rs type="person" key="pers.3263">Meister</rs>!</salute>
                    <p>Wir danken für Ihre freundl. <ref target="letter.23627">Mitteilung</ref> vom
                            <date when="1938-03-17">17. <lb/>III.</date> und die gesandten Formulare
                        zur Verlängerung des <lb/>copyrights. Der Einsendung der Liste von <orgName key="org.131">Philharmo<g ref="#typoHyphen"/>
                            <lb break="no"/>nia</orgName> Partituren, die Sie zu Lasten Ihres Kontos
                            kau<g ref="#typoHyphen"/>
                        <lb break="no"/>fen wollen, sehen wir gerne entgegen. Wir werden Ihnen
                        <lb/>die gewünschten Partituren sogleich nach Erhalt der <lb/>Liste zugehen
                        lassen. Von <persName key="pers.1097">Cesar Franck</persName> ist in der <lb/>
                        <orgName key="org.131">Philharmonia</orgName> Sammlung nichts
                        erschienen.</p>
                    <closer>
                        <salute>Wir empfehlen uns<add place="intralinear" hand="#pers.4190">, mit
                                besten Grüßen u. Wünschen</add>
                            <lb/>
                            <seg rendition="#r">in vorzüglicher Hochachtung</seg>
                        </salute>
                        <lb/>
                        <stamp sameAs="stamp.46" rendition="#r">
                            <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                        </stamp>
                        <lb/>
                        <signed rendition="#r">
                            <persName key="pers.4190">Winter</persName>
                        </signed>
                        <signed rendition="#r">D<hi rendition="#sup">r</hi>
                            <persName key="pers.3065">Roth</persName>
                        </signed>
                    </closer>
                </div>
                <div type="writingSession" n="2" hand="#pers.4190">
                    <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>,</salute>
                    <p>wir alle von der alten <orgName key="org.1">U.E.</orgName>
                        <lb/>Garde haben gerade in den letzten Wochen viel <lb/>an Sie gedacht und
                        danken Ihnen vielmals daß <lb/>Sie sich um unser aller Schicksal
                        interessieren. Es geht <lb/>uns soweit gut. Herr <persName key="pers.3612">Stein</persName> wird sich erlauben Ihnen <lb/>ausführlich zu
                        schreiben. </p>
                    <closer rendition="#inline">
                        <salute>Ergebene Grüße</salute>
                        <signed>
                            <persName key="pers.4190">Hugo Winter</persName>
                        </signed>.</closer>
                </div>
                <pb n="3" sameAs="p.1"/>
                <div type="writingSession" n="3" hand="#pers.3067">
                    <salute>Die besten Empfehlungen <lb/>und herzliche Grüße <lb/>auch an Ihre Frau
                            <rs type="person" key="pers.3297">Gemahlin</rs>
                        <lb/>von Ihrer</salute>
                    <signed>
                        <persName key="pers.3067">B Rothe</persName>
                    </signed>
                </div>
            </div>
        </body>
    </text>
