    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.45">
                        <orgName key="org.1">Universal-Edition·A. G.</orgName>
                        <lb/>WIEN·I·<placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                        <lb/>Musikvereinsgebäude</stamp>
                    <address>
                        <lb/>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schoenberg</persName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 North Rockingham Ave</placeName>
                        </addrLine>
                        <addrLine>Brentwood Park</addrLine>
                        <addrLine>
                            <hi rendition="#g">Los Angeles</hi>
                        </addrLine>
                        <addrLine>Californien</addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.4357">Bau</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1938-03-23">23. März
                        1938</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schoenberg</persName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 North Rockingham Avenue</placeName>
                        </addrLine>
                        <addrLine>Brentwood Park</addrLine>
                        <addrLine>
                            <hi rendition="#u">
                                <hi rendition="#g">Los Angeles</hi>, Calif.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir verweisen auf unsere <lb/>Schreiben v. <ref target="letter.20720">
                        <date when="1937-11-12">12. XI., v. J.</date>
                    </ref>, <ref target="letter.20721">
                        <date when="1937-12-30">30. XII. v. J.</date>
                    </ref>
                    und <ref target="letter.23626">
                        <date when="1938-02-19">19. II. d.
                        J.</date>
                    </ref>
                    <lb/>in Angelegenheit der Copyright-Verlängerung Ihrer <lb/>
                    <bibl sameAs="werke.9">Klavierstücke</bibl> und bitten heute nochmals um <hi rendition="#u">eheste</hi>
                    <lb/>Rücksendung der unterfertigten Erklärungen, damit <lb/>wir den Termin für
                    die Verlängerung nicht versäumen.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">in vorzüglicher Hochachtung</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.90" rendition="#r">„<orgName key="org.1">Universal Edition
                            Actiengesellschaft</orgName>“</stamp>
                    <lb/>
                    <signed rendition="#r">D<hi rendition="#sup">r</hi>
                        <persName key="pers.3065">Roth</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
