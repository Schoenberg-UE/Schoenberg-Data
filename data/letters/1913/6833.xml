    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p>Bitte schicken Sie <lb/>
                    <seg rendition="#c">„über Ersuchen des Kompon.“ <lb/>an
                        Herrn <persName key="pers.3237">Artur Schnabel</persName>
                        <lb/>
                        <hi rendition="#u">Berlin Charlottenburg</hi>
                        <lb/>
                        <placeName key="place.2.8.2">Wielandstraße 14</placeName>
                    </seg>
                    <lb/>einen Gurre Lieder <bibl sameAs="werke.17">Auszug</bibl>
                    <lb/>und eine <ellipsis>
                        <metamark function="ellipsis">〃</metamark>
                        <supplied>Gurre</supplied>
                    </ellipsis>
                    <ellipsis>
                        <metamark function="ellipsis">〃</metamark>
                        <supplied>Lieder</supplied>
                    </ellipsis>
                    <bibl sameAs="werke.16">Partitur</bibl>
                </p>
                <milestone unit="section" rendition="#hr"/>
                <p>
                    <seg type="comment">
                        <orig>Der hats wohl verdient!</orig>
                        <note sameAs="letter.6834/#npmp_qck_kgc"/>
                    </seg>
                </p>
                <closer rendition="#c">
                    <salute>Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
                <pb n="2" xml:id="p.2"/>
                <note place="mTop" hand="#author"><!-- steno -->
                    <hi rendition="#st">Von Herrn <persName key="pers.3263">Arnold Schönberg</persName>
                        <gap reason="illegible" unit="words" quantity="5"/> dass Sie sich für diese
                            <lb/>
                        <bibl sameAs="werke.16">Gurrelieder</bibl> in so tatkräftiger Weise
                        eingesetzt haben und dass es <gap reason="illegible" unit="words" quantity="1"/> Ihrer freundlichen <lb/>Mitwirkung zu danken sein wird
                        wenn eine <placeName key="place.2.3">Berliner</placeName> Aufführung dieses
                        monumentalen Werks <gap reason="illegible" unit="words" quantity="1"/> zu
                        Stande <lb/>kommt. Ich bin <gap reason="illegible" unit="words" quantity="1"/> Ihnen für Ihre freundlichen Bemühungen <gap reason="illegible" unit="lines" quantity="2"/>
                    </hi>
                    <lb/>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </note>
            </div>
        </body>
    </text>
