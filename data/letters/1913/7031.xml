    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.1">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Berlin-Südende<lb/>
                        <placeName key="place.2.23.1.1">Berlinerstr. 17a</placeName>, <hi rendition="#sup">I.</hi>
                        <lb/>Tel.: Tempelhof 174.</stamp>
                    <address>
                        <addrLine> PT. <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>P<supplied cert="high">.</supplied> T.</salute>
                <p rendition="#inline">die <bibl sameAs="werke.11">Orchesterlieder</bibl> sind nun
                        <hi rendition="#u">alle</hi> an <lb/>
                    <orgName key="org.38">Br. u. H.</orgName> abgeschickt. Bitte wollen Sie <lb/>die
                    Fertigstellung aufs äußerste beschleunigen lassen, <lb/>da <persName key="pers.4309">Zeml</persName>. die Partituren dringend benötigt!</p>
                <p>Die <seg type="comment">
                        <orig>Aufführung</orig>
                        <note xml:id="nuj3_lzh_fgc" resp="#KBleier">
                            <ref target="event.172"/>
                        </note>
                    </seg> in <placeName key="place.13.1">Prag</placeName>
                    <note place="inline" hand="#author">(bitte vormerken!)</note>
                    <lb/>ist am <hi rendition="#u">
                        <date when="1913-01-15">15. Jänner 1914</date>.</hi>
                </p>
                <p>Bitte die Stimmen <hi rendition="#u">sorgfältig korrigieren zu <lb/>lassen, da
                            <persName key="pers.4309">Zemlinsky</persName> nicht sehr viele Proben
                        hat!</hi>
                </p>
                <closer>
                    <salute>Hochachtungsvoll</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1913-09-21">21/9. 1913</date>
                    </dateline>
                </closer>
                <note place="mBottom" hand="#unknown"><!-- steno -->
                    <hi rendition="#st">
                        <del rendition="#s">Anteil</del> sofort <gap reason="illegible" unit="words" quantity="1"/>
                    </hi>
                </note>
            </div>
        </body>
