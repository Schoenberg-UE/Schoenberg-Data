    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>,
                        Berlin-Zehlendorf-Wannseebahn <lb/> Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Direktor</addrLine>
                        <addrLine>
                            <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Li<supplied cert="high">e</supplied>ber Herr <rs type="person" key="pers.1538">Direktor</rs>:</salute>
                <p rendition="#inline">bitte senden Sie umgehendst <lb/>eine <hi rendition="#u" hand="#addressee">
                        <metamark function="done" hand="#addressee" spanTo="#br2_x1k_kbc"/>Partitur
                            <bibl sameAs="werke.16">Gurre-Lieder<anchor type="done" xml:id="br2_x1k_kbc"/>
                        </bibl>
                    </hi> an <hi rendition="#u" hand="#addressee">Herr <persName key="pers.741">Camille
                    <lb/>Chevillard</persName>, Paris <placeName key="place.4.4.5.2">2 rue Moncey</placeName> (für<seg type="comment">
                            <orig> Frau <persName key="pers.1105">Freund</persName>
                            </orig>
                            <note xml:id="nd2v_hxb_fgc" resp="#TMuxeneder">
                                <ref target="event.199"/>
                            </note>
                        </seg>
                    </hi>) <lb/>und so rasch wie
                    möglich einen Auszug. – Der <seg type="comment">
                        <orig>Garantie<lb break="no"/>fond</orig>
                        <note sameAs="letter.6831/#nozg_11k_kgc"/>
                    </seg> ist
                    eigentlich der Hauptsache nach schon beisammen. <lb/>Ich hoffe aber noch mehr
                    zusammen zu bekommen, da<g ref="#typoHyphen"/>
                    <lb break="no"/>mit ich 10 Proben machen kann (sonst 8). Wahrscheinlich
                        <lb/>
                    <seg type="comment">
                        <orig>wirds</orig>
                        <note sameAs="letter.6829/#nl1m_bmj_kgc"/>
                    </seg> am <date when="1913-03-25">25. März</date> im <placeName key="place.2.8.1">Charlottenburger</placeName>
                    <orgName key="org.49">Deutschen Opern<g ref="#typoHyphen"/>
                        <lb break="no"/>haus</orgName> sein, oder am <date when="1913-04-14">14.
                        April</date> mit dem <orgName key="org.30">philharm.
                        <lb/>Orchester</orgName>. Ich hoffe aber <date when="1913-03-25">25/3</date>
                    ! <hi rendition="#u">Ich</hi> habe die Wahl! Bitte <lb/>sch<supplied cert="high">le</supplied>unigst: <hi rendition="#u">
                        <bibl sameAs="werke.17">Clavierauszüge</bibl>!!!</hi>
                </p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
