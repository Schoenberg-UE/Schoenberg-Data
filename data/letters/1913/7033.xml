    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.1538">herzka</persName>
                            <rs type="org" key="org.1">musikedition wien</rs>
                        </addrLine>
                    </address>
                </opener>
                <p>= erbitte telegraphisch 150 mark <lb/>vorschuss auf ein neues <seg type="comment">
                        <orig>orchesterlied</orig>
                        <note sameAs="letter.17498/#nfyh_vpb_wxb"/>
                    </seg> und 350 mark fuer 7 <lb/>
                    <orgName key="org.306">konzertwochen</orgName> zusammen 500 mark partitur und 2
                        <seg type="comment">
                        <orig>beitraege</orig>
                        <note xml:id="nvx5_nzb_wxb" resp="#KBleier">Beiträge für <orgName
                                key="org.306">Die Konzertwoche</orgName>, eine Beilage zu
                            Konzertprogrammen des <orgName key="org.307">Wiener
                                Konzerthauses</orgName>: <bibl sameAs="schriften.35">Arnold
                                Schönberg, Warum neue Melodien schwer verständlich sind</bibl>; Zum
                            zweiten Beitrag sandte <persName key="pers.3263">Schönberg</persName>
                            <ref target="document.7034">drei Entwürfe</ref></note>
                    </seg>
                    <lb/>brieflich weitere 5 beitraege naechste woche brauche <lb/>dringendst </p>
                <closer rendition="#inline">
                    <address>
                        <addrLine>
                            <persName key="pers.3263">schoenberg</persName>.+</addrLine>
                    </address>
                </closer>
            </div>
