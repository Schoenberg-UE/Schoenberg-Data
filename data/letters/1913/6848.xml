    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.1">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Berlin-Südende<lb/>
                        <placeName key="place.2.23.1.1">Berlinerstr. 17a</placeName>, <hi rendition="#sup">I.</hi>
                        <lb/>Tel.:
                  Tempelhof 174.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstr. 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">bitte notieren Sie meine <lb/>neue Adresse.</p>
                <p>Sind die <bibl sameAs="werke.24">Georgelieder</bibl> und die <seg type="comment"
                            ><orig>neuen <bibl sameAs="werke.52">Klavierstücke</bibl></orig><note
                            sameAs="letter.6986/#nhkp_pxq_y2c"/></seg> schon <lb/>im Stich?</p>
                <p>Wann <seg type="comment"><orig>erscheint <bibl sameAs="werke.54"
                            >Pierrot</bibl></orig><note xml:id="ners_hkw_cfc" resp="#KBleier"
                            >Lieferdatum: <date when="1914-07-03">3. Juli 1914</date>, Auflage: 200;
                            Büttenausgabe: Lieferdatum: <date when="1914-07-30">30. Juli
                            1914</date>, Auflage: 50 (<rs type="bibl" key="zotero-4528359-LQMNNW3Y"
                                >Buchon 2015</rs>, Bd. 5, S. 663)</note></seg>?</p>
                <p>Wann die <seg type="comment"><orig><bibl sameAs="werke.43"
                            >Balladen</bibl></orig><note xml:id="nxhw_bmw_cfc" resp="#KBleier"
                            >Lieferdatum: <date when="1920-04-11">11. April 1920 </date>und <date
                                when="1920-04-14">14. April 1920</date> (<rs type="bibl"
                                key="zotero-4528359-PIH2NWXP">ASGA B 1/2</rs>, S.175,
                        180)</note></seg>, etc?</p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
