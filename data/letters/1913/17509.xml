    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.97">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG <lb/>
                        <placeName key="place.2.20.9">Sternwartenstr. 15–21</placeName>
                        <lb/>WIEN<lb/>I·<placeName key="place.9.11.6.18">Reichsratsstrasse 9</placeName>
                        <lb/>Telegramm-Adresse: Musikedition,
                  Wien<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 22877·Bank-Konto: <orgName key="org.199">k·k·privil·österr.<lb/>Länderbank,
                  Wien</orgName>·Postsparkassen-Konto: 57557.<lb/>Wien <seg hand="#author">
                            <date when="1913-12-03">3. Dezember
                        1913</date>
                        </seg>
                    </stamp>
                    <lb/>
                    <persName key="pers.4381">GP</persName>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.2.23.1">Berlin-Südende</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir bestätigen Ihr heutiges <seg type="comment">
                        <orig>Telegramm</orig>
                        <note xml:id="ngdy_xwg_qbc" resp="#pkehrer">
                            <ref target="letter.24250">Arnold Schönberg an
                                Universal-Edition, 3. Dezember 1913 [erschlossen]</ref>
                        </note>
                    </seg>
                    und er<g ref="#typoHyphen"/>
                    <lb break="no"/>lauben uns Ihnen mitzuteilen, dass Herr Direktor <persName key="pers.1538">Hertzka</persName>
                    <lb/>zur Zeit verreist ist und eine Erledigung daher erst er<g ref="#typoHyphen"/>
                    <lb break="no"/>folgen kann, bis wir von ihm Nachricht haben.</p>
                <p>Gleichzeitig senden wir Ihnen pag. 107–122 <lb/>Ihrer <seg type="comment">
                        <orig>Original-Partitur</orig>
                        <note sameAs="letter.7255/#nf53_4tp_jgc"/>
                    </seg> zu den „<bibl sameAs="werke.16">Gurre-Liedern</bibl>“, sodass
                    <lb/>Sie den kompletten dritten Teil nunmehr besitzen.</p>
                <closer>Wir zeichnen <salute rendition="#r">hochachtungsvoll</salute>
                    <lb/>
                    <seg rendition="#r">f 
                    <stamp sameAs="stamp.86">
                            <orgName key="org.1">„Universal-Edition“
                     Actiengesellschaft</orgName>
                        </stamp>
                        <lb/>
                        <signed>D<hi rendition="#sup">r</hi>
                            <persName key="pers.1750">
                     Kalmus</persName>
                        </signed>
                    </seg>
                </closer>
                <postscript>
                    <p>
                        <hi rendition="#u">N. B.</hi>
                        <lb/>Wir haben gestern irrtümlicher <lb/>Weise noch einen Abzug des Text<g ref="#typoHyphen"/>
                        <lb break="no"/>buches zu „<bibl sameAs="schriften.94">Erwartung</bibl>“ eingesandt <lb/>und bitten uns dasselbe wieder
                  <lb/>zurückzuschicken.</p>
                </postscript>
            </div>
        </body>
    </text>
