    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <supplied cert="low">
                        <stamp sameAs="stamp.1">
                            <persName key="pers.3263">Arnold Schönberg</persName>
                            <lb/>Berlin-Südende<lb/>
                            <placeName key="place.2.23.1.1">Berlinerstr. 17a</placeName>, <hi rendition="#sup">I.</hi>
                            <lb/>Tel.:
                    Tempelhof 174.</stamp>
                    </supplied>
                    <dateline>
                        <date when="1913-11-28">28/XI. 1913</date>
                    </dateline>
                </opener>
                <salute>Lieber Herr <persName key="pers.2283">Marschalk</persName>,</salute>
                <p rendition="#inline"> ich habe noch immer <lb/>meine Abrechnung nicht erhalten!
                    Das geht doch <lb/>wirklich nicht. Schließlich wozu ist denn dann ein <lb/>
                    <ref target="document.12433">Vertrag</ref> da! Ich musste ihn <hi rendition="#u">wirklich</hi> einhalten!</p>
                <p>Bitte schicken Sie mir die nun. </p>
                <closer rendition="#inline">
                    <salute>Herzl. Grüße</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
