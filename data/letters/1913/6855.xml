    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.1">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Berlin-Südende<lb/>
                        <placeName key="place.2.23.1.1">Berlinerstr. 17a</placeName>, <hi rendition="#sup">I.</hi>
                        <lb/>Tel.:
                        Tempelhof 174.</stamp>
                    <address>
                        <addrLine> P. T. <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Musikverlag</addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstr. 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>P. T.</salute>
                <p rendition="#inline">ich sende Ihnen heute als Postpakett die Partituren meiner <lb/>
                    <bibl sameAs="werke.11">
                        <supplied cert="high">Or</supplied>chesterlieder</bibl> und bitte <hi rendition="#u">schleunigst die Autografien anfertigen</hi>
                    <lb/>zu lassen und das Material herzustellen. Ich muss bitten, die
                    <lb/>Manuskripte <hi rendition="#u">keinesfalls</hi> auszuleihen, da ich <hi rendition="#u">keine Copien</hi>
                    <lb/>besitze! Ich müsste Sie sonst für den Schaden haftbar machen. <lb/>
                    <hi rendition="#u">NB</hi>
                    <persName key="pers.4309">Zemlinsky</persName> benötigt die Partituren <hi rendition="#uu">dringendst</hi>, es wäre <lb/>also sehr nötig sie mit
                    größter Eile fertigstellen zu lassen. Ich <lb/>bitte die Autografien, ehe ich
                    sie korrigiere sorgfältigst korrigieren <lb/>zu lassen. – Herrn Direktor
                        <persName key="pers.1538">Herzkas</persName>
                    <seg type="comment"><orig>Briefe</orig><note xml:id="nbsv_p5m_sbc"
                            resp="#pkehrer"><ref target="letter.24489">Universal-Edition an Arnold Schönberg,
                                vor 9. August 1913 [erschlossen]</ref>; <ref target="letter.24246"
                                >Universal-Edition an Arnold Schönberg, 30. Juli 1913
                                [erschlossen]</ref></note></seg> beantworte ich <lb/>in 3–4 Tagen,
                    da ich heute <hi rendition="#u">nach <placeName key="place.2.3"
                            >Berlin</placeName> zurückreise</hi>.</p>
                <closer>
                    <salute>Hochachtungsvoll</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1913-08-09">9/8.1913</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
