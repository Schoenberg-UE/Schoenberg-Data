    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.97">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG <lb/>
                        <placeName key="place.2.20.9">Sternwartenstr. 15–21</placeName>
                        <lb/>WIEN<lb/>I·<placeName key="place.9.11.6.18">Reichsratsstrasse
                            9</placeName>
                        <lb/>Telegramm-Adresse: Musikedition, Wien<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 22877·Bank-Konto: <orgName key="org.199">k·k·privil·österr.<lb/>Länderbank, Wien</orgName>·Postsparkassen-Konto:
                        57557. <lb/>Wien <seg hand="#author">
                            <date when="1913-12-01">1. Dezember 1913.</date>
                        </seg>
                    </stamp>
                    <lb/>
                    <persName key="pers.4358">W</persName>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <hi rendition="#g">
                                    <placeName key="place.2.3">Berlin</placeName>
                                </hi>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Lieber Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Ich bin Donnerstag oder Freitag, den <date when="1913-12-04">4.</date> oder <date
                        when="1913-12-05">5. Dezember</date>
                    <lb/>in <placeName key="place.2.3">Berlin</placeName> und werde Sie dann sofort
                    telefonisch anrufen, damit <lb/>wir ein Rendez-vous vereinbaren. Heute sandte
                    ich ihnen 50 Mark <lb/>für die Klavierauszugskopie Ihres
                    Monodrams.</p>
                <closer>
                    <salute>Mit herzlichen Grüssen <lb/>
                        <seg rendition="#r">Ihr ganz ergebener</seg>
                    </salute>
                    <signed rendition="#r">
                        <persName key="pers.1538">Hertzka</persName>
                    </signed>
                </closer>
                <note place="mBottom" hand="#author">
                    <bibl sameAs="werke.54">Pierrot lunaire</bibl>
                    <lb/>
                    <seg type="comment">
                        <orig>Partitur</orig>
                        <note sameAs="letter.359/#ne4w_p5w_cfc"/>
                    </seg> eben erhalten.</note>
                <lb/>
                <note place="mBottom" hand="#unknown">
                    <seg type="comment">
                        <orig>Orchesterlied</orig>
                        <note sameAs="letter.17498/#nfyh_vpb_wxb"/>
                    </seg>
                </note>
            </div>
        </body>
