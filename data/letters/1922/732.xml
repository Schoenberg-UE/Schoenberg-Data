    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">Frau <persName key="pers.1105">Freund</persName> braucht
                    <lb/>zur Eintragung des franzö<supplied cert="high">si</supplied>schen Textes
                    des <bibl sameAs="werke.54">Pierrot</bibl>
                    <lb/>eine große Partitur (ich soll im <seg type="comment">
                        <orig>
                            <date when="1922-12">December</date>
                            <lb/>in <placeName key="place.4.4">Paris</placeName>
                        </orig>
                        <note xml:id="nnmh_bmk_yfc" resp="#KBleier">
                            <ref target="event.184"/>. <persName key="pers.3263"
                                >Schönberg</persName> nicht anwesend<!-- siehe ASCC 10730-->
                        </note>
                    </seg> sein) <hi rendition="#u">des <bibl sameAs="werke.54">Pierrot</bibl>
                    </hi> und ein Exemplar <lb/>„<hi rendition="#u">
                        <bibl sameAs="schriften.12">Jacobsleiter</bibl>
                    </hi>“ <!-- nicht in ASCC -->zum
                    Vorlesen<!-- nicht nachgewiesen -->. bitte! als Frei<g
                        ref="#typoHyphen"/>
                    <lb break="no"/>exemplar.</p>
                <closer rendition="#inline">
                    <salute>Beste Grüße</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                    <dateline rendition="#c">
                        <date when="1922-10-18">18/X.1922</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
