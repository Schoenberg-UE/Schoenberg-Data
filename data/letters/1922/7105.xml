    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Lieber Herr Direktor <persName key="pers.1538">Herzka</persName> (oder liebes
               <lb/>Frl <persName key="pers.3067">Rothe</persName>)</salute>
                <p rendition="#inline">bitte senden Sie mir  <lb/>(<hi rendition="#u">außer</hi> den an
               die <orgName key="org.274">Centr. B. Deutsch. <lb/>Spark</orgName> in <placeName key="place.9.2">Gmunden</placeName>
                    <del rendition="#s">)</del> verlangten)
               <lb/>noch <hi rendition="#u">2,000.000</hi> österr Kronen <lb/>direkt an mich im <hi rendition="#u">Geldbrief express</hi>
                    <lb/>Ich musste <del rendition="#s">geste</del> heute Franken verkaufen
                  <lb/>
                    <supplied cert="high">w</supplied>eil die <hi rendition="#u">Million</hi>
                    <add place="sublinear">(15.000)</add> nicht da war.</p>
                <p>Ich dürfte bald nach <placeName key="place.9.11">Wien</placeName> kommen.
               <lb/>Vielleicht schon vor dem <date when="1922-09-20">20/IX.</date>
                    <lb/>Sicher ist das allerdings noch nicht.</p>
                <closer>
                    <salute>Herzliche Grüße</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <lb/>
                    <seg rendition="#c">d. h. </seg>
                    <lb/>
                    <signed rendition="#c">
                        <persName key="pers.3263">Arnold
               Schönberg</persName>
                    </signed>
                </closer>
                <closer>
                    <dateline>
                        <placeName key="place.9.10">Traunkirchen</placeName>
                        <date when="1922-09-09">9/IX.1922</date>
                    </dateline>
                </closer>
            </div>
        </body>
