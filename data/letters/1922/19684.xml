    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.14">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>.<lb/>WIEN<lb/>
                  I. <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>,
                  (Musikvereinsgebäude)</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">Traunkirchen</hi>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.10.2">Villa Spaun</placeName> Ober
                     Oesterreic<supplied cert="high">h</supplied>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.4357">Bau</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1922-07-12">12. Juli 1922</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">
                            <persName key="pers.3263">Arnold
                     Schönberg</persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.9.10">Traunkirchen</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir erlauben uns, Ihnen mit gleicher Post <lb/>folgende Teile der <bibl sameAs="schriften.1">Harmonielehre</bibl> zu senden:</p>
                <p>
                    <list>
                        <item>Handexemplar Pagina 193–398</item>
                        <item>1. Abzug Pagina 206–418</item>
                        <item>2. Abzug Pagina 206–427 und Pagina X–XI</item>
                        <item>3. Abzug Pagina 206–427</item>
                    </list>
                und zeichnen</p>
                <closer>
                    <salute rendition="#r">in vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.128" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>.</stamp>
                    <lb/>
                    <signed rendition="#r">ppa D<hi rendition="#sup">r</hi>
                        <unclear reason="illegible" cert="high">
                            <persName key="pers.1750">Kalmus</persName>
                        </unclear>
                    </signed>
                </closer>
                <note place="mBottom" hand="#addressee">empfangen <lb/>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </note>
            </div>
        </body>
