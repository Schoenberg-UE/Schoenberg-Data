    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.141">
                        <orgName key="org.178">VEREIN FÜR
                            MUSIKALISCHE<lb/>PRIVATAUFFÜHRUNGEN</orgName>
                        <lb/>PRÄSIDENT <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>ALLE ZUSCHRIFTEN AN: SEKRETÄR D<hi rendition="#sup">R.</hi>
                        <persName key="pers.2795">PAUL PISK</persName>
                        <lb/>WIEN, VI., <placeName key="place.9.11.9.7">PROSCHKOGASSE 1</placeName>,
                        TEL. ST. IV v. 704</stamp>
                    <lb/>
                    <stamp sameAs="stamp.12">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>
                        <placeName key="place.9.10.2">Trau<add place="intralinear">nk</add>irc<add place="intralinear">he</add>n N<hi rendition="#sup #uu">o</hi>
                            3</placeName>
                        <lb/>V<add place="intralinear">i</add>lla Spaun<lb/>Oberoesterr.</stamp>
                    <address>
                        <addrLine>P. T. <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#u">Wien I</hi>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlspla<supplied cert="high">tz</supplied> 6</placeName>
                        </addrLine>
                        <addrLine>Musikvereinsgeb.</addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>P. T. <orgName key="org.1">Univ. Ed.</orgName>
                </salute>
                <p rendition="#inline">bitte freundlichst um Zusendung <lb/>eines Verzeichnisses der
                  <orgName key="org.1">Universal-Edition</orgName>, sowie <lb/>
                    <ellipsis>
                        <metamark function="ellipsis">〃</metamark>
                        <supplied>eines</supplied>
                    </ellipsis>
                    <ellipsis>
                        <metamark function="ellipsis">〃</metamark>
                        <supplied>Verzeichnisses</supplied>
                    </ellipsis>
                    <ellipsis>
                        <metamark function="ellipsis">〃</metamark>
                        <supplied>der</supplied>
                    </ellipsis>
                    <hi rendition="#u">
                        <orgName key="org.43">Peters-Edition</orgName>
                    </hi>. <lb/>Besten Dank im Voraus.</p>
                <closer rendition="#inline">
                    <salute>Hochachtungsvoll</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold
                  Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1922-08-04">4.VIII.1922</date>
                    </dateline>
                </closer>
                <postscript>
                    <p>Besitzen Sie ein überflüssiges <seg type="comment">
                            <orig>Programm des
                                    <placeName key="place.9.7">Salzburger</placeName>
                                <lb/>Kammermusikfestes</orig>
                            <note xml:id="nmcj_fm5_ggc" resp="#KBleier">
                                <date when="1922-08-07">7.</date>–<date when="1922-08-10">10. August 1922</date>, <placeName key="place.9.7">Salzburg</placeName>, Internationale
                                Kammermusikaufführungen: Programm (<ref target="https://archive.schoenberg.at/resources/?r=5573">ASCI
                                    CP5573</ref>); von <persName key="pers.3263">Schönberg</persName> stand das <bibl sameAs="werke.26">Streichquartett Nr. 2 op. 10</bibl> auf dem
                            Programm</note>
                        </seg>? Ich nicht!</p>
                </postscript>
                <note place="mBottom" hand="#addressee">
                    <orgName key="org.43">Peters</orgName>-Katalog
                  <lb/>
                    <!-- steno -->
                    <hi rendition="#st">gesendet</hi>
                    <date when="1922-08-21">21.VIII.22</date>
                </note>
                <note place="mBottom" hand="#addressee">R1K.</note>
            </div>
        </body>
