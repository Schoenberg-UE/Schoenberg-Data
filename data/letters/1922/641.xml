    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.12">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>
                        <placeName key="place.9.10.2">Traunkirchen N<hi rendition="#sup #uu">o</hi>
                     3</placeName>
                        <lb/>Villa Spaun<lb/>Oberoesterr.</stamp>
                    <dateline>
                        <date when="1922-07-04">4. Juli
                     1922</date>
                    </dateline>
                    <note place="right" hand="#addressee">
                        Dir/<unclear reason="illegible" cert="low">K.</unclear>
                        <lb/>
                        <date when="1922-07-05">5/7.<hi rendition="#o">22</hi>
                        </date>
                    </note>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">gestern waren <lb/>es 14 Tage, dass wir unsere Abmachung
               <lb/>zuende besprochen hatten und heute <lb/>habe ich noch nichts von Ihnen
               bekommen! <lb/>Was soll ich davon denken?</p>
                <p>Lieber Herr Direktor, <hi rendition="#u">das darf nun</hi>
                    <lb/>nicht mehr länger dauern. Ich muss <lb/>einen genauen Ueberblick über meine
               <lb/>Einkünfte haben, weil ich danach für <lb/>die nächste Saison wichtige
               Entscheidungen <lb/>zu treffen habe.</p>
                <p>Ich bitte Sie also nochmals um um<g ref="#typoHyphen"/>
                    <lb break="no"/>gehende
               Erledigung.</p>
                <closer rendition="#inline">
                    <salute>Beste Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
