    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.14">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>.<lb/>WIEN<lb/>
                  I. <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>,
                  (Musikvereinsgebäude)</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>,</addrLine>
                        <addrLine>Traunkirchen</addrLine>
                        <addrLine>
                            <placeName key="place.9.10.2">Villa Spaun</placeName> Ober
                     Oesterreich</addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.4357">Bau</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1922-07-13">13. Juli 1922</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.10">
                                <hi rendition="#g">
                                    <hi rendition="#uda">Traunkirchen</hi>
                                </hi>
                            </placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir senden Ihnen gleichzeitig folgende Teile <lb/>der <bibl sameAs="schriften.1">Harmonielehre</bibl>:</p>
                <list>
                    <item>1. Abzug Pagina 419–496 letzte Seite ist in <lb/>der Druckerei verloren
                 gegangen</item>
                    <item>2. Abzug Pagina 428–507</item>
                    <item>3. Abzug Pagina 428–507</item>
                    <item>
                        <add place="intralinear">
                            <metamark/>
                        </add>
                        Handexemplar Pagina 399–476 <note place="right" hand="#addressee">empfangen <lb/>
                            <signed>
                                <persName key="pers.3263">Sch</persName>
                            </signed>
                        </note>
                    </item>
                    <item>
                        <note place="mBottom" hand="#author">
                            <metamark/> fe<supplied cert="high">rn</supplied>er Sach und
                            <lb/>Namenregister unkorrigiert</note>
                    </item>
                </list>
                <p>ausserdem 3 verschiedene
               Abzüge des Umschlages <lb/>mit der Bitte, uns mitzuteilen, welche Fassung <lb/>Ihnen
               am ehesten zusagt.</p>
                <closer>
                    <salute rendition="#r">In vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed rendition="#r">ppa Dr <unclear reason="illegible" cert="high">
                            <persName key="pers.1750">Kalmus</persName>
                        </unclear>
                    </signed>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                </closer>
            </div>
        </body>
