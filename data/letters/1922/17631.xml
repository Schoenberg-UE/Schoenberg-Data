    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.116">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/>I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition Wien, A. B. C. Code 5<hi rendition="#sup">th</hi> Ed.<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 3228,
                  4533·Bank-Konto: <orgName key="org.199">Oesterr. Länder-<lb/>bank. Wien</orgName>.
                  Postsparkassen Konto: 57557.</stamp>
                    <lb/>
                    <persName key="pers.3067">R</persName>/Bau<dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1922-11-22">22. November 1922</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #uda">
                                <placeName key="place.9.4">Mödling</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Ihrem Wunsche entsprechend lassen wir Ihnen gleichzeitig <lb/>eine <bibl sameAs="schriften.1">Harmonielehre</bibl> im Umtausch gegen das schlechte
                    Ihnen ge<g ref="#typoHyphen"/>
                    <lb break="no"/>sandte Exemplar zugehen, ferner die noch gewünschten <seg type="comment">
                        <orig>4 schönen <lb/>Ausgaben</orig>
                        <note xml:id="nwhk_ldv_ggc" resp="#TMuxeneder">Exemplar aus dem
                            Schönberg-Nachlass mit marmoriertem Deckel und goldgeprägtem Lederrücken (BOOK S29, c. 1)</note>
                    </seg>.</p>
                <closer>
                    <salute>Wir empfehlen uns  <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition
                  Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
