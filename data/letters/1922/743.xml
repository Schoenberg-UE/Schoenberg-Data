    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">darf ich Sie bitten, mir <lb/>durch den jungen Herr <persName key="pers.4187">Winkler</persName> im Laufe des Tages <lb/>1.000.000 (eine Million)
               Kronen zu senden?</p>
                <closer rendition="#inline">
                    <salute>Bestens Dankend schönsten <lb/>Gruß Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <lb/>
                    <seg rendition="#c">
                        <hi rendition="#rectangle">Bitte die Adresse <lb/>für die
                            200–M. Sendung <lb/>richtigzustellen. <note place="right" hand="#author">
                                <orgName key="org.271">Merkur</orgName>
                                <lb/>
                                <placeName key="place.9.4">Mödling</placeName>
                            </note>
                        </hi>
                    </seg>
                    <dateline rendition="#c">
                        <date when="1922-10-25">25/X.1922</date>
                    </dateline>
                    <lb/>
                    <stamp sameAs="stamp.9" rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg 6</placeName>.-Tel. 118.</stamp>
                </closer>
            </div>
        </body>
    </text>
