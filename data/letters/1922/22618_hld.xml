    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">Ihrem <seg type="comment">
                        <orig>Vorschlag</orig>
                        <note xml:id="nnrt_mbq_3xb" resp="#pkehrer">
                            <ref target="letter.24373_tl">Universal-Edition an Arnold Schönberg, 11.
                                April 1922 [erschlossen]</ref>
                        </note>
                    </seg> vom <date when="1922-04-11">11/IV</date>
                    <lb/>fehlt vor <hi rendition="#u">Allem Eines</hi>:</p>
                <p>
                    <hi rendition="#u">
                        <subst>
                            <del rendition="#ow">die</del>
                            <add place="across">Eine</add>
                        </subst> Entschuldigung für <subst>
                            <del rendition="#s">die</del>
                            <add place="superlinear">meine</add>
                        </subst> Verluste</hi>
                    <del rendition="#s">(</del>aus <lb/>der vertragswidrigen Be<subst>
                        <del rendition="#ow">z</del>
                        <add place="across">r</add>
                    </subst>echnung meiner Auslandstan<g ref="#typoHyphen"/>
                    <lb break="no"/>tiemen und <subst>
                        <del rendition="#ow">aus</del>
                        <add place="across">der</add>
                    </subst>
                    <add place="superlinear">unerwünschten</add> Umwechslung dieser Gewinnan<g ref="#typoHyphen"/>
                    <lb break="no"/>teile in Papierkronen.</p>
                <p>Wenn Sie bereit sind mir <subst>
                        <del rendition="#ow">den</del>
                        <add place="across">als</add>
                    </subst> Ersatz <lb/>für diesen Schaden den Betrag von
               <lb/>– – – – – – Kronen <lb/>zu bezalen, so bin
               ich <add place="superlinear">dagegen</add> bereit, <add place="superlinear">die
                  Vorschläge</add> Ihre<add place="intralinear">s</add>
                    <del rendition="#s">
                        <gap reason="illegible" quantity="1" unit="words"/>
                    </del>
                    <lb/>
                    <del rendition="#s">in Ihrem</del> Brief<add place="intralinear">es</add> vom <date when="1922-04-11">11. April 1922</date>
                    <del rendition="#s">vor<g ref="#typoHyphen"/>
                        <lb break="no"/>geschlagenen</del>
                    <del rendition="#s">mit</del> vorbehaltlich einer sorgfältigeren <lb/>Stilisierung
               und folgender Aenderungen <lb/>zu akzeptieren.</p>
            </div>
        </body>
    </text>
