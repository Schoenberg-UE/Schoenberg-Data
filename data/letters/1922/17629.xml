    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.116">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/>I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition Wien, A. B. C. Code
                            5<hi rendition="#sup">th</hi> Ed.<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 3228, 4533·Bank-Konto: <orgName key="org.199">Oesterr.
                            Länder-<lb/>bank. Wien</orgName>. Postsparkassen Konto: 57557.</stamp>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1922-11-29">29.
                            November 1922</date>.</dateline>
                    <address>
                        <addrLine>wohlgeboren Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #uda">
                                <placeName key="place.9.4">Mödling</placeName>.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter <rs type="person" key="pers.3263">Herr</rs>!</salute>
                <p>Wir erlegten Ihnen heute durch Herrn <persName key="pers.1339">Greissle</persName>
                    <lb/>
                    <seg rendition="#c">
                        <hi rendition="#uda">K 2,004.750.– i. W. Kronen zwei Millionen
                     viertausendsieben<g ref="#typoHyphen"/>
                            <lb break="no"/>hundertfünfzig</hi>
                    </seg>
                    <lb/>als Gegenwert <table rows="3" cols="2">
                        <row>
                            <cell>der monatlichen Garantiezahlung von</cell>
                            <cell>schw. Fr. 100.–</cell>
                        </row>
                        <row>
                            <cell>und der monatlichen Vorschusszahlung</cell>
                            <cell>
                                <hi rendition="#uda">
                                    <ellipsis>
                                        <metamark function="ellipsis">〃</metamark>
                                        <supplied>schw.</supplied>
                                    </ellipsis>
                                    <ellipsis>
                                        <metamark function="ellipsis">〃</metamark>
                                        <supplied>Fr.</supplied>
                                    </ellipsis> 50.–</hi>
                            </cell>
                        </row>
                        <row>
                            <cell>
                                <seg rendition="#r">zusammen . . . . .</seg>
                            </cell>
                            <cell>
                                <hi rendition="#uda">schw. Fr. 150.–</hi> à 13.365.–</cell>
                        </row>
                    </table> und ersuchen höflich uns beiliegende Empfangsbestätigung gefl.
               <lb/>unterschrieben einzusenden.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                    <signed>pp
                     <persName key="pers.4190">Winter</persName>
                    </signed>
                    <lb/>
                </closer>
            </div>
        </body>
    </text>
