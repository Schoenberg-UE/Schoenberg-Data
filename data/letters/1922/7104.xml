    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine rendition="#c">
                            <rs type="org" key="org.1">musikedition win</rs> =</addrLine>
                    </address>
                </opener>
                <p>
                    <persName key="pers.2817">polnauer</persName> hat <persName key="pers.2279"
                        >manen</persName> u meine <seg type="comment">
                        <orig>
                            <bibl sameAs="werke.47">orchesterstuecke</bibl>
                        </orig>
                        <note xml:id="ntxp_tcz_r2c" resp="#KBleier">Aufgrund einer Anfrage nahm
                                <orgName key="org.43">C. F. Peters</orgName> die <date when="1914"
                                >1914</date>/<date when="1915">15</date> kriegsbedingt nicht
                            erfolgte Revision und Neuausgabe der <bibl sameAs="werke.47">5
                                Orchesterstücke op. 16</bibl> wieder auf und erkundigte sich bei
                                <persName key="pers.3263">Schönberg</persName> über die Aktualität
                            der seinerzeit zugesandten (insbesondere die Dynamik betreffenden)
                            Korrekturen (<ref
                                target="https://www.schoenberg-peters.at/cfp/letters/letter.20411"
                                >C. F. Peters an Arnold Schönberg, 24. August 1922</ref>). <persName
                                key="pers.3263">Schönberg</persName> beauftragte <persName
                                key="pers.2817">Josef Polnauer</persName> mit der Übermittlung
                            seines Exemplares von <placeName key="place.9.4">Mödling</placeName>
                            nach <placeName key="place.9.10">Traunkirchen</placeName>, welche sich
                            offenbar verzögerte. <persName key="pers.3263">Schönberg</persName>
                            bestätigte die Gültigkeit der Korrekturen und veranlasste die
                            Herstellung ein Fehlerliste als Beilage zum Orchestermaterial (<ref
                                target="https://www.schoenberg-peters.at/cfp/letters/letter.20411"
                                >C. F. Peters an Arnold Schönberg, 24. August 1922</ref>; <ref
                                target="https://www.schoenberg-peters.at/cfp/letters/letter.719">C.
                                F. Peters an Arnold Schönberg,7. September 1922</ref></note>
                    </seg> nicht <lb/>gebracht benoetige dringent veranlaszet expresz<lb/>
                    <choice>
                        <sic>entung</sic>
                        <corr cert="high">sendung</corr>
                    </choice> dankent </p>
                <closer rendition="#inline">
                    <address>
                        <addrLine>= <persName key="pers.3263">schoenberg</persName> = "</addrLine>
                    </address>
                </closer>
            </div>
