    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1922-01-05">5.I.1922</date>
                    </dateline>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">beifolgenden <ref target="document.17068">Brief</ref> des Herrn
                  <lb/>
                    <persName key="pers.3612">Erwin Stein</persName> empfehle ich zur schleunigen
               und <lb/>einsichtsvollen Erledigung im Interesse der <lb/>
                    <bibl sameAs="schriften.1">Harmonielehre</bibl>. Seine Korrektur ist außer<g ref="#typoHyphen"/>
                    <lb break="no"/>ordentlich – so gut, dass ich infolge seiner <lb/>
                    <supplied cert="high">B</supplied>eanstandungen
               an je 16 Seiten 3–4 <lb/>Stunden zu verbessern habe – das ist für
               <lb/>die Neuauflage sehr wichtig und wertvoll. <lb/>Seine Forderung finde ich <hi rendition="#u">äußerst bescheiden</hi>!</p>
                <p>Unser Telefon war einige Tage ge<g ref="#typoHyphen"/>
                    <lb break="no"/>stört; geht
               aber jetzt wieder. <hi rendition="#u">Herr <persName key="pers.4190">Winter</persName>
                        <lb/>hat sich noch nicht gemeldet!!</hi>
                </p>
                <closer rendition="#r">
                    <salute>Herzliche Grüße</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                    <lb/>
                    <stamp sameAs="stamp.9">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg 6</placeName>.-Tel. 118.</stamp>
                </closer>
            </div>
        </body>
    </text>
