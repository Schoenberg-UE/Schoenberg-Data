    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.12">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>
                        <placeName key="place.9.10.2">Traunkirchen N<hi rendition="#sup #uu">o</hi>
                     3</placeName>
                        <lb/>Villa Spaun<lb/>Oberoesterr.</stamp>
                    <address>
                        <addrLine rendition="#r">An die <orgName key="org.1">Universal
                     Edition</orgName>
                        </addrLine>
                    </address>
                </opener>
                <table cols="2">
                    <row>
                        <cell>
                            <salute>Lieber Herr Direktor <persName key="pers.1538">Herzka</persName>
                            </salute>
                        </cell>
                        <cell rows="3">bitte zalen Sie <lb/>zu Lasten</cell>
                    </row>
                    <row>
                        <cell>
                            <salute>Liebes Frl <persName key="pers.3067">Rothe</persName>
                            </salute>
                        </cell>
                    </row>
                    <row>
                        <cell>
                            <salute>Lieber Herr <persName key="pers.1750">Kalmus</persName>
                            </salute>
                        </cell>
                    </row>
                </table>
                <p>meines Contos an <lb/>Frl. <persName key="pers.2631">Olga Novakovič</persName> einen Betrag von <lb/>höchstens
               500.000 Kr. gegen Bestätigung (even<g ref="#typoHyphen"/>
                    <lb break="no"/>tuell in
               mehreren Teilen<subst>
                        <del rendition="#ow">.</del>
                        <add place="across">)</add>
                    </subst>
                </p>
                <p>ferner an Herrn <lb/>
                    <persName key="pers.1757">Fritz Kaltenborn</persName> den Gegenwert von <lb/>20
               Schweizer Franken und 10 holl. Gulden <lb/>(ca 57<add place="intralinear">0</add>.000 Kr) zum Kurs vom <date when="1922-08-31">31./VIII.1922</date>
                </p>
                <p>Es wird noch Frau D<hi rendition="#sup #u">r</hi>
                    <persName key="pers.2696">Pappenheim-Frischauf</persName>
                    <lb/>mit einem Cheque auf den <orgName key="org.275">Kompass</orgName> zu
                    <lb/>Ihnen kommen. Ich will einstweilen keine <lb/>Gulden verkaufen.</p>
                <closer rendition="#inline">
                    <salute>Viele hrzle Grüße Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <lb/>
                    <seg rendition="#r">d. h.
                        <signed>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </signed>
                    </seg>
                    <lb/>
                    <stamp sameAs="stamp.142" rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </stamp>
                </closer>
                <note place="mBottom" hand="#addressee">erl <lb/>
                    <date when="1922-09-02">2.IX 22</date>
                </note>
            </div>
