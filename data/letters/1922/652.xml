    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.12">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>
                        <placeName key="place.9.10.2">Traunkirchen N<hi rendition="#sup #uu">o</hi>
                     3</placeName>
                        <lb/>Villa Spaun<lb/>Oberoesterr.</stamp>
                    <dateline>
                        <date when="1922-07-19">19.VII.1922</date>
                    </dateline>
                </opener>
                <salute>P. T. <orgName key="org.1">Universal Edition</orgName>,</salute>
                <p rendition="#inline">ich habe eine Bitte; nicht an <lb/>den Verlag, sondern an
               irgenwelche Freunde, <lb/>die mir eine Gefälligkeit erweisen wollen. <lb/>Ich habe
               aus Versehen einige Schreibrequisiten nicht <lb/>hieher mitgenommen und kann hier
               manches <lb/>gar nicht, oder meist nur in unbrauchbaren <lb/>Qualitäten bekommen.</p>
                <p>Wäre nur einer der Herrn (<add place="superlinear">mit</add> Sachverständnis)
                    <lb/>so freundlich mir diese Gegenstände zu be<g ref="#typoHyphen"/>
                    <lb break="no"/>sorgen und <hi rendition="#uu">unter Nachnahme</hi> hieher zu
                    senden? – <lb/>bitte: unter Nachnahme, damit keine Verrech<g ref="#typoHyphen"/>
                    <lb break="no"/>nung nötig ist.<note place="right" hand="#unknown"><!-- steno -->
                        <hi rendition="#st">1 hart 1 weich</hi>
                    </note>
                </p>
                <list>
                    <item>
                        <supplied cert="high">1.</supplied>) 6 <orgName key="org.303">Fabersche Castell</orgName>
                        <hi rendition="#u">Tintenstifte</hi>, u zw. <note place="right" hand="#unknown"><!-- steno -->
                            <hi rendition="#st">Mittel und hart</hi>
                        </note>
                        <lb/>3 „HB“ und 3 „F“</item>
                    <item>2.) <metamark function="done" hand="#addressee" spanTo="#pkk_h42_g2c"/>
                        <hi rendition="#u">100</hi>
                        <anchor type="done" xml:id="pkk_h42_g2c"/> Bogen
                        billiges Konzeptpapier</item>
                    <item>3<metamark function="done" hand="#addressee">✓</metamark>.) <metamark function="done" hand="#addressee" spanTo="#vcc_342_g2c"/>
                        <hi rendition="#u">10</hi><anchor type="done" xml:id="vcc_342_g2c"/> <ellipsis>
                            <metamark function="ellipsis">〃</metamark>
                            <supplied>Bogen</supplied>
                        </ellipsis>
                        <hi rendition="#u">gutes</hi>, bestes Durch<hi rendition="#uu">schreib</hi>papier <lb/>für Handschrift <del rendition="#s">mit</del> gut
                            lesbar<add place="sublinear">
                            <del rendition="#s">er</del>
                        </add> und
                            dauer<g ref="#typoHyphen"/>
                        <lb break="no"/>hafte Durchschrift!</item>
                    <item>4<metamark function="done" hand="#addressee">✓</metamark>.) <metamark function="done" hand="#addressee" spanTo="#znq_342_g2c"/>3<anchor type="done" xml:id="znq_342_g2c"/> Blatt (<add place="superlinear">ca</add> 70 x 100) allerbesten Lösch-<hi rendition="#u">Carton</hi>!</item>
                    <item>5.) 10 Bogen (70 x 100) des <del rendition="#s">Noten</del>
                        <subst>
                            <del rendition="#ow">p</del>
                            <add place="across">P</add>
                        </subst>apieres, welches für <lb/>mein Notenpapier verwendet wurde, aber:
                        ohne <lb/>Raster; unliniert, als Vorsatz und Umschlag für <lb/>Notenheft und
                            Bücher.<note place="right" hand="#unknown">
                            <hi rendition="#circle">47</hi>
                            <lb/>
                            <!-- steno -->
                            <hi rendition="#st">
                                <gap reason="illegible" unit="lines" quantity="3"/>
                                <lb/>5 Bögen</hi>
                        </note>
                    </item>
                </list>
                <closer>
                    <salute>Im Voraus dem freundlichen Helfer bestens <lb/>dankend<subst>
                            <add place="sublinear">; bin</add>
                            <del rendition="#s"> und grüß</del>
                        </subst>
                        ich mit <unclear reason="illegible" cert="high">schönstem</unclear> Gruß</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold
                     Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
