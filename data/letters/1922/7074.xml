    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <note place="mTop" hand="#addressee">
                    <persName key="pers.1538">Dir</persName>/K <lb/>
                    <date when="1922-06-21">21/6.<hi rendition="#o">22</hi>
                    </date>
                </note>
                <salute>P T. <orgName key="org.1">Universal Edition</orgName>,</salute>
                <p rendition="#inline">
                    <hi rendition="#u">Herrn <persName key="pers.3256">Ossip
                        Schnirlin</persName>
                    </hi> gebe ich hiemit <lb/>die <seg type="comment">
                        <orig>Erlaubnis</orig>
                        <note xml:id="nopx_szk_32c" resp="#KBleier">Arnold Schönberg an Ossip Schnirlin, 20. Mai 1922 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B064722">ASCC
                                6472</ref>)</note>
                    </seg> in seinem pädagogischen <bibl sameAs="werke.211">Werk</bibl> Stellen aus den Geigen<g ref="#typoHyphen"/>
                    <lb break="no"/>
                    <supplied cert="high">pa</supplied>rtien <add place="superlinear">u Violapartien</add> meiner <seg type="comment">
                        <orig>Kompositionen</orig>
                        <note xml:id="nqzm_q1v_ggc" resp="#KBleier">
                            <bibl sameAs="werke.42">Arnold Schönberg,
                                Streichquartett Nr. 1 op. 7</bibl>
                        </note>
                    </seg> als Citat zu
                    pädagogischen Zwecken <lb/>abzudrucken und knüpfe daran die Bedingungen,
                    dass:</p>
                <p>I. de<subst>
                        <del rendition="#ow">r</del>
                        <add place="across">m</add>
                    </subst> Abdruck nicht persönlich beleidigende Polemik angehängt werden <lb/>darf
               und, dass</p>
                <p>II. die zitierten Stellen <hi rendition="#u">fehlerfrei</hi> abgedruckt werden
               müssen, zu <lb/>welchem Zweck ich einen Bürstenabzug der mich betreffenden Stellen
               <lb/>erhalten muss.</p>
                <closer rendition="#inline">
                    <dateline>– <placeName key="place.9.4">Mödling</placeName>
                        <date when="1922-05-20">20/V.1922</date>
                    </dateline>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <lb/>
                    <stamp sameAs="stamp.9">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg 6</placeName>.-Tel. 118.</stamp>
                </closer>
                <note place="mBottom" hand="#unknown">
                    <hi rendition="#u">
                        <date when="1922-06">Juni
                     1922</date>
                    </hi>
                </note>
