    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.14">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>.<lb/>WIEN<lb/>
                  I. <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>,
                  (Musikvereinsgebäude)</stamp>
                    <address>
                        <addrLine>Herrn Prof.</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Mödling bei Wien</addrLine>
                        <addrLine>
                            <placeName key="place.9.4.1">Bernhardga<supplied cert="high">sse
                           6</supplied>
                            </placeName>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.3067">R</persName>/Ei<dateline>
                        <placeName key="place.9.11">Wien</placeName>, am
                     <date when="1922-11-28">28. November 1922</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold
                     Schönberg</persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Mödling bei Wien</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.4.1">Bernhardgasse
                     6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir entsprechen gerne einer An<g ref="#typoHyphen"/>
                    <lb break="no"/>regung des Komponisten <persName key="pers.688">Alfredo
                        Casella</persName> und las<g ref="#typoHyphen"/>
                    <lb break="no"/>sen Ihnen gleichzeitig seine bei uns erschie<g ref="#typoHyphen"/>
                    <lb break="no"/>nenen Werke<add place="intralinear">
                        <metamark/>
                    </add>
                    <note place="mBottom" hand="#author">
                        <metamark/>
                        <bibl sameAs="werke.201">Klavierstücke</bibl> &amp; <lb/>
                        <bibl sameAs="werke.202">Quartettpartitur</bibl>
                    </note> als Ehrenexemplar<add place="intralinear">e</add> zugehen. </p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#c">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition
                  Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.4190">Winter</persName>
                    </signed>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
