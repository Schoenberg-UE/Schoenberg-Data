    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <orgName key="org.1">UNIVERSAL - EDITION</orgName>
                        </addrLine>
                        <addrLine>WIEN I.,</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>.</addrLine>
                    </address>
                    <persName key="pers.3204">Schl</persName>/<persName key="pers.416">Be</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1947-07-22">22.
                            Juli 1947</date>.</dateline>
                    <address>
                        <addrLine>Mr.</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>,</addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 N. Rockingham Ave.</placeName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#u">
                                <hi rendition="#g">Los Angeles</hi> 24,</hi>
                        </addrLine>
                        <addrLine>California.</addrLine>
                    </address>
                </opener>
                <salute>Verehrter <rs type="person" key="pers.3263">Meister</rs>!</salute>
                <p> Ich habe seit langer Zeit keine Nachricht von Ihnen erhalten. <lb/>Haben Sie
                    meine <seg type="comment">
                        <orig>Berichte</orig>
                        <note xml:id="ndh1_vhf_q1c" resp="#pkehrer">Alfred Schlee an Arnold Schönberg, 13. Mai 1947
                        (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B177367">ASCC 17736</ref>)</note>
                    </seg> über die <placeName key="place.5">italienische</placeName> Tournee erhal<g ref="#typoHyphen"/>
                    <lb break="no"/>ten? Ich hoffe bald von Ihnen über die verschiedenen Nachrich<g ref="#typoHyphen"/>
                    <lb break="no"/>ten Antwort zu bekommen. </p>
                <closer rendition="#r">
                    <salute>Beste Grüsse</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.3204">Schlee</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
