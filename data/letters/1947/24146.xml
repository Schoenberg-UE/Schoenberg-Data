    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <rs type="org" key="org.1">Musikedition</rs>
                            <placeName key="place.9.11">Wien</placeName> (Vienna,
                            Austria)</addrLine>
                    </address>
                </opener>
                <milestone unit="section" rendition="#hr"/>
                <p>Please <del rendition="#s">
                        <gap reason="illegible" quantity="2" unit="words"/>
                    </del> airmail <add place="superlinear">me upon</add>
                    <orgName key="org.125">alien <add place="intralinear">property</add>
                        <lb/>
                        <subst>
                            <del rendition="#s">Custodian</del>
                            <add place="superlinear">custodians</add>
                        </subst>
                    </orgName> request<del rendition="#s">ed</del> list of <add place="right">
                        <del rendition="#s">titles of</del>
                    </add> my works <lb/>
                    <add place="superlinear">detailed</add> stating my percentage and <del rendition="#s">right</del>
                    <lb/>shares on various rights I granted <lb/>you.</p>
                <closer rendition="#r">
                    <signed>
                        <persName key="pers.3263">Arnold Schoenberg</persName>
                    </signed>
                </closer>
                <note place="mBottom" hand="#author">Date??</note>
            </div>
