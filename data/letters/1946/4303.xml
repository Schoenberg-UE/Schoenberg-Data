    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1946-03-03">March, 3 1946</date>
                    </dateline>
                    <address>
                        <addrLine>
                            <rs type="org" key="org.1">MUSIKEDITION Wien</rs> (<placeName key="place.9.11">Vienna</placeName>, Austria)</addrLine>
                    </address>
                </opener>
                <p>
                    <bibl sameAs="schriften.1">Harmonielehre</bibl>
                    <bibl sameAs="werke.54">PIERROT</bibl> KLAVIERSTUECKE <lb/>UNVERAENDERT STOP
                        <bibl sameAs="schriften.26">FORMENLEHRE</bibl> UNFERTIG <lb/>SENDE JEDOCH
                        <bibl sameAs="schriften.25">MODELS FOR BEGINNERS</bibl> STOP <lb/>
                </p>
                <p><seg type="comment"><orig>ANNEHME EHRENPRAESIDIUM</orig><note
                            xml:id="ntyh_5mq_rcc" resp="#pkehrer">Ehrenpräsidentschaft der <orgName
                                key="org.93">IGNM</orgName> (Internationale Gesellschaft für neue
                            Musik an Arnold Schönberg, 21. Jänner 1946; <ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B211847">ASCC
                                21184</ref>)</note></seg> BIN <lb/>VERLOCKENDEM <seg type="comment"
                            ><orig>ANGEBOT</orig><note xml:id="npsz_fnq_rcc" resp="#pkehrer"
                                ><persName key="pers.3263">Schönberg</persName> bezieht sich auf
                                <persName key="pers.3204">Alfred Schlees</persName> Bemerkung über
                            die &#8222;Berufung durch eine öffentliche Stelle&#8220; in <ref
                                target="letter.17720">Universal-Edition an Arnold Schönberg, 9.
                                Jänner 1946</ref></note></seg> NICHT ABGENEIGT</p>
                <closer rendition="#r">
                    <persName key="pers.3263">ARNOLD SCHOENBERG</persName>
                </closer>
            </div>
