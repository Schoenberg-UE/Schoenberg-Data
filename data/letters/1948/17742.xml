                        </addrLine>
                        <addrLine>
                            <hi rendition="#u">
                                <hi rendition="#g">Los Angeles</hi> 24.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter <rs type="person" key="pers.3263">Meister</rs>!</salute>
                <p>Im Rahmen der <orgName key="org.93">IGNM</orgName> fanden folgende Aufführungen
                    Ihrer Werke <lb/>statt, die zum Teil auch schon in dem von mir geschickten
                        <lb/>
                    <ref target="document.17741">Verzeichnis</ref> enthalten
                    <!-- fismoll nicht, op. 15 nicht, vkl nacht JA aber fälschlich "november", pierrot kein datum passt, op. 29 nicht, op. 11 nicht-->sind:</p>
                <list>
                    <item>
                        <hi rendition="#u">
                            <bibl sameAs="werke.26">Fis-moll-Quartett</bibl>
                        </hi>
                        <seg type="comment">
                            <orig>
                                <date when="1945-06-28">28. Juni
                                1945</date>
                            </orig>
                            <note xml:id="njb1_wxj_rcc" resp="#pkehrer">
                                <ref target="event.82"/>
                            </note>
                        </seg>
                    </item>
                    <item>
                        <hi rendition="#u">
                            <bibl sameAs="werke.24">15 Gedichte op. 15</bibl>
                        </hi>
                        <seg type="comment">
                            <orig>
                                <date when="1945-09-26">26. September
                                1945</date>
                            </orig>
                            <note xml:id="nsyn_tdj_rcc" resp="#pkehrer">
                                <ref target="event.83"/>
                            </note>
                        </seg>
                    </item>
                    <item>
                        <hi rendition="#u">
                            <bibl sameAs="werke.13">Verklärte Nacht</bibl>
                        </hi>
                        <seg type="comment">
                            <orig>
                                <date when="1946-10-26">26. Oktober
                                1946</date>
                            </orig>
                            <note xml:id="nkdz_nhc_rcc" resp="#pkehrer">
                                <ref target="event.78"/>
                            </note>
                        </seg>
                    </item>
                    <item>
                        <hi rendition="#u">
                            <bibl sameAs="werke.54">Pierrot lunaire</bibl>
                        </hi>
                        <seg type="comment">
