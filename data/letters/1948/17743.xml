    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <orgName key="org.1">UNIVERSAL-EDITION</orgName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">WIEN</hi>, I.,</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>.</addrLine>
                    </address>
                    <seg rendition="#c">
                        <persName key="pers.1485">Ha</persName>/<persName key="pers.416">Be</persName>
                    </seg>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1948-01-29">29.
                            Jänner 1948</date>.</dateline>
                    <address>
                        <addrLine>Mr.</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>,</addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 N. Rockingham Ave.</placeName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#u">
                                <hi rendition="#g">Los Angeles</hi> 24.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter <persName key="pers.3263">Meister</persName>!</salute>
                <p> Den beiliegenden<!-- nicht ermittelt -->, etwas unbeholfenen, aber irgendwie rührenden <lb/>Brief haben
                    wir mit der Bitte erhalten, ihn an Sie weiterzu<g ref="#typoHyphen"/>
                    <lb break="no"/>leiten. Der Schreiber ist uns im übrigen nicht weiter
                    bekannt.</p>
                <closer>
                    <salute rendition="#c">Wir begrüssen Sie bestens</salute>
                    <lb/>
                    <stamp sameAs="stamp.76" rendition="#r">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3067">Rothe</persName>
                    </signed>
                    <signed rendition="#r">
                        <persName key="pers.1485">Hartmann.</persName>
                    </signed>
                </closer>
            </div>
