    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.159">
                        <orgName key="org.1">Universal-Edition·A. G.</orgName>
                        <lb/>WIEN·I·<placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                        <lb/>Musikvereinsgebäude / Tel. U 47-5-85 <lb/>LEIPZIG·<placeName key="place.2.20.8">KARLSTRASSE 10</placeName>
                        <lb/>TELEGRAMM-ADRESSE:
                        MUSIKEDITION, WIEN – POSTSPARKASSEN·KONTO WIEN 57557</stamp>
                    <lb/>
                    <persName key="pers.1740">Ks.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1940-12-27">27.
                            Dezember 1940</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schoenberg</persName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 North Rockingham Avenue</placeName>
                        </addrLine>
                        <addrLine>Brentwood Park</addrLine>
                        <addrLine>
                            <hi rendition="#g">
                                <hi rendition="#u">Los Angeles</hi>
                            </hi>, California.</addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p> Wir haben im <date when="1940-02">Februar 1940</date> auf Grund Ihres <ref target="letter.22680">Auf<g ref="#typoHyphen"/>
                        <lb break="no"/>trages</ref>
                    vom <date when="1939-11-18">18. November 1939</date> an die <orgName key="org.224">University of California</orgName>, <lb/>
                    <placeName key="place.15.7">Los Angeles</placeName>, Ihre Werke im Fakturenbetrag von
                    RM 327.05 ge<g ref="#typoHyphen"/>
                    <lb break="no"/>liefert. Den Empfang der
                    Sendung <ref target="letter.7249">bestätigten</ref> Sie uns im <date when="1940-08">August <lb/>1940</date>.</p>
                <p>Da unsere <ref target="document.24145">Rechnung</ref> noch unbeglichen ist,
                        schrei<g ref="#typoHyphen"/>
                    <lb break="no"/>ben wir gleichzeitig an die Universität und bitten auch Sie
                    <lb/>zu veranlassen, dass uns der Fakturenbetrag überwiesen wird. <lb/>Eine
                    eventuelle Verrechnung mit Beträgen, die wir Ihnen in <lb/>Zukunft gutschreiben
                    können, ist wegen unserer Devisenbestim<g ref="#typoHyphen"/>
                    <lb break="no"/>mungen nicht möglich.</p>
                <closer>
                    <salute>Mit bestem Dank im voraus für eine baldige Erle<g ref="#typoHyphen"/>
                        <lb break="no"/>digung, empfehlen wir uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <unclear reason="illegible" cert="high">
                            <persName key="pers.1425">Halbhuber</persName>
                        </unclear>
                    </signed>
                    <signed rendition="#r">
                        <persName key="pers.3126">Schenk</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
