    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.132">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                    </stamp>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">könnten Sie vielleicht zur <lb/>morgigen (Samstag-) <seg type="comment">
                        <orig>Probe</orig>
                        <note xml:id="nyj1_tc4_4fc" resp="#KBleier">Vermutlich Hauptprobe zur <bibl sameAs="werke.50">Glücklichen Hand op.
                                18</bibl> an der <orgName key="org.184">Volksoper Wien</orgName> am
                                <date when="1924-10-11">11. Oktober 1924</date> (Kalendereintrag,
                            11. Oktober 1924; <ref target="https://archive.schoenberg.at/resources/pages/view.php?ref=12399">ASCI DC12399</ref>)</note>
                    </seg>, (auf 10<hi rendition="#sup">
                        <hi rendition="#u">h</hi>
                    </hi>) kommen? <lb/>Es ist vielleicht ein<del rendition="#s">e</del> plötzlicher
                    Entschluss <lb/>zu fassen!</p>
                <closer rendition="#inline">
                    <salute>Herz. Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                    <note place="mBottom" hand="#unknown">
                        <hi rendition="#uu">ca. 12</hi>
                    </note>
                    <!-- 180 Grad gedreht -->
                </closer>
            </div>
        </body>
    </text>
