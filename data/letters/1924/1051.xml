    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1924-06-24">27. 6. 24</date>
                    </dateline>
                    <address>
                        <addrLine>PT <orgName key="org.180">Dreililie<supplied cert="high">n</supplied>-Verlag</orgName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.2.3.3">Berlin-Halensee</placeName>
                        </addrLine>
                    </address>
                </opener>
                <p>Auf Ihre <seg type="comment">
                        <orig>Anfrage</orig>
                        <note xml:id="nirx_pk4_jcc" resp="#pkehrer">
                            <ref target="letter.24324">Verlag Dreililien an Arnold
                                Schönberg, zwischen 10. Februar 1923 und 27. Juni 1924
                                [erschlossen]</ref>
                        </note>
                    </seg> teile ich Ihnen mit, <lb/>dass
                    meine Adresse seit <date when="1918-03">März 1918</date> unver<g ref="#typoHyphen"/>
                    <lb break="no"/>ändert die obenstehende ist.</p>
                <p>Eine Geldsendung bitte ich Goldmarknoten <lb/>oder in einem Goldmarkschek an mich
                        ge<g ref="#typoHyphen"/>
                    <lb break="no"/>langen zu lassen.</p>
                <closer rendition="#inline">
                    <salute>Hochachtungsvoll</salute>
                </closer>
            </div>
        </body>
    </text>
