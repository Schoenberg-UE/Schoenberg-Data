    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1924-11-27">27.XI.<supplied cert="high">192</supplied>4</date>
                    </dateline>
                </opener>
                <salute>Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">darf ich Sie sehr <lb/>bitten, mir mein Monatsgeld (500
                    Goldmark) <lb/>durch meinen Sohn <persName key="pers.3281">Georg
                        Schönberg</persName> bereits <lb/>(wenn möglich) heute zu schicken. Sollten
                    <lb/>Sie das zufällig nicht können, dann geb<choice>
                        <sic>n</sic>
                        <corr cert="high">e</corr>
                    </choice>n <lb/>Sie ihm, bitte, einen Teil mit; er wird dann <lb/>den Rest
                    morgen vormittag holen.</p>
                <closer>
                    <salute>Herzlichste Grüsse und besten Dank, Ihr</salute>
                </closer>
                <note place="mBottom" hand="#unknown">
                    <orgName key="org.1">UE</orgName>
                </note>
            </div>
        </body>
