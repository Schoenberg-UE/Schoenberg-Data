    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Liebes Frl. <persName key="pers.3067">Rothe</persName>
                </salute>
                <p>Sind die <seg type="comment">
                        <orig>Stimmen</orig>
                        <note xml:id="ngks_hvd_pcc" resp="#pkehrer">Vermutlich Handschriftliche Stimmen, Kopistenabschrift
                                (<ref target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=1221&amp;werke_id=421&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke">ASGA B 22, Quelle C</ref>)</note>
                    </seg> der beiden <lb/>ersten
                    Sätze des <bibl sameAs="werke.59">Bläser-quin<supplied cert="high">tett</supplied>s</bibl>
                    <lb/>gut kollationiert <del rendition="#s">wo</del> und an <lb/>
                    <subst>
                        <del rendition="#ow">das</del>
                        <add place="across">die</add>
                    </subst>
                    <orgName key="org.187">W<hi rendition="#sup">
                            <hi rendition="#uu">r</hi>
                        </hi> Bläser Vereinigung</orgName> geschickt <lb/>worden; <seg type="comment">
                        <orig>an Prof. <persName key="pers.4290">Wunderer</persName>
                        </orig>
                        <note xml:id="noly_tnp_hgc" resp="#KBleier">
                            <ref target="event.117"/>
                        </note>
                    </seg>?</p>
                <closer>
                    <salute rendition="#c">Herzl. Grüße Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1924-08-22">22/VIII. 24</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
