    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.15">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>MÖDLING BEI WIEN<lb/>
                        <placeName key="place.9.4.1">BERNHARDGASSE 6</placeName>
                        <lb/>TELEPHON NR. 118<lb/>MÖDLING, <date when="1924-02-05">
                            <seg hand="#author">
                                <subst>
                                    <del rendition="#ow">8</del>
                                    <add place="across">5</add>
                                </subst>.II. </seg>192<seg hand="#author">4</seg>
                        </date>
                    </stamp>
                </opener>
                <lb/>
                <salute>PT <orgName key="org.1">UE</orgName> – Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p>Die <orgName key="org.126">Postsparkasse</orgName> hat mir dies<choice>
                        <sic>n</sic>
                        <corr cert="high">e</corr>
                    </choice>n Monat <choice>
                        <sic>n</sic>
                        <corr type="deleted"/>
                    </choice>
                    <lb/>noch nicht den Erlag der 150 Franken ge<g ref="#typoHyphen"/>
                    <lb break="no"/>meldet. Ich lege Erlagscheine bei und bit<lb break="no"/>te,
                    entsprechendes zu veranlassen.</p>
                <p>Ferner: <lb/>Ich <seg type="comment">
                        <orig>reklamierte</orig>
                        <note xml:id="nsdz_gzy_51c" resp="#pkehrer"><ref target="letter.985">Arnold
                                Schönberg an Universal-Edition, 19. Dezember 1923</ref>. Der
                            fehlende <persName key="pers.2180">Liszt</persName>-Band findet dort
                            keine Erwähnung</note>
                    </seg> bei Herrn <persName key="pers.994">Englisch</persName> vor <choice>
                        <sic>et</sic>
                        <corr type="deleted"/>
                    </choice>
                    <lb/>etwa 4 Wochen wegen des Preises einer No<lb break="no"/>tensendung
                    ausserdem aber auch, we<choice>
                        <sic>li</sic>
                        <corr cert="high">il</corr>
                    </choice>
                    <lb/>ein Band <hi rendition="#g">
                        <persName key="pers.2180">Liszt</persName>
                    </hi> nicht mitgeschickt <lb/>worden war. Darf ich um freundliche Er<g
                        ref="#typoHyphen"/>
                    <lb break="no"/>ledigung bitten?</p>
                <closer rendition="#inline">
                    <salute>Beste Grüsse</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
