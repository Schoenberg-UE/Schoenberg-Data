    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.9">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg 6</placeName>.-Tel. 118.</stamp>
                    <address>
                        <addrLine>
                            <note place="left" hand="#unknown">T </note>An die <orgName key="org.1">Universal-<lb break="no"/>
                                <hi rendition="#g">EDITION</hi>
                            </orgName>
                        </addrLine>
                        <addrLine>Musikverlag</addrLine>
                        <addrLine>Wien 1</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        </addrLine>
                        <addrLine>Musikvereinsgebäude</addrLine>
                    </address>
                    <note place="mBottom" hand="#unknown">
                        <unclear reason="illegible" cert="high">1000</unclear>
                    </note>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>
                    <supplied cert="high">Li</supplied>ebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">meine Reklamation wegen <lb/>der <persName key="pers.2180">Liszt</persName>-Partituren ist aus der mir geschick<g ref="#typoHyphen"/>
                    <lb break="no"/>ten Rechnung Nr. 37.923 v. <date when="1923-12-19">19.12.23</date> zu
                  ver<g ref="#typoHyphen"/>
                    <lb break="no"/>stehen, wo<add place="sublinear">nach</add> mir bloss <hi rendition="#u">zwei</hi> Bände (Nr. 1 u. 2) ver<g ref="#typoHyphen"/>
                    <lb break="no"/>rechnet und gesendet wurden<choice>
                        <sic>.</sic>
                        <corr type="deleted"/>
                    </choice> während ich <choice>
                        <sic>selb</sic>
                        <corr type="deleted"/>
                    </choice>
                    <lb/>selbstverständlich alle <hi rendition="#g">drei</hi> brauche und  <lb/>auch
               bestellt hatte. Darf ich Sie also um die  <lb/>Freundlichkeit bitten, diese
               Nachsendung zu  <lb/>veranlassen.</p>
                <closer rendition="#inline">
                    <salute>Besten Dank im voraus und viele  <lb/>herzlichste Grüsse; Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1924-02-12">12.II.24</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
