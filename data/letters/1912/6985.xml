    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <note place="left" hand="#author">
                        <hi rendition="#u">express</hi>
                        <hi rendition="#u">Eilbote</hi>
                    </note>
                    <address>
                        <addrLine>
                            <gap reason="illegible" unit="chars" quantity="3"/> Direktor
                                <persName key="pers.1538">E. Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>
                            Wien I</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße
                     9</placeName>
                        </addrLine>
                    </address>
                    <note place="mBottom" hand="#author">
                        <hi rendition="#u">persönlich</hi>
                    </note>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                  <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <dateline>
                        <date when="1912-05-19">19/5</date>
                    </dateline>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">heute früh <lb/>stand im <seg type="comment">
                        <orig>Berliner
                            Tagblatt</orig>
                        <note xml:id="nbrv_qmy_dbc" resp="#pkehrer">
                            <rs type="bibl" key="zotero-4528359-TTIZUJ89">Berliner Tageblatt
                                1912a</rs>
                        </note>
                    </seg>, dass <lb/>
                    <persName key="pers.2618">Nowak</persName> „<hi rendition="#u">Leiter</hi> der
                    Komp.-Klassen“ <lb/>an der <orgName key="org.10">Wiener Akad.</orgName> ist.
                    Daraufhin, <lb/>habe ich selbst an den <persName key="pers.4134">Präsidenten</persName>
                    <lb/>um Aufklärung geschrieben <!-- nicht erhalten -->und bitte <lb/>Sie einstweilen von unserer
                    Gestrigen <lb/>Unterredung <del rendition="#s">nichts</del> keinen Gebrauch
                    <lb/>zu machen. Denn damit dürfte <lb/>wohl diese ganze Affäre erledigt
                    <lb/>sein!</p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rendition="#uu">NB</hi> ich habe mit äußerster Vorsicht geschrieben! <lb/>Aber
                  es scheint, dass man mich hintergangen hat!!</p>
                </postscript>
            </div>
        </body>
