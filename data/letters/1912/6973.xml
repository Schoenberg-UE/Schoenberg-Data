    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>,
                        Berlin-Zehlendorf-Wannseebahn <lb/> Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>: </salute>
                <p rendition="#inline">In Eile!</p>
                <p>Ich habe bereits vom <persName key="pers.4134">Präsidenten</persName>
                    <lb/>
                    <seg type="comment">
                        <orig>Antwort</orig>
                        <note xml:id="nwpc_5z5_hbc" resp="#pkehrer">Karl von Wiener an Arnold Schönberg, 21. Mai 1912 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B117034">ASCC 11703</ref>)</note>
                    </seg> erhalten<hi rendition="#u">, die mich <lb/>außerordentlich befriedigt hat!!</hi>
                </p>
                <p>Nun bitte ich Sie in meinem <lb/>Interesse (es kann mich die Stellung
                    <lb/>kosten!!) um strengste Verschwie<g ref="#typoHyphen"/>
                    <lb break="no"/>genheit!!</p>
                <closer>
                    <salute>Herzl Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
