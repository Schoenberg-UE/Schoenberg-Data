    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn Direktor</addrLine>
                        <addrLine>
                            <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Herzl Gruß</salute>
                <p rendition="#inline">von einem Ausflug nach <hi rendition="#u">Rügen</hi>.
                    <lb/>Ist die Partitur der <bibl sameAs="werke.108">IX</bibl>. von <persName
                        key="pers.2225">Mahler</persName>
                    <lb/>schon <seg type="comment">
                        <orig>erschienen</orig>
                        <note xml:id="njss_kxd_pgc" resp="#KBleier">Lieferdatum: <date
                                when="1913-01-09">9. Jänner 1913</date>. Im <date when="1912-06"
                                >Juni 1912</date> war der von <persName key="pers.4273">Josef
                                Venantius Wöss</persName> erstellte Klavierauszug erschienen (<rs
                                type="bibl" key="zotero-4528359-LQMNNW3Y">Buchon 2015</rs>, Bd. 5,
                            S. 665; Exemplar aus dem Schönberg-Nachlass; SCO M31)</note>
                    </seg>? Kann ich sie haben? </p>
                <closer>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                    <salute hand="#pers.3290">Herzlichen Gruß</salute>
                    <signed>
                        <persName key="pers.3290">Mathilde
                  Schönberg</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <persName key="pers.438">Irene
                     Bien</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <persName key="pers.1701">Johanna Jalowetz</persName>
                    </signed>
                    <signed>Dr <persName key="pers.1640">Horwitz</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <persName key="pers.2150">Erna Liebenthal</persName>
                    </signed>
                    <signed>Dr <persName key="pers.1702">Jalowetz</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <persName key="pers.2155">Ite Liebenthal</persName>
                    </signed>
                </closer>
            </div>
