    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Li<supplied cert="high">e</supplied>ber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">ich komme <date when="1912-11-01">Freitag</date> früh in
                        <placeName key="place.9.11">Wien</placeName>
                    <lb/>an und werde Sie im Lauf des Nachmittags (wenn <lb/>es mir irgend
                        ausgeht<supplied cert="high">)</supplied>, besuchen. Jedenfalls aber
                    telefoniere <lb/>ich Ihnen.</p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>NB. Wer in <placeName key="place.9.15">Graz</placeName> will denn die <hi rendition="#uu">Ur</hi>aufführung meiner <lb/>
                        <bibl sameAs="werke.11">Orchesterlieder</bibl> machen. Ich habe gar keine
                        Lust dazu! <lb/>Das geht doch wohl kaum. Da kann ichs ja bald in
                            <lb/>
                        <placeName key="place.21.1">Kattowitz</placeName> an der Neisse
                        aufführen lassen. </p>
                </postscript>
            </div>
        </body>
    </text>
