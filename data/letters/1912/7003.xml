    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">eben <seg type="comment">
                        <orig>schreibt</orig>
                        <note xml:id="ncyw_212_pgc" resp="#KBleier">Alban Berg an Arnold Schönberg,
                            27. August 1912 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B101478">ASCC
                                10147</ref>)</note>
                    </seg> mir <persName key="pers.385">Berg</persName>, dass er <lb/>das „verlorene“ Pakett mit der Korrektur (<choice>
                        <sic>II</sic>
                        <corr cert="high">I</corr>
                    </choice> Theil) der <bibl sameAs="werke.16">
                        <lb/>Gurre Lieder</bibl> endlich erhalten hat. – <hi rendition="#uu">Bitte
                        teilen Sie <lb/>mir mit</hi>, <hi rendition="#u">dass Sie die </hi>
                    <hi rendition="#uu">15 Mark</hi>
                    <hi rendition="#u"> mit denen <lb/>ich <seg type="comment">
                            <orig>mich „belastet“
                                fühle</orig>
                            <note sameAs="letter.7002/#nrld_cyv_jgc"/>
                        </seg>, </hi>
                    <hi rendition="#uu">gestrichen haben</hi>. Ich zahle <lb/>das nicht! Das ist
                    doch nicht meine Schuld. – Kann <lb/>ich gegen die Post etwas tun?</p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
