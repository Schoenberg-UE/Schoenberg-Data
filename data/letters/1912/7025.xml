    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">auf Grund meiner <seg type="comment">
                        <orig>
                            <placeName key="place.8.1">Amsterdamer</placeName>
                            <lb/>Erfahrungen</orig>
                        <note xml:id="ntpk_245_2gc" resp="#KBleier">
                            <ref target="event.197"/>
                        </note>
                    </seg> habe ich in der <bibl sameAs="werke.5">Pelleas</bibl>-Partitur ein paar <lb/>kleine Retouchen
                    vorgenommen. Ich schicke Ihnen ein <lb/>3 mal durchgeschriebenes <seg type="comment">
                        <orig>Verzeichnis</orig>
                        <note sameAs="letter.7016/#nvs1_5g5_2gc"/>
                    </seg> davon und bitte <lb/>Sie ein
                    Exemplar dessen <hi rendition="#uu">sofort</hi>
                </p>
                <p>
                    <hi rendition="#u">nach <seg type="comment">
                            <orig>
                                <placeName key="place.10.2">Petersburg</placeName>
                            </orig>
                            <note xml:id="nhw1_k45_2gc" resp="#KBleier">
                                <ref target="event.194"/>
                            </note>
                        </seg>
                    </hi> zu schicken und um Eintragung <lb/>in die Stimmen zu ersuchen.</p>
                <p>Und außerdem das Material für die <placeName key="place.9.11">Wiener</placeName>
                    <seg type="comment">
                        <orig>Aufführung</orig>
                        <note sameAs="letter.7010/#nkt4_5g2_zzb"/>
                    </seg>
                    <lb/>danach korrigieren zu lassen.</p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>Ich fahre am <date when="1912-12-15">15.</date> nach <placeName key="place.10.2">Petersburg</placeName>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
