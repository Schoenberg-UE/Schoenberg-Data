    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">besten Dank für die <persName key="pers.2225">Mahler</persName>-<seg type="comment">
                        <orig>Auszüge</orig><note xml:id="npc4_jjj_kbc" resp="#pkehrer">Klavierauszüge von
                            <bibl sameAs="werke.225">Gustav Mahler, Sinfonie Nr. 2</bibl>, <bibl sameAs="werke.226"
                                    >Sinfonie Nr. 3 (bearbeitet von Josef Venantius von Wöss)</bibl> und <bibl sameAs="werke.227">Sinfonie Nr. 9 (bearbeitet von Josef Venantius von Wöss)</bibl>
                            (Exemplare aus dem Schönberg-Nachlass; SCO M18; SCO M20b; SCO M31)</note></seg>. Aber <lb/>ic<supplied cert="high">h</supplied> hatte auch noch um die
                    Partitur von <bibl sameAs="werke.108">Mahlers IX</bibl>. gebeten. <lb/>Kann ich
                    die denn nicht bekommen? – Da ich den Klavier Aus<g ref="#typoHyphen"/>
                    <lb break="no"/>zug der <bibl sameAs="werke.17">Gurre-Lieder</bibl> bis jetzt
                    noch nicht erhalten habe, nehme <lb/>ich an, dass er schon <seg type="comment">
                        <orig>erschienen</orig>
                        <note sameAs="letter.6937/#nby2_n3f_bgc"/>
                    </seg>
                    ist und bitte Sie Herrn <persName key="pers.3709">Stöhr</persName>
                    <lb/>oder <persName key="pers.3931">Vockner</persName> zu ersuchen, dass sie mir <add place="superlinear">für</add> solange, bis ich
                    eins <lb/>von der <orgName key="org.1">U. E.</orgName> bekomme, ihr
                    Ehrenexemplar von meinem Werk <lb/>leihen! – Uebrigens bitte ich Sie dringen,
                    sobald Partitur oder <lb/>Klavier Auszug erscheinen je ein Exemplar <hi rendition="#uu">sofort</hi>
                    <hi rendition="#uu">als erstes</hi>
                    <seg type="comment">
                        <orig>
                            <lb/>zu senden</orig>
                        <note xml:id="nbct_kbn_bgc" resp="#KBleier">Arnold Schönberg an Alexander Zemlinsky, 2. Oktober 1912
                                (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B002904">ASCC 290</ref>). Konkrete Aufführungspläne nicht
                        nachweisbar</note>
                    </seg> an: <hi rendition="#u">
                        <persName key="pers.4309">Alex. Zemlinsky</persName>, Prag II. <placeName key="place.13.1.2.1">Havliczekgasse 9</placeName>
                    </hi>. <lb/>Ich sage Ihnen, wie die Dinge jetzt zu stehen scheinen, wird doch <lb/>
                    <persName key="pers.4309">Zemlinsky</persName> die Uraufführung machen! Ich habe
                    das feste Gefühl!</p>
                <closer>
                    <salute>
                        <supplied cert="high">Ein</supplied>stweilen herzl Grüße Ihr </salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>Sie kommen doch zu <seg type="comment">
                            <orig>
                                <bibl sameAs="werke.54">Pierrot
                                    lunaire</bibl>
                            </orig>
                            <note xml:id="ntkd_sfc_1fc" resp="#KBleier">
                                <ref target="event.145"/>
                            </note>
                        </seg> nach <placeName key="place.2.3">Berlin</placeName> (<date when="1912-10-16">16/10.</date>)!!</p>
                </postscript>
            </div>
        </body>
    </text>
