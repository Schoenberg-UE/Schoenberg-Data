    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>,
                        Berlin-Zehlendorf-Wannseebahn <lb/> Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>
                    <supplied cert="high"> Li</supplied>eber Herr <rs type="person" key="pers.1538">Direktor</rs>, </salute>
                <p rendition="#inline">bitte senden Sie <hi rendition="#uu">schleunigst</hi> mit dem
                    <lb/>Vermerk „über Ersuchen des Autors“ <seg type="comment">
                        <orig>an <persName key="pers.282">Hermann Bahr</persName>
                        </orig>
                        <note xml:id="nfl5_q2h_cgc" resp="#TMuxeneder">
                            <persName key="pers.282">Hermann Bahr</persName> hatte 1909 die Absicht
                            ausgesprochen, bei <persName key="pers.3263">Schönberg</persName>
                            Stunden in Harmonielehre nehmen zu wollen (<rs type="bibl" key="zotero-4528359-X2WHHITQ">Muxeneder 2018a</rs>, S.
                        126)</note>
                    </seg>
                    <lb/>ein Exemplar meiner <bibl sameAs="schriften.1">Harmonielehre</bibl>. Bitte dringendst: <lb/>sofort! Es ist das eine
                    peinliche Vergesslichkeit von mir, die ich <lb/>gutmachen muss. </p>
                <closer rendition="#inline">
                    <salute>Viele herzl. Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <lb/>
                    <note place="left" hand="#addressee">
                        <stamp>Erledigt</stamp>
                    </note>
                    <dateline rendition="#l">
                        <date when="1912-01-12">12/1. 1912</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
