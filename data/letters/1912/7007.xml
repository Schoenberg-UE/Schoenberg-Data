    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Li<supplied cert="high">e</supplied>bster Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">wenn Sie wirklich Gewicht <lb/>darauf legen, dass ich das
                    autografierte <bibl sameAs="werke.5">Pelleas</bibl>
                    <lb/>Material in <seg type="comment">
                        <orig>
                            <placeName key="place.8.1">Amsterdam</placeName>
                        </orig>
                        <note xml:id="nldb_xtd_dgc" resp="#KBleier">
                            <ref target="event.197"/>
                        </note>
                    </seg>, <seg type="comment">
                        <orig>
                            <placeName key="place.8.2">Haag</placeName>
                        </orig>
                        <note xml:id="nlm1_b5d_dgc" resp="#KBleier">
                            <ref target="event.195"/>
                        </note>
                    </seg> und <seg type="comment">
                        <orig>
                            <placeName key="place.10.2">Petersburg</placeName>
                        </orig>
                        <note xml:id="nrv1_ztd_dgc" resp="#KBleier">
                            <ref target="event.194"/>
                        </note>
                    </seg>, wo ich
                    <lb/>selbst dirigiere, benutze, dann<hi rendition="#uu"> bitte ich Sie
                        dringendst</hi>
                    <lb/>
                    <hi rendition="#uu">lassen Sie es sofort gründlich korrigieren!</hi> Ich
                    <lb/>habe überall nur <hi rendition="#uu">drei</hi> Proben!! Die kann ich nicht
                    zum <lb/>Fehler-Ausbessern verwenden, sonst werde ich nicht fertig. <lb/>
                    <hi rendition="#u">Bitte schleunigst</hi>!!</p>
                <closer rendition="#inline">
                    <salute>Herzlichste Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
