    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>, Berlin-Zehlendorf-Wannseebahn
                     <lb/>
                        Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>.</stamp>
                    <address>
                        <orgName key="org.1">Universal-Edition</orgName>
                        <addrLine>Wien I</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>P. T.</salute>
                <p rendition="#inline">bitte <hi rendition="#uu">umgehendst</hi>
                    <add place="superlinear">je</add> ein Exemplar meiner folgenden <lb/>
                    <supplied cert="high">W</supplied>erke an Herrn <persName key="pers.2503">Arno
                        Nadel</persName> Berlin-Wilmersdorf <lb/>
                    <placeName key="place.2.4.1.3">Kaiserplatz 15</placeName>, der Sie für die
                        <orgName key="org.54">Musik</orgName>
                    <seg type="comment">
                        <orig>bespricht</orig>
                        <note xml:id="nlvn_lg3_rcc" resp="#KBleier">
                            <rs type="bibl" key="zotero-4528359-B7BX7KRK">Nadel
                                1912</rs>; Arno Nadel an Arnold Schönberg, 4. April 1911 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B145906">ASCC
                                14590</ref>)</note>
                    </seg>, zu <lb/>senden. Nämlich</p>
                <list rendition="#inline-block">
                    <item>
                        <bibl sameAs="werke.26">II. Quartett</bibl> Partitur</item>
                    <item>
                        <bibl sameAs="werke.9">Klavierstücke</bibl>
                    </item>
                    <item>
                        <bibl sameAs="werke.11">Orchester-Lieder</bibl>
                    </item>
                    <item>
                        <bibl sameAs="schriften.1">Harmonielehre</bibl>.</item>
                </list>
                <p rendition="#inline">Bitte aber schleunigst, denn die
               <lb/>Sache ist dringend.</p>
                <closer rendition="#inline">
                    <salute>Hochachtungsvoll</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
