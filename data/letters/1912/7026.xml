    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstr 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <dateline>
                    <date when="1912-11-30">30/11. <lb/>1912</date>
                </dateline>
                <p>Herzl Gruß nach der 2. <placeName key="place.8">holländischen</placeName>
                    <lb/>
                    <seg type="comment">
                        <orig>Aufführung</orig>
                        <note xml:id="ni5c_w45_2gc" resp="#KBleier">
                            <ref target="event.195"/>
                        </note>
                    </seg> (<placeName key="place.8.2">Haag</placeName>). Es war wohl ein <lb/>
                    <seg type="comment">
                        <orig>Erfolg</orig>
                        <note xml:id="npxb_x45_2gc" resp="#KBleier">Rezensionen: <rs type="bibl"
                                key="zotero-4528359-JW8S6397">De nieuwe courant 1912</rs>; <rs
                                type="bibl" key="zotero-4528359-B3W9ZKSM">Haagsche courant
                            1912</rs>; <rs type="bibl" key="zotero-4528359-MNNWKHMA">Rutters
                                1912</rs>
                        </note>
                    </seg>. <persName key="pers.2334">Mengelberg</persName> will jetzt immer <lb/>
                    <del rendition="#s">
                        <unclear reason="illegible" cert="low">M</unclear>
                    </del> etwas von mir machen. Senden Sie <lb/>ih<supplied cert="high"
                        >m</supplied> meine <seg type="comment">
                        <orig>Noten</orig>
                        <note xml:id="nvs3_np5_2gc" resp="#TMuxeneder">Werke (mit Orchester) im
                            Katalog der <orgName key="org.1">UE</orgName>, die zu diesem Zeitpunkt
                            noch nicht in <placeName key="place.8.1">Amsterdam</placeName>
                            aufgeführt worden waren: <bibl sameAs="werke.132">Sechs Lieder für
                                Gesang und Orchester op. 8</bibl>; <bibl sameAs="werke.2"
                                >Kammersymphonie für 15 Soloinstrumente op. 9</bibl>; <bibl
                                sameAs="werke.16">Gurre-Lieder</bibl>
                        </note>
                    </seg>.</p>
                <closer rendition="#inline">
                    <salute>Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>
                    </signed>
                    <salute hand="#pers.3290">Beste Grüße</salute>
                    <signed>
                        <persName key="pers.3290">Mathilde Schönberg</persName>
                        <lb/>
                    </signed>
                    <salute hand="#pers.3612">Ergebenst</salute>
                    <signed>
                        <persName key="pers.3612">Erwin Stein</persName>
                    </signed>
                </closer>
            </div>
            <pb n="2" xml:id="p.2"/>
            <div>
                <figure>
                    <p>
                        <placeName key="place.8.1">Amsterdam</placeName> Dam met Paleis.</p>
