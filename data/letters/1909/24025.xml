    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1909-10-07">7/101909</date>
                    </dateline>
                </opener>
                <salute>Verehrter Herr <rs type="person" key="pers.1538">Direktor,</rs>
                </salute>
                <p rendition="#inline"> verabredungsgemäß benachrichtige <lb/>ich Sie, dass ich mit
                    meinem Schüler D<hi rendition="#sup #u">r</hi>
                    <persName key="pers.4001">Anton von Webern</persName>
                    <lb/>
                    <date when="1909-10-10">Sonntag</date> vormittag gegen 1/2 12 Uhr bei Ihnen sein
                    werde <lb/>um Ihnen meine <seg type="comment">
                        <orig>
                            <bibl sameAs="werke.9">Klavierstücke</bibl>
                        </orig>
                        <note xml:id="nhdj_kbc_hdc" resp="#KBleier">
                            <persName key="pers.3263">Schönberg</persName> berichtete <persName
                                key="pers.647">Ferruccio Busoni</persName> am <date
                                when="1909-10-06">6. Oktober 1909</date> vom „gestrigen Entschlusse“
                            der Bindung an die <orgName key="org.1">Universal-Edition </orgName>für
                            10 Jahre und bittet <persName key="pers.647">Busoni</persName> um eine
                            (von der <orgName key="org.1">UE</orgName> gewünschte) Aufführungszusage
                            für seine <bibl sameAs="werke.9">Drei Klavierstücke op. 11</bibl>
                            (Arnold Schönberg an Ferruccio Busoni, 6. Oktober 1909; <ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B239447">ASCC
                                23944</ref>)</note>
                    </seg> und <seg type="comment">
                        <orig>Kompositionen <persName key="pers.4001">Weberns</persName>
                        </orig>
                        <note xml:id="nvqh_scc_hdc" resp="#KBleier">
                            <persName key="pers.3263">Schönbergs</persName> Engagement für <persName
                                key="pers.4001">Anton Webern</persName> führte kurzfristig nicht zu
                            dessen Vertragsabschluss mit der <orgName key="org.1">UE</orgName> (<rs
                                type="bibl" key="zotero-4528359-HVUQ8Z9K">Webern 2020</rs>, S.
                            12)</note>
                    </seg>
                    <lb/>vorzuführen, und bitte Sie mir Ihre Wohnungs-Adresse <lb/>mitzuteilen. </p>
                <closer rendition="#inline">
                    <salute>Hochachtungsvoll grüßend ergebenst</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
