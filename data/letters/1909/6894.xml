    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.3">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>– – – WIEN – – –
                        <lb/>IX. <placeName key="place.9.11.1.2">LIECHTENSTEINSTRASSE 68/70</placeName>
                    </stamp>
                    <address>
                        <addrLine>Herrn Direktor</addrLine>
                        <addrLine>
                            <persName key="pers.1538">Emil Hertzka</persName>
                        </addrLine>
                        <addrLine>I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.24">Wipplingerstraße 32</placeName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>S<supplied cert="high">eh</supplied>r geehrter Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline"> wann kann ich <lb/>über den <seg type="comment">
                        <orig>Erfolg
                            Ihrer <placeName key="place.2.3">Berlin</placeName> Reise</orig>
                        <note xml:id="nfb1_ybz_bgc" resp="#KBleier">
                            <persName key="pers.3263">Schönberg</persName> bezieht sich vermutlich auf eine Unterredung
                            zwischen <persName key="pers.1538">Emil Hertzka</persName> und <persName key="pers.2283">Max Marschalk</persName> (<ref target="letter.114">Arnold Schönberg an Verlag Dreililien 30.
                                Dezember 1909)</ref></note>
                    </seg> was <lb/>erfahren. Könnten Sie mir
                    das Wichtigste <lb/>schriftlich mitteilen; denn vor <date when="1909-12-04" cert="medium">Samstag</date>
                    <lb/>kann ich wol kaum zu Ihnen kommen. </p>
                <closer>
                    <salute>Ergebenste Grüße</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1909-12-01">
                            <supplied cert="low">1</supplied>/12.1909
                        </date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
