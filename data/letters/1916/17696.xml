    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.135">
                        <orgName key="org.1">„UNIVERSAL-EDITION“
                            A.-G.</orgName>
                        <lb/>WIEN, I., <placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                        <lb/>(MUSIKVEREINSGEBÄUDE).</stamp>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine>Herrn Prof. <persName key="pers.3263">Arnold
                            Schönberg</persName>
                        </addrLine>
                        <addrLine>per Adr. <hi rendition="#g">
                                <persName key="pers.2160">Lieser</persName>
                            </hi>
                        </addrLine>
                        <addrLine>Wien XIII.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.5.1">Gloriettegasse
                            45</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener>
                    <stamp>Buchhaltung</stamp>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1916-06-15">15. Juni 1916</date>.</dateline>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #u">
                                <placeName key="place.9.11">Wien</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Im Sinne unserer <seg type="comment">
                        <orig>Vereinbarung</orig>
                        <note xml:id="nrwd_5bp_vbc" resp="#pkehrer">
                            <ref target="letter.24507">Universal-Edition
                                an Arnold Schönberg?, 23. Mai 1916 [erschlossen]</ref>
                        </note>
                    </seg>
                    vom <lb/>
                    <date when="1916-05-23">23. Mai 1916</date> überwiesen wir Ihnen heute per <lb/>
                    <table rows="3" cols="3">
                        <row>
                            <cell>Postanweisung</cell>
                            <cell>K 99.80</cell>
                            <cell>zuzüglich</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>
                                <hi rendition="#u">
                                    <ellipsis>
                                        <metamark function="ellipsis">〃</metamark>
                                        <supplied>K</supplied>
                                    </ellipsis> –.20</hi>
                            </cell>
                            <cell>für Porto</cell>
                        </row>
                        <row>
                            <cell/>
                            <cell>
                                <hi rendition="#u">K 100.–</hi>
                            </cell>
                            <cell/>
                        </row>
                    </table>
                    wofür Sie uns gefl. erkennen wollen.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.85" rendition="#r">
                        <orgName key="org.1">Universal Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">
                        <unclear reason="illegible" cert="high">
                            <persName key="pers.1538">H</persName>
                        </unclear>
                    </signed>
                    <lb/>
                    <signed>
                        <persName key="pers.4190">W</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
