    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.168">
                        <persName key="pers.4278">Friedrich Wührer</persName>
                        <lb/>VI., <placeName key="place.9.11.9.8">Fillgradergasse 6</placeName>,
                        Tel. 857/II</stamp>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">bitte Herrn Prof. <seg type="comment">
                        <orig>
                            <persName key="pers.4278">Wührer</persName>
                        </orig>
                        <note xml:id="nu2x_rpb_mcc" resp="#KBleier"><persName key="pers.4278">Friedrich Wührer</persName> wirkte Ende
                                    <date when="1925-04">April 1925</date> bei Aufführungen des
                                    <bibl sameAs="werke.54">Pierrot lunaire op. 21</bibl>
                                mit:<!-- 18. Ankunft Marseille DC12478, Girona liegt am Weg nach B. --> <date when="1925-04-22">22. April 1925</date>, Girona; <ref target="event.235"/>
                        </note>
                    </seg>
                    <lb/>so rasch als möglich einen Bürsten Abzug <lb/>(womöglich exemplarmäßig)
                    meiner <lb/>
                    <bibl sameAs="werke.58">Klaviersuite</bibl> zu geben.</p>
                <closer rendition="#inline">
                    <salute>Besten Dank <lb/>und herzliche Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
