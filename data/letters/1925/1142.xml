    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.15">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>MÖDLING BEI WIEN<lb/>
                        <placeName key="place.9.4.1">BERNHARDGASSE 6</placeName>
                        <lb/>TELEPHON NR. 118<lb/>MÖDLING, <seg hand="#author">14. August </seg>
                            192<seg hand="#author">5</seg>
                    </stamp>
                    <address>
                        <addrLine>An Fräulein <persName key="pers.3067">Rothe</persName>.</addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>.</addrLine>
                    </address>
                </opener>
                <salute>Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p>Da ich bereits Ende <date when="1925-08">August</date> zum <seg type="comment">
                        <orig>Musikfest</orig>
                        <note xml:id="nqcc_hjg_4yb" resp="#pkehrer">
                            <ref target="event.23"/>
                        </note>
                    </seg>
                    <lb/>nach <placeName key="place.5.6">Venedig</placeName> fahre, möchte ich zirka
                    am <lb/>
                    <date when="1925-08-25">
                        <subst>
                            <del rendition="#s">2r</del>
                            <add place="superlinear">25</add>
                        </subst>. d. M.</date> mein Monatsgeld beheben und bitte <lb/>Sie
                    freundlichst, dieses bereit zu stellen. –<lb/>
                    <hi rendition="#ll">Ferner bitte ich Sie, Herrn <persName key="pers.300">Bechert</persName> zu er<g ref="#typoHyphen"/>
                        <lb break="no"/>suchen, die <orgName key="org.93">I. G. f. N. M.</orgName> möge d<subst>
                            <del rendition="#ow">ie</del>
                            <add place="across">en</add>
                        </subst> Musiker<add place="intralinear">n</add> mit<g ref="#typoHyphen"/>
                        <lb break="no"/>teilen, dass ich spätestens am <date when="1925-08-27">27.
                            d. M.</date> zwei <lb/>Proben gehabt haben muss, da ich sonst absagen
                        <lb/>müsste. Auf <add place="superlinear">Herrn</add>
                        <persName key="pers.2813">Pollatschek</persName> kann ich eventuell bei
                        <lb/>der Probe verzichten. Alle Anderen müssen bei der <lb/>Probe da sein.
                        In <placeName key="place.5.6">Venedig</placeName> müssen alle, auch der <lb/>
                        <rs type="person" key="pers.3410">Sänger</rs>, mindestens einen Tag vor der
                        Aufführung <lb/>für zwei Proben zur Verfügung stehen.</hi>
                </p>
                <closer rendition="#r">
                    <salute>Besten Dank und herzliche Grüsse</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
