    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Wien IX</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.1.2">Liechtensteinstr
                                <lb/>68/70</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>L. H. <persName key="pers.3263">Sch.</persName>
                </salute>
                <p rendition="#inline"> Ich bin seit <lb/>14 Tagen auf der Reise. <lb/>Daher!
                        <persName key="pers.1112">Fried</persName>, den ich <lb/>hier traf, jammert
                    nach <lb/>einem <seg type="comment">
                        <orig>Klavier-Auszug</orig>
                        <note sameAs="letter.12391/#ncdl_gf2_25b"/>
                    </seg>
                    <lb/>von <bibl sameAs="werke.5">P. u. M.</bibl> Haben Sie <lb/>nicht einen
                    Schüler der <lb/>sich aufopfern möchte.</p>
                <closer rendition="#c">
                    <salute>Viele Grüsse Ihr</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.2283">M. M.</persName>
                    </signed>
                    <lb/>und Fr. <signed>
                        <persName key="pers.2294">Olli M.</persName>
                    </signed>
                </closer>
            </div>
            <pb n="2" xml:id="p.2"/>
            <div>
                <figure>
                    <p>
                        <placeName key="place.2.24">München</placeName>
                        <lb/>Blick vom Turm des neuen Rathauses nach Westen</p>
                </figure>
            </div>
        </body>
