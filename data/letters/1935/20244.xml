    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.1750">Dr. K</persName>/<persName key="pers.4357">Bau</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1935-01-09">9.
                            Jänner 1935</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold
                                Schoenberg</persName>,</addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.15.7.1.2">5860 Canyon Cove</placeName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Hollywood, Californien</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir bestätigen den Empfang des <ref target="letter.2308">Telegramms</ref>
                    <lb/>und werden Ihrem Sohne <persName key="pers.3281">Georg</persName> den
                    Gegenwert von $ 50.– <lb/>sukzessive in der Zeit vom <date when="1935-01-14">14.
                        Jänner</date> bis <date when="1935-02-14">14. Feber</date>
                    <lb/>ausbezahlen.</p>
                <closer rendition="#inline">Wir erwarten Ihre weiteren Nachrichten <lb/>bezüglich
                    ev. weiterer Zahlungen und zeichnen <lb/>
                    <salute rendition="#r">in vorzüglicher Hochschätzung</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.4190">W</persName>
                    </signed>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
