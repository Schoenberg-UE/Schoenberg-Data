    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.42">
                        <orgName key="org.1">UNIVERSAL-EDITION A. G.</orgName>
                        <lb/>WIEN, <seg hand="#author">
                            <date when="1935-12-24">24.XII.35</date>.</seg>
                        <lb/>I. <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                    </stamp>
                </opener>
                <salute>Hochverehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>
                    <persName key="pers.385">Alban Berg</persName> ist tot. In tiefer Ergriffen<g ref="#typoHyphen"/>
                    <lb break="no"/>heit drücken wir Ihnen, verehrter Meister, der Sie mit <lb/>ihm
                    Ihren liebsten Schüler und besten Freund verloren <lb/>haben, innigst die Hände.
                    Wir alle trauern mit Ihnen <lb/>um den prachtvollen Menschen, Freund und
                    Künstler.</p>
                <closer>In innigster Verehrung und Anhänglichkeit <lb/>
                    <seg rendition="#r">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName>
                    </seg>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.4190">Winter</persName>
                    </signed>
                    <signed rendition="#r">
                        <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
