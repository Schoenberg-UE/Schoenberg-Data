    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1935-02-19">19. Februar 1935</date>
                    </dateline>
                    <stamp sameAs="stamp.37">
                        <persName key="pers.3263">ARNOLD SCHOENBERG</persName>
                        <lb/>
                        <placeName key="place.15.7.1.2">5860 CANYON COVE</placeName>
                        <lb/>HOLLYWOOD, CALIFORNIA<lb/>TEL. HEMPSTEAD 1095</stamp>
                    <address>
                        <addrLine>An die <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Lieber Herr Dir. D<hi rendition="#sup #u">r</hi>
                    <persName key="pers.1750">Kalmus</persName>,</salute>
                <p>bitte zahlen Sie meinem Sohn <lb/>
                    <persName key="pers.3281">Georg</persName>, für meine Rechnung bis auf
                    <lb/>Widerruf monatlich fünfzig Dollars.</p>
                <p>Ich bin augenblicklich sehr beschäf<g ref="#typoHyphen"/>
                    <lb break="no"/>tigt und schreibe über alles andere <lb/>ein anderes mal.</p>
                <p>Viele herzlichsten Dank für <lb/>alle die Mühe, die Sie so lieb sind, <lb/>sich
                    für mich zu machen.</p>
                <closer>
                    <salute rendition="#c">Herzlichste Grüße</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schoenberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
