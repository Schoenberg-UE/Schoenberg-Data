    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.9">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg
                     6</placeName>.-Tel. 118.</stamp>
                    <dateline>
                        <placeName key="place.9.4">Mödling</placeName>
                        <date when="1923-12-15">15/XII.1923</date>
                    </dateline>
                </opener>
                <salute>Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">Herr <persName key="pers.3599">Starbird</persName>, der in
                    <lb/>einer <placeName key="place.9.11">Wiener</placeName> Musikalienhandlung
                    vergebens <lb/>sein Glück versucht hat<choice>
                        <sic>:</sic>
                        <corr cert="high">,</corr>
                    </choice> den<seg type="comment">
                        <orig> „<bibl sameAs="schriften.88">Kon<supplied cert="high"
                                >t</supplied>rapunkt</bibl>“ von <lb/>
                            <persName key="pers.375">Bellermann</persName>
                        </orig>
                        <note xml:id="nvq3_2cj_hgc" resp="#KBleier"><persName key="pers.3599">Arthur
                                Starbird</persName> nahm ab Oktober Unterricht bei <persName
                                key="pers.3263">Schönberg</persName> (Arthur Starbird an Arnold
                            Schönberg, 18. August 1923; <ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B216234">ASCC
                                21623</ref>). Im Kontrapunktunterricht stimmte <persName
                                key="pers.3263">Schönberg</persName> mit <persName key="pers.375"
                                >Bellermann</persName> in der Verwendung von Kirchentonarten
                            überein, wich aber hinsichtlich melodischer Konstruktion von dessen
                            Prinzip ab (<rs type="bibl" key="zotero-4528359-NR72ATCS">Weiss
                                1932</rs>, S. 106f.)</note>
                    </seg> zu kaufen, wird Sie bitten, ihm dies<supplied cert="high">e</supplied>n
                    <lb/>bei <orgName key="org.81">Guttmann</orgName> zu bestellen, da er ihn sehr
                    dringend <lb/>benötigt. Darf ich Sie recht seh<choice>
                        <sic>t</sic>
                        <corr cert="high">r</corr>
                    </choice> bitten? Herzlich<g ref="#typoHyphen"/>
                    <lb break="no"/>sten Dank im Voraus. Ich komme übrigens n<choice>
                        <sic>c</sic>
                        <corr cert="high">o</corr>
                    </choice>ch vor <lb/>Weihnachten in die <orgName key="org.1">UE</orgName>. </p>
                <closer rendition="#inline">
                    <salute>Herzliche Grüsse, Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold
                     Schönberg</persName>
                    </signed>
                    <address>
                        <addrLine>Wolgeb. Frl <persName key="pers.3067">Rothe</persName>, Prokuristin
                     der</addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>,</addrLine>
                        <addrLine rendition="#r">Wien, 1. <placeName key="place.9.11.6.12">Karlsplatz<lb/>Nr. 6</placeName>
                        </addrLine>
                        <addrLine rendition="#r">Musikvereinsgebäude</addrLine>
                    </address>
                </closer>
            </div>
        </body>
    </text>
