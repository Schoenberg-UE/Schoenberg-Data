    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <note place="mTop" hand="#author">Kopie</note>
                <opener>
                    <stamp sameAs="stamp.15">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>MÖDLING BEI WIEN<lb/>
                        <placeName key="place.9.4.1">BERNHARDGASSE 6</placeName>
                        <lb/>TELEPHON NR. 118<lb/>
                        <subst>
                            <add place="intralinear">Wien</add>
                            <del rendition="#s">MÖDLING</del>
                        </subst>, <seg hand="#author">3. X</seg> 192<seg hand="#author">3</seg>
                    </stamp>
                    <address>
                        <addrLine rendition="#r">
                            <placeName key="place.9.11.7.1">Sanatorium
                                Auerspergstr.</placeName>
                        </addrLine>
                    </address>
                    <address>
                        <addrLine>P. T. <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine rendition="#r">Wien I</addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.11.6.12">Musikvereinsgebäude</placeName>
                        </addrLine>
                        <addrLine rendition="#r">Karlsplatz</addrLine>
                    </address>
                </opener>
                <salute>Liebes Frl <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">darf ich Sie bitten, mir <lb/>wieder den durch Boten
                    überreichten Schek auf <lb/>die <orgName key="org.271">Mercurbank</orgName>
                    Filiale <placeName key="place.9.4">Mödling</placeName>, oder 5
                    (fünf)-<lb/>Millionen Kronen einzulösen.</p>
                <closer rendition="#inline">
                    <salute>Besten Dank im <lb/>Voraus und herzliche Grüße Ihr</salute>
                    <signed>
                        <del rendition="#s">
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </del>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
