    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.135">
                        <orgName key="org.1">„UNIVERSAL-EDITION“
                     A.-G.</orgName>
                        <lb/>WIEN, I., <placeName key="place.9.11.6.12">KARLSPLATZ
                     6</placeName>
                        <lb/>(MUSIKVEREINSGEBÄUDE).</stamp>
                    <address>
                        <addrLine>Herrn Prof.</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine>
                            <del rendition="#s">abgereist nach <hi rendition="#u">Mödling</hi>
                            </del>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.4.1">
                                <del rendition="#s">Bernhardgasse
                                    6</del>
                            </placeName>
                        </addrLine>
                        <addrLine>
                            <del rendition="#s">Traunkirchen</del>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.10.1">
                                <del rendition="#s">Villa
                                    Josef</del>
                            </placeName>
                        </addrLine>
                        <addrLine>
                            <del rendition="#s">Ob. Oe.</del>
                        </addrLine>
                        <addrLine>Wien VIII</addrLine>
                        <addrLine>
                            <seg type="comment">
                                <orig>
                                    <placeName key="place.9.11.7.1">Auerspergstrasse <lb/>9</placeName>
                                </orig>
                                <note xml:id="nn1g_kx3_hgc" resp="#TMuxeneder">Spitalsaufenthalt von
                                        <persName key="pers.3290">Mathilde Schönberg</persName> im
                                        <orgName key="org.272">Sanatorium Auersperg</orgName> von
                                        <date when="1923-09-19">19. September 1923</date> bis zu
                                    ihrem Ableben am <date when="1923-10-18">18. Oktober
                                    1923</date>
                                </note>
                            </seg>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.3067">R</persName>/<persName key="pers.4368">Ei</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am
                     <date when="1923-09-19">19. September 23</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold
                     Schönberg</persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #uda">
                                <placeName key="place.9.10">Traunkirchen</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Soeben ist Ihre „<bibl sameAs="werke.190">Kammer<g ref="#typoHyphen"/>
                        <lb break="no"/>symphonie</bibl>“ in der Bearbeitung für Klavier zwei<g ref="#typoHyphen"/>
                    <lb break="no"/>händig von Herrn <persName key="pers.3662">Steuermann</persName> erschienen und <lb/>lassen wir Ihnen gleichzeitig 1
               Ehrenexemplar <lb/>zugehen.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp
                  <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
