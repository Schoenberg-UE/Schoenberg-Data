    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <p>Für die erwiesene <seg type="comment">
                        <orig>Teilnahme</orig>
                        <note xml:id="nyzv_cx3_hgc" resp="#KBleier">
                            <persName key="pers.3290">Mathilde
                        Schönberg</persName> verstarb am <date when="1923-10-18">18. Oktober
                        1923</date> im <orgName key="org.272">Sanatorium
                  Auersperg</orgName>
                        </note>
                    </seg> sagen <lb/>vom Herzen Dank </p>
                <p>
                    <persName key="pers.3263">Arnold Schönberg</persName>, <persName key="pers.3284">Gertrud
               Greissle</persName>
                    <lb/>geb. Schönberg, <persName key="pers.3281">Georg
                  Schönberg</persName>, <lb/>
                    <persName key="pers.1339">Felix Greissle</persName>.</p>
                <closer>
                    <dateline rendition="#l">
                        <placeName key="place.9.4">Mödling</placeName>, <date when="1923-10">Oktober 1923</date>.</dateline>
                    <address>
                        <addrLine>
                            <placeName key="place.9.4.1">Bernhardgasse 6</placeName>.</addrLine>
                    </address>
                    <note place="mBottom" hand="#author">Herzlichsten Dank für die Blumen. <lb/>Ihr <signed>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </signed>
                    </note>
                </closer>
            </div>
        </body>
