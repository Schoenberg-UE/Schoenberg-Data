    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <placeName key="place.9.10">Traunkirchen</placeName>xxxxxxxx<date when="1923-09-11">II.IX. <supplied cert="high">192</supplied>3</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn Dr. <persName key="pers.1750">Kallmus</persName>, <orgName key="org.131">Philharmonia-Verlag</orgName>
                        </addrLine>
                        <addrLine rendition="#r">Wien IV.</addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.11.12.1">Suttnerplatz 10</placeName>
                        </addrLine>
                    </address>
                </opener>
                <p>
                    <seg type="comment">
                        <orig>Ich telegraphierte Ihnen heute</orig>
                        <note xml:id="ngq2_55h_4bc" resp="#jfranz">
                            <ref target="letter.99">Arnold Schönberg an Wiener Philharmonischer
                                Verlag, 11. September 1923</ref>
                        </note>
                    </seg>: <lb/>„Ich verbiete unbedingt die Herausgabe <bibl sameAs="werke.2"
                        >Solo-Kammersymphonie</bibl> wenn der von mir <lb/>herausgegebene Text auch
                    nur im geri<supplied cert="high">n</supplied>gsten <choice>
                        <sic>ver</sic>
                        <corr type="deleted"/>
                    </choice>
                    <lb/>
                    <seg type="comment">
                        <orig>verändert</orig>
                        <note xml:id="nejy_fs3_hgc" resp="#KBleier">„Unter anderem hab ich die <bibl
                                sameAs="werke.2">Kammersymphonie</bibl> für die Ausgabe des <orgName
                                key="org.131">Philharmonischen Verlag</orgName> revidiert. Durch
                            Zusätze in kleinem Stich ist auch die <bibl sameAs="werke.154"
                                >Orchester-Bearbeitung</bibl> in der neuen Ausgabe enthalten“ (Erwin
                            Stein an Arnold Schönberg, 10. September 1923; <ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B216770">ASCC
                                21677</ref>). Die Studienpartitur erschien in zwei verschiedenen
                            Aufmachungen als Publikation der <orgName key="org.1"
                                >Universal-Edition</orgName> bzw. als Philharmonia-Partitur mit
                            identischem Notentext (<rs type="bibl">ASGA B 11/2</rs>, S. 26f.)</note>
                    </seg> wurde“ <lb/>und füge erläuternd bei, dass ich gegen diese
                    <lb/>Vergewaltigung nötigenf<del rendition="#s">e</del>alls mit den äusser<g
                        ref="#typoHyphen"/>
                    <lb break="no"/>sten Mitteln einschreiten werde.</p>
                <closer>
                    <salute>Mit Hochachtung</salute>
                    <note place="mBottom" hand="#author">
                        <choice>
                            <abbr>recom</abbr>
                            <expan>recommandiert</expan>
                        </choice>
                    </note>
                </closer>
            </div>
        </body>
    </text>
