    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <note place="mTop" hand="#author">Kopie</note>
                <opener>
                    <stamp sameAs="stamp.15">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>
                        <subst>
                            <del rendition="#s">MÖDLING BEI WIEN<lb/>
                                <placeName key="place.9.4.1">BERNHARDGASSE 6</placeName>
                                <lb/>TELEPHON NR. 118</del>
                            <add place="sublinear">Wien <placeName key="place.9.11.7.1">Sanatorium
                           Auerspergstr.</placeName>
                            </add>
                        </subst>
                        <lb/>
                        <subst>
                            <del rendition="#s">MÖDLING</del>
                            <add place="superlinear">Wien</add>
                        </subst>, <date when="1923-10-10">
                            <seg hand="#author">10. X</seg> 192<seg hand="#author">3</seg>
                        </date>
                    </stamp>
                    <address>
                        <addrLine>P. T. <orgName key="org.1">Universal-Edition</orgName>, Wien
                     I</addrLine>
                        <addrLine rendition="#c">
                            <placeName key="place.9.11.6.12">Karlsplatz
                     6</placeName>
                        </addrLine>
                        <addrLine rendition="#c">Musikvereinsgebäude</addrLine>
                    </address>
                </opener>
                <table cols="2">
                    <row>
                        <cell>
                            <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                        </cell>
                        <cell rows="2">darf ich Sie bitten, den durch</cell>
                    </row>
                    <row>
                        <cell>
                            <salute>Liebes Frl <persName key="pers.3067">Rothe</persName>
                            </salute>
                        </cell>
                    </row>
                </table>
                <p rendition="#inline">den Überbringer (v. <orgName key="org.272">Sanatorium</orgName>) Ihnen gebrachten <lb/>Schek auf die <placeName key="place.9.4">Mödlinger</placeName>
                    <orgName key="org.271">Merkur-Bank</orgName> Filiale <lb/>über <subst>
                        <del rendition="#ow">5</del>
                        <add place="across">4</add>
                    </subst>,000.000 (<del rendition="#s">fünf</del>
                    <add place="sublinear">eigenhändig korrigiert
                  <signed>
                            <persName key="pers.3263">Arnold
                     Schönberg</persName>
                        </signed>
                    </add> Vier
               Millionen) Kr für <lb/>mich auszubezahlen und den Schek einzukassieren.</p>
                <closer>
                    <salute>Mit herzlichstem Dank bin ich Ihr ergebener</salute>
                    <signed>
                        <del rendition="#s">
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </del>
                    </signed>
                </closer>
                <note place="mBottom" hand="#author">Kopie</note>
            </div>
        </body>
    </text>
