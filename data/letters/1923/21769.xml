    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.135">
                        <orgName key="org.1">„UNIVERSAL-EDITION“
                     A.-G.</orgName>
                        <lb/>WIEN, I., <placeName key="place.9.11.6.12">KARLSPLATZ
                     6</placeName>
                        <lb/>(MUSIKVEREINSGEBÄUDE).</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Mödling bei Wien</addrLine>
                        <addrLine>
                            <placeName key="place.9.4.1">Bernhardgasse 6</placeName>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.4368">Ei.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1923-03-26">
                            <subst>
                                <del rendition="#ow">15</del>
                                <add place="across">26</add>
                            </subst>. März 1923</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <hi rendition="#g">
                                    <placeName key="place.9.4">Mödling</placeName>
                                </hi> b. Wien</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir entsprechen gerne einer <seg type="comment">
                        <orig>Anre<g ref="#typoHyphen"/>
                            <lb break="no"/>gung</orig>
                        <note xml:id="ntmz_qw4_vcc" resp="#pkehrer">Ernst Krenek an
                            Universal-Edition, 13. März 1923 (<rs type="bibl"><rs type="bibl"
                                    key="zotero-4528359-TJVR5Q5V">Krenek 2010</rs></rs>, S. 50f.).
                            Die darauf folgende Beschwerde in Ernst Krenek an Universal-Edition, 26.
                            März 1923 (<rs type="bibl"><rs type="bibl" key="zotero-4528359-TJVR5Q5V"
                                    >Krenek 2010</rs></rs>, S. 51f.), es habe „keiner der mir
                            erreichbaren Adressaten [...] etwas erhalten“, stimmt mit der
                            Umdatierung der vorliegenden Karte vom 15. auf den 26. März überein; der
                            Grund für die Verspätung ist unklar</note>
                    </seg> des Komponisten <persName key="pers.2053">Ernst Krenek</persName> und
                    lassen Ihnen <lb/>ein Ehrenexemplar seines soeben erschienen<supplied
                        cert="high">en</supplied> Kla<g ref="#typoHyphen"/>
                    <lb break="no"/>vierstückes <seg type="comment"><orig>„<bibl sameAs="werke.96"
                                >Toccata und Chaconne</bibl>“</orig><note xml:id="nrpk_whq_mhc"
                            resp="#KBleier">Exemplar aus dem Schönberg-Nachlass (PM/med
                        10)</note></seg> zugehen.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.128" rendition="#r">
                        <orgName key="org.1">Universal-Edition
                     Actiengesellschaft</orgName>.
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp
                        <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
