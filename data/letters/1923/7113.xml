    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsp<supplied cert="high">latz</supplied> 6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Herzliche Grüße!</salute>
                <p rendition="#inline"> Ich bin sehr zufrieden <lb/>hier. Alles <seg type="comment">
                        <orig>Musikalische</orig>
                        <note xml:id="nx43_113_hgc" resp="#KBleier">
                            <ref target="event.219"/>
                        </note>
                    </seg> ausge<g ref="#typoHyphen"/>
                    <lb break="no"/>zeichnet und der persönliche sehr <lb/>angenehme <persName
                        key="pers.1901">Klenau</persName> ist wi<supplied cert="high"
                    >r</supplied>klich <lb/>sehr lieb und nett!</p>
                <closer rendition="#inline">
                    <salute>Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Schönberg</persName>, Kopenhagen</addrLine>
                        <addrLine>
                            <placeName key="place.1.1.2">Hotel
                     D’Angleterre</placeName>
                        </addrLine>
                    </address>
                    <dateline>
                        <date when="1923-01-27">27/I.1923</date>
                    </dateline>
                </closer>
                <pb n="2" xml:id="p.2"/>
                <figure>
                    <p>
                        <placeName key="place.1.1">København</placeName>. Raadhuset set fra
                        Tivoli.</p>
                </figure>
            </div>
        </body>
