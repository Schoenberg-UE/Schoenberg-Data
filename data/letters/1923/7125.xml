    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.15">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>MÖDLING BEI WIEN<lb/>
                        <placeName key="place.9.4.1">BERNHARDGASSE 6</placeName>
                        <lb/>TELEPHON NR. 118<lb/>
                        <subst>
                            <del rendition="#s">MÖDLING,</del>
                            <add place="superlinear">Wien,</add>
                        </subst>
                        <date when="1923-10-26">
                            <seg hand="#author">
                                <unclear reason="illegible" cert="high">2</unclear>6.X.</seg> 192<seg hand="#author">3</seg>
                        </date>
                    </stamp>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">ich bitte Sie zu veranlassen, dass <lb/>mir <hi rendition="#u">zu jeder <bibl sameAs="werke.16">Gurrelieder</bibl>
                        <seg type="comment">
                            <orig>Aufführung</orig>
                            <note xml:id="nwkx_wx3_hgc" resp="#KBleier"><ref target="event.221"/>; <ref target="event.222"/>; <ref target="event.223"/>
                            </note>
                        </seg>
                    </hi> (auch Generalproben) <lb/>zehn beste <hi rendition="#u">Frei</hi>karten <del rendition="#s">einf</del> zugeschickt
                    werden <lb/>und außerdem ca <lb/>15–20 Karten verschiedener Kategorie zum Kaufen
                    <lb/>solange wie möglich reserviert bleiben.</p>
                <closer rendition="#inline">
                    <salute>Besten Dank u Gruß <lb/>
                        <seg rendition="#r">Ihr</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
