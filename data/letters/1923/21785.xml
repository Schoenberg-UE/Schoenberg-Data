    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Professor <persName key="pers.3263">Arn<choice>
                                    <sic>a</sic>
                                    <corr type="deleted"/>
                                </choice>old<lb/>
                                <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine>
                            <subst>
                                <del rendition="#s">
                                    <hi rendition="#g">Mödling</hi> bei Wien<lb/>
                                    <placeName key="place.9.4.1">Bernhardgasse 6</placeName>
                                </del>
                                <add place="superlinear">Wien VIII <placeName key="place.9.11.7.1">Auerspergs<supplied cert="high">tr</supplied>
                                        <lb/>9</placeName>
                                </add>
                            </subst>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.3067">R</persName>/<persName key="pers.4368">EI</persName>/<persName key="pers.4190">W.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1923-10-01">1. Oktober 1923</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #uda">
                                <placeName key="place.9.4">Mödling</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Soeben ist die Partitur von <persName key="pers.2053">Krenek’s</persName>
                    <lb/>„<bibl sameAs="werke.97">Symphonische Musik</bibl>“ erschienen un<choice>
                        <sic>s</sic>
                        <corr cert="high">d</corr>
                    </choice> erlauben wir <del rendition="#s">uns</del>
                    <lb/>uns, Ihnen über Anregung des
                    Komponisten ein <lb/>
                    <seg type="comment">
                        <orig>Ehrenexemplar</orig>
                        <note xml:id="njdz_hw3_hgc" resp="#KBleier">Exemplar aus dem Schönberg-Nachlass (PM/med 10)</note>
                    </seg> einzusenden.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.4190">Winter</persName>
                    </signed>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
