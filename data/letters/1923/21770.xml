    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.135">
                        <orgName key="org.1">„UNIVERSAL-EDITION“
                     A.-G.</orgName>
                        <lb/>WIEN, I., <placeName key="place.9.11.6.12">KARLSPLATZ
                     6</placeName>
                        <lb/>(MUSIKVEREINSGEBÄUDE).</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Professor</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">Mödling</hi> b/Wien</addrLine>
                        <addrLine>
                            <placeName key="place.9.4.1">Bernhard<del rendition="#s">t</del>gasse
                        6</placeName>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.3067">R</persName>/<persName key="pers.3795">Sw</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1923-04-21">21. April 1923</date>.</dateline>
                    <address>
                        <addrLine>Herrn Professor</addrLine>
                        <addrLine rendition="#c">
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.4">
                                <hi rendition="#g">Mödling</hi>
                            </placeName>.
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir entsprechen gerne einer Anregung <lb/>des Komponisten <persName key="pers.2394">Darius Milhaud</persName> und erlauben uns <lb/>Ihnen
                    gleichzeitig die vor kurzem erschienene <lb/>Partitur seiner „<seg type="comment">
                        <orig>Cinq Sinfonies</orig>
                        <note xml:id="nycp_mgm_jyb" resp="#pkehrer">
                            <bibl sameAs="werke.110">Symphonie de Chambre Nr. 1 op. 43 „Printemps“</bibl>;
                                <bibl sameAs="werke.233">Symphonie de Chambre Nr. 2 op. 49
                                „Pastorale“</bibl>; <bibl sameAs="werke.234">Symphonie
                                de Chambre Nr. 3 op. 71 „Serenade“</bibl>; <bibl sameAs="werke.235">Symphonie de Chambre Nr. 4 op. 74</bibl>; <bibl sameAs="werke.236">Symphonie de Chambre Nr. 5 op. 75</bibl>
                            (Exemplar aus dem Schönberg-Nachlass; PM/sm 4)</note>
                    </seg>“ als Ehrenexem<g ref="#typoHyphen"/>
                    <lb break="no"/>plar einzusenden.</p>
                <closer>Wir empfehlen uns <lb/>
                    <seg rendition="#r">hochachtungsvoll </seg>
                    <lb/>
                    <stamp sameAs="stamp.128" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>.
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp
                  <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
