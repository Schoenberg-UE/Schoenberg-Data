    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.15">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>MÖDLING BEI WIEN<lb/>
                        <placeName key="place.9.4.1">BERNHARDGASSE 6</placeName>
                        <lb/>TELEPHON NR. 118<lb/>MÖDLING, <date when="1923-12-03">
                            <seg hand="#author">3.XII.</seg> 192<seg hand="#author">3</seg>
                        </date>
                    </stamp>
                    <address>
                        <addrLine>PT <orgName key="org.1">Universal-Edi<choice>
                                    <sic>l</sic>
                                    <corr cert="high">t</corr>
                                </choice>ion</orgName>, Wien 1 <placeName key="place.9.11.6.12">Karlsplatz
                        6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <p>Bitte dem mir bestens empfoh<g ref="#typoHyphen"/>
                    <lb break="no"/>lenen <orgName key="org.273">Danziger Trio</orgName>, welches
                    die Absicht hat, <lb/>den <bibl sameAs="werke.54">Pierr<supplied cert="high">o</supplied>t lunaire</bibl> aufzuführen 25–30 Ensem<g ref="#typoHyphen"/>
                    <lb break="no"/>bleproben <!-- nicht nachgewiesen -->zur Bedingung zu machen, ihm aber be<g ref="#typoHyphen"/>
                    <lb break="no"/>züglich der Materiall<choice>
                        <sic>l</sic>
                        <corr type="deleted"/>
                    </choice>eihgebühr soweit wie <lb/>irgend möglich entgegen zu kommen.</p>
                <closer rendition="#inline">
                    <salute>Hochachtungs<g ref="#typoHyphen"/>
                        <lb break="no"/>voll</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
