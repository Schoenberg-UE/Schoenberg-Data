    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.52">
                        <orgName key="org.180">VERLAG<lb/>DREILILIEN</orgName>
                        <lb/>Halensee-Berlin<lb/>
                        <del rendition="#s">
                            <placeName key="place.2.4.1.1">Georg Wilhelm-Str. 22</placeName>
                        </del>
                        <lb/>den <date when="1923-02-10">
                            <seg hand="#author">10.Febr<supplied cert="high">u</supplied>ar 23</seg>
                            190</date>
                    </stamp>
                    <address>
                        <addrLine>Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">Mödling bei</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Wien</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.4.1">Bernhardsgasse
                                6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute rendition="#c">Sehr geehrter <rs type="person" key="pers.3263">Herr</rs>!</salute>
                <p>Anbei übersenden wir Ihnen die Kopie des am <date when="1923-01-04">4.1.23</date>
                    an <lb/>Sie gerichteten <ref target="letter.20322">Briefes</ref> nebst <ref target="document.20323">Abrechnung</ref>, der leider nicht <lb/>in Ihre
                    Hände gelangt ist.</p>
                <closer rendition="#c">
                    <salute>Hochachtungsvoll</salute>
                    <lb/>per <orgName key="org.180">Verlag Dreililien</orgName>
                    <lb/>
                    <signed>
                        <persName key="pers.4222">Wolf</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
