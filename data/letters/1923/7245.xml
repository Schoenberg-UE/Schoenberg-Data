    <text>
        <body>
            <div type="letter">
                <div type="writingSession" n="1">
                    <pb n="1" xml:id="p.1"/>
                    <opener>
                        <dateline>
                            <date when="1923-11-06">6.XI.<supplied cert="high">192</supplied>3</date>
                        </dateline>
                        <address>
                            <addrLine>Herrn <persName key="pers.1532">Carl Heinzen</persName>,
                                Düsseldorf, <placeName key="place.2.12.1">Düsselstr <lb/>
                                    <seg rendition="#r">68</seg>
                                </placeName>
                            </addrLine>
                        </address>
                    </opener>
                    <salute>Sehr geehrter <rs type="person" key="pers.1532">Herr</rs>,</salute>
                    <p rendition="#inline">Sie haben von <orgName key="org.43">Peters</orgName> die <lb/>
                        <seg type="comment">
                            <orig>Partitur</orig>
                            <note xml:id="nak4_jpc_gxb" resp="#pkehrer">
                                <bibl sameAs="werke.47">Arnold Schönberg, Fünf Orchesterstücke op.
                                    16</bibl>
                            </note>
                        </seg> erhalten, die, revidiert <date when="1922">1922</date> eben
                        <lb/>diese Verbesserungen alle schon enthält, <del rendition="#s">we</del>
                        <lb/>
                        <del rendition="#s">
                            <gap reason="illegible" quantity="4" unit="chars"/>
                        </del>
                        <add place="superlinear">welche</add> auf der <seg type="comment">
                            <orig>Liste</orig>
                            <note xml:id="nh52_p31_kyb" resp="#pkehrer">Fehlerliste, autographiert
                                    (<ref
                                    target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=623&amp;werke_id=228&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                    >ASGA B 12, Quelle G</ref>)</note>
                        </seg> für die Besitzer der un<g ref="#typoHyphen"/>
                        <lb break="no"/>revidierten Ausgabe und für die Stimmen <del rendition="#s">
                            <gap reason="illegible" quantity="2" unit="chars"/>
                        </del>
                        <lb/>
                        <del rendition="#s">
                            <gap reason="illegible" quantity="4" unit="chars"/>
                        </del> zusammengestellt wurden! In Eile einst<g ref="#typoHyphen"/>
                        <lb break="no"/>weilen das. ––– Am Ende dieses Briefes finden <lb/>Sie eine
                        Empfehlung an die <orgName key="org.1">UE</orgName>, die Sie an <lb/>diese
                        gef. einsenden wollen.</p>
                    <closer rendition="#inline">
                        <salute>Hochachtungsvol<supplied cert="high">l</supplied>
                        </salute>
                    </closer>
                </div>
                <div type="writingSession" n="2">
                    <salute>PT <orgName key="org.1">Universal Edition</orgName>,</salute>
                    <p rendition="#inline">Ich empfehle hiemit, <lb/>Herrn <persName key="pers.1532">Carl Heinzen</persName>, Musikkritiker der <orgName key="org.54">Musik</orgName>
                        <lb/>etc., der meine Sachen wirklich kennen zu <lb/>lernen b<supplied cert="high">e</supplied>str<supplied cert="high">e</supplied>bt ist, ein
                            Exem<supplied cert="high">p</supplied>lar der <bibl sameAs="werke.2">Kam<g ref="#typoHyphen"/>
                            <lb break="no"/>mersymphonie</bibl>-Partitur und <bibl sameAs="werke.190">Steuermannbear<choice>
                                <sic> e</sic>
                                <corr type="deleted"/>
                            </choice>
                            <lb break="no"/>beitung</bibl> und ein Exemplar <bibl sameAs="werke.26">II. Quartett</bibl>-Part. <lb/>zu senden.</p>
                    <closer rendition="#inline">
                        <salute>Hochachtungsvoll</salute>
                        <dateline rendition="#l">
                            <placeName key="place.9.4">Mödling</placeName>
                            <date when="1923-11-06">6.XI.1923</date>
                        </dateline>
                    </closer>
                </div>
            </div>
        </body>
    </text>
