    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.135">
                        <orgName key="org.1">„UNIVERSAL-EDITION“
                     A.-G.</orgName>
                        <lb/>WIEN, I., <placeName key="place.9.11.6.12">KARLSPLATZ
                     6</placeName>
                        <lb/>(MUSIKVEREINSGEBÄUDE).</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">Traunkirchen</hi>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.10.1">Villa Josef</placeName>
                            <add place="sublinear">Ob.Oe.</add>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <address>
                        <addrLine>
                            <hi rendition="#uda">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                                </persName>, <placeName key="place.9.10">Traunkirchen</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir bitten Sie, uns die von Ihnen bean<g ref="#typoHyphen"/>
                    <lb break="no"/>ständete Abrechnung freudlichst
                    zurück zu senden, <lb/>damit wir Ihnen soweit als möglich die Details
                    <lb/>einfügen können.</p>
                <p>Die gewünschten Werke, gehen gleichzeitig <lb/>an Ihre werte Adresse.</p>
                <closer>
                    <salute rendition="#r">Mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                    <dateline rendition="#l">
                        <placeName key="place.9.11">Wien</placeName>, <date when="1923-07-20">20. Juli
                  1923</date>
                    </dateline>
                    <persName key="pers.3067">R</persName>/<persName key="pers.4357">Bau</persName>
                </closer>
            </div>
        </body>
    </text>
