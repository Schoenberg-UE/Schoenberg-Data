    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.143">
                        <persName key="pers.3263">
                            <supplied cert="high">Arnold</supplied>
                            Schönberg</persName>
                        <lb/>
                        <supplied cert="high">Wien, XII</supplied> I. <placeName key="place.9.11.5.1">Gloriette- <lb/>
                            <supplied cert="high">gasse</supplied> 43</placeName>. Tel. 84373 </stamp>
                    <dateline>
                        <date when="1915-12-10">10.12.1915</date>
                    </dateline>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">Sie haben zwar meinen <lb/>seinerzeitigen <ref
                        target="letter.461">Vorschlag</ref>, die zwischen uns schwebenden Fragen
                    <lb/>in Güte zu ordnen durch die beleidigenden Frozzeleien Ihrer <lb/>
                    <ref target="letter.17582">Antwort</ref> verhindert. Aber, da ich <seg
                        type="comment">
                        <orig>am <date when="1915-12-15">15.</date> einrücke</orig>
                        <note xml:id="nhld_hmg_ggc" resp="#TMuxeneder">
                            <persName key="pers.3263">Schönberg</persName> rückte am <date
                                when="1915-12-15">15. Dezember 1915</date> als Kriegsfreiwilliger
                            zum <orgName key="org.53">k. k. Infanterieregiment „Hoch- und
                                Deutschmeister“ Nr. 4</orgName> ein</note>
                    </seg> und mut<g ref="#typoHyphen"/>
                    <lb break="no"/>maßlich wenn ich tauglich bin, in einigen Monaten ins Feld gehe,
                    <lb/>so will ich meine Angelegenheiten noch rasch ordnen
                    und <hi rendition="#u">biete <lb/>Ihnen nochmals die Hand zum Frieden</hi>
                </p>
            </div>
        </body>
    </text>
