    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine>Herrn <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">Berlin</hi> – Südende</addrLine>
                        <addrLine>
                            <placeName key="place.2.23.1.1">Berlinerstr. 17 a</placeName>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <address>
                        <addrLine>Wohlgeboren Herrn <persName key="pers.3263">Arn. Schönberg</persName>
                            <placeName key="place.2.3">Berlin</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Am <date when="1914-06-09">9. Juni 1914</date>
                    <seg type="comment">
                        <orig>sandten</orig>
                        <note xml:id="nmdm_4vn_xcc" resp="#pkehrer"><ref target="letter.17543">Universal-Edition an
                                Arnold Schönberg, 8. Juni 1914</ref>
                        </note>
                    </seg> wir Ihnen 10
                    Exemplare <lb/>der <bibl sameAs="werke.2">Kammersymphonie</bibl> in Partitur und
                    Stimmen. Sie <lb/>wollten damals diese Materiale entsprechend ein<g ref="#typoHyphen"/>
                    <lb break="no"/>richten. Nun sind inzwischen 9 Monate vergangen <lb/>und wir
                    haben über diese Sache <seg type="comment">
                        <orig>nichts weiter ge<g ref="#typoHyphen"/>
                            <lb break="no"/>hört</orig>
                        <note sameAs="letter.17543/#nyhs_j4n_xcc"/>
                    </seg>.</p>
                <closer>Wir sehen Ihrer freundl. umgehenden Rück<g ref="#typoHyphen"/>
                    <lb break="no"/>äusserung resp. Einsendung der Materiale entgegen <lb/>und zeichnen <lb/>
                    <salute rendition="#r">hochachtungsvoll</salute>
                    <lb/>
                    <stamp sameAs="stamp.68">WIEN <seg hand="#author">
                            <date when="1915-03-16">16. März 1915</date>
                        </seg>
                        <lb/>I,
                     <placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>.<lb/>
                        <orgName key="org.1">UNIVERSAL-EDITION A.-G.</orgName>
                    </stamp>
                </closer>
            </div>
        </body>
    </text>
