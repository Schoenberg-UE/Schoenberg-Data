    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.52">
                        <orgName key="org.180">VERLAG<lb/>DREILILIEN</orgName>
                        <lb/>Halensee-Berlin<lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Str. 22</placeName>
                        <lb/>den <date when="1907-05-31">
                            <seg hand="#author">31. Mai 07.
                            </seg>190</date>
                    </stamp>
                    <address>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">
                                <placeName key="place.9.11">Wien</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute rendition="#c">Lieber Herr <persName key="pers.3263">
                        <hi rendition="#g">Schönberg</hi>
                    </persName>!</salute>
                <p>Die <seg type="comment">
                        <orig>Stimmen</orig>
                        <note sameAs="letter.11564/#nlvg_t22_zyb"/>
                    </seg> zu Ihrem <bibl sameAs="werke.42">Quartett</bibl> befinden sich in <placeName key="place.2.20">Leipzig</placeName>. Ich habe an <lb/>
                    <orgName key="org.211">Röder</orgName> geschrieben und gebeten den Stich nach
                    Möglichkeit zu beschleuni<g ref="#typoHyphen"/>
                    <lb break="no"/>gen und nach
                    Fertigstellung Ihnen die Korrektur sofort zuzustellen. Sei<g ref="#typoHyphen"/>
                    <lb break="no"/>en Sie dann doch so freundlich die Korrektur möglichst
                    schnell zu lesen; <lb/>wir möchten doch gern die Stimmen fertig haben bis zu dem
                        <seg type="comment">
                        <orig>Fest</orig>
                        <note xml:id="ng3f_kjm_lzb" resp="#KBleier">
                            <ref target="event.26"/>
                        </note>
                    </seg>, um einer <lb/>evtl. Nachfrage genügen zu
                    können.</p>
                <closer rendition="#r">
                    <salute>Mit besten Grüssen auch an Ihre <rs type="person" key="pers.3290">Frau</rs>
                        <lb/>Ihr</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.2283">Max Marschalk</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
