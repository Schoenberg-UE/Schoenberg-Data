    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Wien IX</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.1.2">Liechtensteinstr 68/70</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieb. Herr <persName key="pers.3263">Sch</persName>.</salute>
                <p>Guten Erfolg für <lb/>
                    <seg type="comment">
                        <orig>morgen</orig>
                        <note xml:id="nttt_pbt_lzb" resp="#KBleier">
                            <ref target="event.41"/>
                        </note>
                    </seg>! Und seien Sie <lb/>mir nicht böse, dass ich <lb/>Sie wieder mal warten
                    <lb/>lasse. Aber ich wollte Ih<g ref="#typoHyphen"/>
                    <lb break="no"/>nen einen besonders netten <lb/>Brief schreiben; und da<g ref="#typoHyphen"/>
                    <lb break="no"/>zu fand ich im Gedrang <lb/>der Geschäfte noch nicht <lb/>Zeit.
                    Ausserdem war ich <lb/>jetzt 14 Tage verreist.</p>
                <closer rendition="#c">
                    <salute>Beste Grüsse v. Haus <lb/>zu Haus <lb/>Ihr </salute>
                    <lb/>
                    <signed>
                        <persName key="pers.2283">M. M.</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1907-11-06">6.11.07</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
