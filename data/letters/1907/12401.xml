    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.93">
                        <orgName key="org.180">Verlag Dreililien</orgName> Berlin <lb/>
                        <placeName key="place.2.4.1">Berlin-Halensee</placeName>
                    </stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Wien IX</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.1.2">Liechtensteinstr
                            68/70</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>L. H. <persName key="pers.3263">Sch.</persName>
                </salute>
                <p rendition="#inline">Mir wird eben <lb/>mitgeteilt, dass die rechtzeitige <seg type="comment">
                        <orig>Fer<g ref="#typoHyphen"/>
                            <lb break="no"/>tigstellung</orig>
                        <note sameAs="letter.13002/#nwbs_1tm_c5b"/>
                    </seg>
                    des <bibl sameAs="werke.42">Quartettes</bibl> nicht garan<g ref="#typoHyphen"/>
                    <lb break="no"/>tiert werden kann, da bis zum <date when="1907-01-31">31.</date>
                    <lb/>abends die letzten Korrekturbogen <lb/>von Ihnen nicht gesandt seien. </p>
                <p>Warum machen Sie nun in <lb/>letzter Stunde noch solche Sachen? <lb/>Schade.</p>
                <closer rendition="#c">
                    <salute>Bestens Ihr </salute>
                    <signed>
                        <persName key="pers.2283">M.M.</persName>
                    </signed>
                    <stamp sameAs="stamp.109" rendition="#l">
                        <placeName key="place.2.4.1">Berlin-Halensee</placeName>, den <date when="1907-02-01">
                            <seg hand="#author">1. Febr</seg> 190<seg hand="#author">7</seg>
                        </date>
                    </stamp>
                </closer>
            </div>
        </body>
    </text>
