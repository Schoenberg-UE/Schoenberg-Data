    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.96">
                        <orgName key="org.1">Universal-Edition·A. G.</orgName>
                        <lb/>WIEN·I·<placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                        <lb/>Musikvereinsgebäude</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schoenberg</persName>, <add place="superlinear" hand="#unknown">
                                <placeName key="place.15.9.1">Ho. Constance</placeName>
                            </add>
                        </addrLine>
                        <addrLine>
                            <subst>
                                <del rendition="#s">Chautauqua, N. Y.</del>
                                <add place="superlinear" hand="#unknown">
                                    <del rendition="#s" hand="#unknown">Gen Del.</del>
                                </add>
                            </subst>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.15.14.1">26 Vincent Ave.</placeName>
                            <add place="superlinear" hand="#unknown">Pasadena</add>
                        </addrLine>
                        <addrLine>U.S.A. <add place="sublinear" hand="#unknown">California</add>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <persName key="pers.4190">Dir. W</persName>/<persName key="pers.4349">Hb</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1934-09-08">8.
                            September 1934</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. 
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schoenberg</hi>
                            </persName>
                            ,</addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.15.14.1">26 Vincent Ave.</placeName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Chautauqua, N. Y.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schoenberg</persName>!</salute>
                <p>Besten Dank für Ihre liebe <seg type="comment">
                        <orig>Karte</orig>
                        <note xml:id="nfr5_vzj_5xb" resp="#pkehrer">
                            <ref target="letter.24456">Arnold Schönberg an Universal-Edition,
                                zwischen 16. August und 8. September 1934 [erschlossen]</ref>
                        </note>
                    </seg>. <lb/>Herr <persName key="pers.3612">Stein</persName> teilte mir mit,
                    dass er Ihnen bereits <lb/>vor einigen Tagen die <seg type="comment">
                        <orig>beiden letzten Hefte der <lb/>„Fackel“</orig>
                        <note xml:id="ny5x_vjq_p5b">
                            <rs type="bibl" key="zotero-4528359-5YE6G9IY">Die Fackel 1934</rs> und
                                <rs type="bibl" key="zotero-4528359-L8N2B69Y">Die Fackel 1934a</rs>
                            (Exemplare aus dem Schönberg-Nachlass; BOOK
                            F9)</note>
                    </seg> eingesandt hat, sodass meine <ref target="letter.17613">Anfrage</ref> und
                    <lb/>Ihre Antwort überholt ist.</p>
                <closer>
                    <salute>Mit besten Wünschen für Sie und <lb/>die Ihren <lb/>
                        <seg rendition="#c">Ihr ergebener</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.4190">Hugo Winter</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
