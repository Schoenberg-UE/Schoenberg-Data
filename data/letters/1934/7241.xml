    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.38">HOTEL ANSONIA <lb/>
                        <placeName key="place.15.8.14">BROADWAY 73RD STR</placeName>
                        <lb/>NEW YORK CITY</stamp>
                </opener>
                <lb/>
                <salute>Verehrte Direktion der <orgName key="org.1">U. E.</orgName>
                </salute>
                <p>Ich habe das <orgName key="org.53">Deutschmeister Reg.</orgName> um <lb/>meinen
                        <seg type="comment">
                        <orig>Landsturm Urlaubschein</orig>
                        <note xml:id="nak1_jqg_j1c" resp="#pkehrer">Landsturmurlaubsschein, 5.
                            Dezember 1917 (<ref target="https://archive.schoenberg.at/resources/pages/view.php?search=basicyear%3A1917&amp;k=&amp;modal=&amp;display=thumbs&amp;order_by=relevance&amp;offset=0&amp;per_page=48&amp;archive=&amp;sort=DESC&amp;restypes=2&amp;recentdaylimit=&amp;foredit=&amp;noreload=true&amp;access=&amp;ref=6131">ASCI D6131</ref>)</note>
                    </seg> und <lb/>die <orgName key="org.94">Israel. Kultusgem.</orgName> um meinen <lb/>
                    <note place="left" hand="#unknown">
                        <hi rendition="#u">erl </hi>
                        <lb/>
                        <date when="1934-07">VII 34</date>
                    </note>
                    <seg type="comment">
                        <orig>Geburtsschein</orig>
                        <note xml:id="nvhm_yqg_j1c" resp="#pkehrer">Geburts-Zeugnis, 17. Juli 1934
                                (<ref target="https://archive.schoenberg.at/resources/pages/view.php?search=d6135&amp;k=&amp;modal=&amp;display=thumbs&amp;order_by=relevance&amp;offset=0&amp;per_page=48&amp;archive=&amp;sort=DESC&amp;restypes=1%2C2%2C5%2C6%2C7%2C8%2C9%2C12&amp;recentdaylimit=&amp;foredit=&amp;noreload=true&amp;access=&amp;ref=6135">ASCI D6135</ref>)</note>
                    </seg>
                    <seg type="comment">
                        <orig>gebeten</orig>
                        <note xml:id="npbw_t5g_j1c" resp="#pkehrer">
                            <ref target="document.2720">Arnold Schönberg an Israelitische
                                Kultusgemeinde Wien, 2. Juli 1934</ref>; Arnold Schönberg an die
                            Regimentskanzlei des ehem. K u. K Infanterieregiments Hoch und
                            Deutschmeister Nr. 4 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B027229">ASCC
                                2722</ref>)</note>
                    </seg>
                </p>
                <p>und ersucht die Bezahlung von Ihnen <lb/>zu verlangen. Bitte freundlichst das zu
                    <lb/>übernehmen und raschestens an mich <lb/>zu senden.</p>
                <closer rendition="#inline">
                    <salute>Besten Dank und herzl. Grüße <lb/>
                    </salute>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schoenberg</persName>
                    </signed>
                </closer>
                <note place="left" hand="#unknown">
                    <!-- steno -->
                    <hi rendition="#st">wir eben besucht haben</hi>
                </note>
                <pb n="2" xml:id="p.2"/>
                <note place="left"> am <date when="1934-07-02">20.7.</date>
                    <lb/>
                    <hi rendition="#u">verständigt</hi>
                </note>
            </div>
        </body>
