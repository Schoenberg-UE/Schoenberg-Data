    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4357">Bau</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1934-12-19">19.
                            Dezember 1934</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schoenberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.15.7.1.2">5860 Canyon Cove</placeName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Hollywood,
                            Californien</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir überreichen Ihnen gleichzeitig 1 Ehrenexem<g ref="#typoHyphen"/>
                    <lb break="no"/>plar der soeben erschienenen <seg type="comment">
                        <orig>Orchesterpartitur</orig>
                        <note xml:id="nlv4_xf1_y5b">
                            <bibl sameAs="werke.90">Alban Berg, Symphonische Stücke aus der Oper
                                Lulu: nach den Tragödien „Erdgeist“ und „Büchse der Pandora“ von
                                Frank Wedekind</bibl> (Exemplar aus dem Schönberg-Nachlass; PM/lg
                            2)</note>
                    </seg> von <lb/>
                    <persName key="pers.385">Alban Berg’s</persName> „<bibl sameAs="werke.90">Symphonische Stücke a. d. Oper Lulu</bibl>“ <g ref="#typoHyphen"/>
                    <lb break="no"/>und empfehlen uns</p>
                <closer rendition="#r">
                    <salute>mit vorzüglicher Hochachtung</salute>
                    <signed>B</signed>
                    <lb/>
                    <signed>
                        <persName key="pers.3065">R</persName>
                    </signed>
                    <signed>
                        <persName key="pers.1750">DK</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
