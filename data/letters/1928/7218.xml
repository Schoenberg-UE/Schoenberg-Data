    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.25">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>TEL.: WESTEND 22<supplied cert="high">66</supplied>
                    </stamp>
                    <address>
                        <addrLine>Roquebrune-Cap Martin</addrLine>
                        <addrLine>
                            <placeName key="place.4.6.1">Pavillon Sevigné</placeName>
                        </addrLine>
                        <addrLine>Frankreich</addrLine>
                    </address>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">WIEN,</hi> I.</addrLine>
                        <addrLine>Autriche</addrLine>
                    </address>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">meine Adresse! <lb/>Ich glaube ich werde hier längere Zeit
                        blei<g ref="#typoHyphen"/>
                    <lb break="no"/>ben. Wie gehts Ihnen <unclear reason="illegible" cert="high">und</unclear> Ihrer <rs type="person" key="pers.1539">Frau</rs>? Ich hoffe
                    <lb/>bald zu arbeiten. Es ist sehr ruhig hier, da <lb/>man die Bahn ja nicht
                    mehr rechnet. – Gerne <lb/>wüsste ich, was mit <persName key="pers.3281">Görgi</persName> worden ist. <lb/>Hoffentlich gelingen Ihre guten
                    Absichten. – <lb/>Ich habe hier trotz der Hitze schon einmal <lb/>Tennis
                    gespielt – Da ich aber am selben Tag viel <lb/>gegangen bin und gearbeitet habe,
                    war ich etwas <lb/>müde. –</p>
                <closer rendition="#inline">
                    <salute>Viele herzlichste Grüße. Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <rs type="person" key="pers.3263">Arnold Schönberg</rs>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1928-07-01">
                            <unclear reason="illegible" cert="low">1</unclear>/VII 28</date>
                    </dateline>
                    <lb/>
                    <salute hand="#pers.3279">Herzlichste Grüße <lb/>auch an Ihre l. <rs type="person" key="pers.1539">Frau</rs> u Frl. <persName key="pers.1607">Hofer</persName>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3297">Gertrud Schönberg</persName>. </signed>
                </closer>
                <pb n="2" xml:id="p.2"/>
                <figure>
                    <p>269 BAIE DE <placeName key="place.4.6">ROQUEBRUNE</placeName>
                        <lb/>ET PRINCIPAUTÉ DE MONACO. RM</p>
                </figure>
            </div>
        </body>
    </text>
