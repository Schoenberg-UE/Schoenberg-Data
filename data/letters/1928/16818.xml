    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.54">
                        <orgName key="org.191">PULT UND TAKTSTOCK</orgName>
                        <lb/>MONATSSCHRIFT FÜR DIRIGENTEN<lb/>Verlag der <orgName key="org.1">Universal-Edition</orgName>
                        <lb/>WIEN, <seg hand="#author">
                            <date when="1928-11-28">28. November 1928</date>.</seg>
                        <lb/>I. <placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                    </stamp>
                    <lb/>
                    <persName key="pers.3067">R.</persName>/<persName key="pers.4351">Fi.</persName>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.4.6">Roquebrune-Cap Martin</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Ihrem Wunsche gemäß retournieren <lb/>wir Ihnen beigeschlossen Ihren Artikel <hi rendition="#u">
                        <seg type="comment">
                            <orig>
                                <bibl sameAs="schriften.45">INTERVIEW</bibl>
                            </orig>
                            <note sameAs="letter.1505/#nrt4_4yp_pzb"/>
                        </seg>
                    </hi>
                    <lb/>und empfehlen uns</p>
                <closer>
                    <salute rendition="#r">mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.148" rendition="#r">
                        <orgName key="org.191">Pult und Taktstock</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">
                        <unclear reason="illegible" cert="high">
                            <persName key="pers.3067">Rothe</persName>
                        </unclear>
                    </signed>
                </closer>
                <note hand="#unknown" place="mBottom">Bitte mir diesen Brief</note>
                <pb n="2" xml:id="p.2"/>
                <note hand="#unknown" place="left">
                    <hi rendition="#uu">Pass!</hi>
                    <lb/>
                    <hi rendition="#uu">
                        <bibl sameAs="werke.62">Suite</bibl>
               partitur!</hi>
                    <!-- siehe dazu letter.1609 -->
                    <lb/>Steuerkarte<lb/>
                    <bibl sameAs="schriften.13">Aron</bibl>
                </note>
                <lb/>
                <note hand="#addressee" place="right">
                    <seg rendition="#r">22 : 5 ~ 4.4
                        <lb/>
                        <hi rendition="#o">17.4</hi>
                    </seg>
                </note>
            </div>
        </body>
    </text>
