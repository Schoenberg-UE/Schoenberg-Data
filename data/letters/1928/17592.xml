    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.130">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/> I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>.
                        <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition, Wien. A. B. C. Code
                            5<hi rendition="#sup">th</hi> Ed. Mosse Code.<lb/>Telefon N<hi rendition="#sup #uu">o</hi>.57-5-85 Serie. Bank-Konto: <orgName key="org.199">Zentral-Europä-<lb/>ische Länderbank Wien</orgName>.
                        Postsparkassen-Kto. 57557.<lb/>Wien<seg hand="#author">, am <date when="1928-04-03">3. April 1928</date>
                        </seg>
                    </stamp>
                    <persName key="pers.3065">Dr. R</persName>/<persName key="pers.4379">Pz.</persName>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold
                                SCHÖNBERG</persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Westend</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter <rs type="person" key="pers.3263">Meister</rs>!</salute>
                <p>Nachdem nun das <orgName key="org.3">Kolisch-Quartett</orgName> nach <placeName key="place.9.11">Wien</placeName> zurück<g ref="#typoHyphen"/>
                    <lb break="no"/>gekehrt ist und die von ihm benützten <seg type="comment">
                        <orig>Stimmen</orig>
                        <note sameAs="letter.1319/#ns4g_2zb_3zb"/>
                    </seg> Ihres <bibl sameAs="werke.63">Streich<g ref="#typoHyphen"/>
                        <lb break="no"/>quartetts op. 30</bibl> verfügbar sind, beabsichtigen wir
                    schon in den <lb/>nächsten Tagen den Stich dieser Stimmen in Angriff zu nehmen.
                    <lb/>Wir haben heute mit Herrn <persName key="pers.1947">Kolisch</persName> über
                    die technische Einrich<g ref="#typoHyphen"/>
                    <lb break="no"/>tung der Stimmen gesprochen und er teilte uns mit, dass die in
                    <lb/>seinem Besitz befindlichen Stimmen von Ihnen als Stichvorlage <lb/>noch
                    nicht gutgeheissen seien. Wir bitten Sie daher um gefälli<g ref="#typoHyphen"/>
                    <lb break="no"/>ge Mitteilung, ob Sie die Zusendung dieser Stimmen wünschen,
                    <lb/>um für den Stich etwaige Anweisungen dazu geben zu können, ins<g ref="#typoHyphen"/>
                    <lb break="no"/>besondere was die Stichnoten anlangt, oder ob Ihnen diese Stim<g ref="#typoHyphen"/>
                    <lb break="no"/>men soweit in Erinnerung sind, dass Sie sie als Stichvorlage
                    <lb/>gutheissen können, ohne sie vorher noch einmal durchgesehen zu <lb/>haben.
                    Wir bitten Sie, <del rendition="#s">auch</del> uns auch alle ihre sonstigen
                        Wün<g ref="#typoHyphen"/>
                    <lb break="no"/>sche in Bezug auf den Stich der Stimmen mitzuteilen und zeich<g ref="#typoHyphen"/>
                    <lb break="no"/>nen, in Erwartung Ihrer gefl. Nachrichten, </p>
                <closer>
                    <salute rendition="#c">in vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.128" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>.
                    </stamp>
                    <lb/>
                    <signed rendition="#r">D<hi rendition="#sup">r</hi>
                        <persName key="pers.3065">Roth</persName>
                    </signed>
                </closer>
                <note hand="#unknown" place="mBottom">6/4</note>
            </div>
        </body>
    </text>
