    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.25">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/> CHARLOTTENBURG 9<lb/>
                        <placeName key="place.2.3.1.8">NUSSBAUM-ALLEE 17</placeName>
                        <lb/>TEL.: WESTEND 2266</stamp>
                    <address>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>P. T. <orgName key="org.1">UE.</orgName>,</salute>
                <p rendition="#inline">da mir die <orgName key="org.126">Postsparkasse</orgName>
                    heute <lb/>meine Schecks „<hi rendition="#u">Keine Deckung</hi>“ zurückschickt,
                    <lb/>bitte ich um eine <hi rendition="#u">verlässliche</hi> Mitteilung, wann
                    <lb/>die <orgName key="org.199">Länderbank</orgName> die 500 Mark für mich ein<g ref="#typoHyphen"/>
                    <lb break="no"/>gezahlt hat, da ich energisch Beschwerde <lb/>einlegen will
                    –</p>
                <closer rendition="#inline">
                    <salute>hochachtungsvoll</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1928-05-02">
                            <subst>
                                <del rendition="#ow">1</del>
                                <add place="across">2</add>
                            </subst>.V.1928</date>
                    </dateline>
                </closer>
                <note hand="#addressee" place="mBottom">
                    <date when="1928-04-25">25.IV</date> L <!-- steno --><hi rendition="#st">durchgeführt <lb/>ret gekommen</hi>
                    <lb/>
                    <date when="1928-04-28">28.IV</date>
                    <!-- steno -->
                    <hi rendition="#st">
                        <orgName key="org.199">Länderbank</orgName>
                        Überweisung</hi>
                </note>
                <note hand="#addressee" place="mBottom">840.–</note>
            </div>
        </body>
