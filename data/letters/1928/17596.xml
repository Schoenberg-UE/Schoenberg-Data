    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.122">
                        <orgName key="org.1">UNIVERSAL-EDITION A.
                  G.</orgName>
                        <lb/>WIEN, I. <placeName key="place.9.11.6.12">KARLSPLATZ
                     6</placeName> (Musikvereinsgebäude)</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schönberg</persName>,</addrLine>
                        <addrLine>Berlin-Charlottenburg 9</addrLine>
                        <addrLine>
                            <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>
                        </addrLine>
                        <addrLine>Deutschland</addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1928-05-24">24.
                            Mai 1928</date>.</dateline>
                    <persName key="pers.4349">Hb</persName>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Berlin-Charlottenburg 9</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Als Gegenwert der <date when="1928-08">August</date>-Rate per <lb/>R.M. 500.–
               überwiesen wir Ihnen heute auf Ihr <orgName key="org.126">Post<g ref="#typoHyphen"/>
                        <lb break="no"/>sparkassenkonto</orgName> den Betrag von .....<hi rendition="#u">S. 840.–</hi>, dessen <lb/>Empfang Sie uns gelegentlich gefl.
               bestätigen wollen.</p>
                <closer>
                    <salute>Wir empfehlen uns mit dem <lb/>Ausdrucke <lb/>
                        <seg rendition="#r">vorzüglichster Hochachtung</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.90" rendition="#r">„<orgName key="org.1">Universal Edition
                  Actiengesellschaft</orgName>“</stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.4190">Winter</persName>
                    </signed>
                </closer>
                <note hand="#unknown" place="left">W</note>
            </div>
        </body>
    </text>
