    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <hi rendition="#g">CARTE POSTALE</hi>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Roquebrune Cap Martin</addrLine>
                        <addrLine>
                            <placeName key="place.4.6.1">Pavillon Sévigné</placeName>
                        </addrLine>
                        <addrLine>Frankreich</addrLine>
                    </address>
                    <address>
                        <addrLine>An die</addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">I. Karlsplatz 6</placeName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">Wien</hi>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">VIENNE</hi>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>PT <orgName key="org.1">UE</orgName>,</salute>
                <p rendition="#inline">bitte senden Sie mir gefälligst umgehend:</p>
                <list>
                    <item>1. meine <seg type="comment">
                            <orig>Partitur</orig>
                            <note sameAs="letter.1495/#nn32_v4k_nzb"/>
                        </seg> der <bibl sameAs="werke.64">Orchester Variationen</bibl> und <lb/>womöglich<choice>
                            <sic>es</sic>
                            <corr type="deleted"/>
                        </choice> ein zweites gestochenes oder photogra<g ref="#typoHyphen"/>
                        <lb break="no"/>fiertes Exemplar davon;</item>
                    <item>2. <seg type="comment">
                            <orig>Kritiken</orig>
                        <note xml:id="nyvf_htl_pdc" resp="#pkehrer">Rezension aus dem Schönberg-Nachlass: <ref target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=12661&amp;action=view&amp;sortieren=lastChanged%20DESC&amp;vonBis=0-19">Strobel, Dezember 1928</ref></note>
                        </seg> der <placeName key="place.2.3">Berliner</placeName>
                        <seg type="comment">
                            <orig>Aufführung</orig>
                            <note xml:id="nws4_322_ndc" resp="#pkehrer"><ref target="event.118"/>; <ref target="event.119"/>
                            </note>
                        </seg>;</item>
                    <item>3. Das Datum der <placeName key="place.9.11">Wiener</placeName>
                        <bibl sameAs="werke.16">Gurrelieder</bibl>-<seg type="comment">
                            <orig>Aufführung</orig>
                            <note xml:id="neqg_4r5_qdc" resp="#pkehrer">
                                <ref target="event.124"/>
                            </note>
                        </seg> durch <lb/>
                        <persName key="pers.1901">Klenau</persName>, welche durchs Radio übertragen
                        wird.</item>
                </list>
                <p>Ich hoffe, dass die <seg type="comment">
                        <orig>
                            <bibl sameAs="werke.62">Suite</bibl>
                        </orig>
                        <note sameAs="letter.17792/#nidl_fqr_pzb"/>
                    </seg> inzwische<supplied cert="high">n</supplied> unterwegs ist.</p>
                <closer>
                    <salute>I<supplied cert="high">ch</supplied> empfehle mich, mit vorzüglicher
                        Hochachtung, <lb/>ergebenst</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>Obwohl es auch mir schadet, freut es mich, dass Sie <lb/>an der <seg type="comment">
                            <orig>Kritik</orig>
                            <note xml:id="nnhk_4py_pzb" resp="#pkehrer">
                                <rs type="bibl" key="zotero-4528359-3FL7VBGU">Einstein
                                1928</rs>
                            </note>
                        </seg> des <persName key="pers.950">Einstein</persName> sehen können, wie
                        gut es <lb/>für Sie gewesen wäre, meinen <bibl sameAs="schriften.45">Artikel</bibl> auch teuer zu <lb/>erwerben!</p>
                </postscript>
                <dateline rendition="#l">
                    <date when="1928-12-06">6/XII.1928</date>
                </dateline>
                <postscript>
                    <p>Bitte mir, zu <hi rendition="#u">Lasten meines Kontos</hi> ein
                        <lb/>„Ehrenexemplar“ von <persName key="pers.2053">Kreneks</persName>
                        <seg type="comment">
                            <orig>Drei Einaktern</orig>
                            <note xml:id="ng2s_jlt_qzb" resp="#pkehrer">
                                <bibl sameAs="werke.101">Ernst Krenek, Der Diktator op. 49</bibl>;
                                    <bibl sameAs="werke.102">Das geheime Königreich op. 50</bibl>;
                                    <bibl sameAs="werke.103">Schwergewicht oder Die
                                    Ehre der Nation op. 55</bibl> (Exemplare aus dem
                                Schönberg-Nachlass; PM/med 9; PM/med 10)</note>
                        </seg>
                        <lb/>und dessen <seg type="comment">
                            <orig>
                                <bibl sameAs="werke.104">Potpourri</bibl>-Partitur</orig>
                            <note xml:id="nr43_5h5_qdc" resp="#pkehrer">Exemplar aus dem
                                Schönberg-Nachlass (PM/med 10)</note>
                        </seg> zusenden</p>
                </postscript>
            </div>
        </body>
    </text>
