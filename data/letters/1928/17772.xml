    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <div type="writingSession" n="1" hand="#author">
                    <opener>
                        <stamp sameAs="stamp.122">
                            <orgName key="org.1">UNIVERSAL-EDITION
                                A.-G.</orgName>
                            <lb/>WIEN, I. <placeName key="place.9.11.6.12">KARLSPLATZ
                                6</placeName> (Musikvereinsgebäude)</stamp>
                        <address>
                            <addrLine>Herrn</addrLine>
                            <addrLine>Professor <persName key="pers.3263">Arnold Schönberg</persName>
                            </addrLine>
                            <addrLine>Roquebrune-Cap Martin</addrLine>
                            <addrLine>
                                <placeName key="place.4.6.1">Pavillon Sevigné</placeName>
                            </addrLine>
                            <addrLine>Frankreich</addrLine>
                        </address>
                    </opener>
                    <pb n="2" xml:id="p.2"/>
                    <opener>
                        <persName key="pers.1740">Ks.</persName>
                        <dateline>
                            <placeName key="place.9.11">Wien</placeName>, <date when="1928-07-21">21.
                                Juli 1928</date>.</dateline>
                        <address>
                            <addrLine>
                                <hi rendition="#uda">Herrn Professor <persName key="pers.3263">Arnold
                                    Schönberg</persName>, <placeName key="place.4.6">Roquebrune</placeName>
                                </hi>.</addrLine>
                        </address>
                    </opener>
                    <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                    <p>Wir überwiesen Ihnen heute auf Ihr <lb/>
                        <placeName key="place.9.11">Wiener</placeName>
                        <orgName key="org.126">Postsparkassen</orgName>-Konto den Betrag von <lb/>S
                        840.– als Gegenwert von M 500.– dessen Er<g ref="#typoHyphen"/>
                        <lb break="no"/>halt Sie uns gefl. gelegentlich bestätigen <lb/>wollen.</p>
                    <closer>
                        <salute rendition="#r">Mit vorzüglicher Hochachtung</salute>
                        <lb/>
                        <stamp sameAs="stamp.46" rendition="#r">
                            <orgName key="org.1">Universal-Edition
                                Actiengesellschaft</orgName>
                        </stamp>
                        <lb/>
                        <signed rendition="#r">pp <persName key="pers.4190">Winter</persName>
                        </signed>
                    </closer>
                </div>
                <div type="writingSession" n="2" hand="#pers.4190">
                    <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                    <p>Das letz<supplied cert="high">t</supplied>e Heft der „Fackel“ und
                        <lb/>
                        <persName key="pers.2031">K. Kraus</persName> „<bibl sameAs="schriften.92">Die Unüberwindlichen</bibl>“ <!-- kein Exemplar im Schönberg-Nachlass --><lb/>erliegt bei mir
                        zu Ihrer Verfügung. <lb/>Soll ich beides nach <placeName key="place.4.6">Roquebrune</placeName> senden?</p>
                    <closer rendition="#r">
                        <salute>Ergebenst</salute>
                        <signed>
                            <persName key="pers.4190">Winter</persName>
                        </signed>
                    </closer>
                </div>
            </div>
        </body>
    </text>
