    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.25">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/> CHARLOTTENBURG 9<lb/>
                        <placeName key="place.2.3.1.8">NUSSBAUM-ALLEE 17</placeName>
                        <lb/>TEL.: WESTEND 2266</stamp>
                    <note place="mTop" hand="#unknown">Roquebrune Cap Martin <lb/>
                        <placeName key="place.4.6.1">Pavillon Sévigné</placeName>
                    </note>
                    <note place="mTop" hand="#unknown">
                        <del rendition="#s">Charlbrg</del> 9 <lb/>
                        <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>
                    </note>
                </opener>
                <salute>P. T. <orgName key="org.1">UE.</orgName>,</salute>
                <p rendition="#inline">ich habe keine Nachricht, ob von Ihnen schon, die 500 M.
                    <lb/>auf mein <orgName key="org.126">Postsparkassen Konto</orgName> angezahlt
                    sind.</p>
                <p>Wenn nicht, so bitte ich es telegrafisch zu tun, da sonst die <lb/>Scheks die ich
                    heute absende an mich zurückgehen.</p>
                <closer>
                    <note place="mBottom" hand="#addressee">
                        <date when="1928-10-29">29/X/28</date>
                    </note>
                    <salute rendition="#r">hochachtungsvoll</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <note place="right" hand="#addressee">
                    <date when="1928-10-23">23.X</date> 840 S <lb/>
                    <!-- steno -->
                    <hi rendition="#st">auf sein <placeName key="place.9.11">W.</placeName> Post Konto eingezahlt</hi>
                </note>
            </div>
        </body>
    </text>
