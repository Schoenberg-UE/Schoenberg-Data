    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.31">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/> I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>·
                        <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition, Wien. A. B. C. Code
                            5<hi rendition="#sup">th.</hi> Ed. Mosse Code.<lb/>Telefon U-47-5-85
                        Serie. Bank-Konto: <orgName key="org.199">Zentral-Europä-<lb/>ische
                            Länderbank Wien</orgName>. Postsparkassen-Kto. 57557.<lb/>Wien<seg hand="#author">, <date when="1928-12-14">14. Dezember 1928</date>.</seg>
                    </stamp>
                    <lb/>
                    <persName key="pers.3067">R</persName>/<persName key="pers.4362">M.</persName>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.4.6">Roquebrune Cap Martin</placeName>.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Auf Ihre vorgestern eingelangte <ref target="letter.7221">Karte</ref> erlauben
                    wir <lb/>uns mitzuteilen, dass</p>
                <list>
                    <item>1. die <seg type="comment">
                            <orig>Partitur</orig>
                            <note sameAs="letter.1495/#nn32_v4k_nzb"/>
                        </seg> der „<hi rendition="#u">
                            <bibl sameAs="werke.64">Orchester-Variationen</bibl>
                        </hi>“ sich <lb/>in zweiter Korrektur befindet
                        <!-- zweiter korrekturgang laut letter.1713 ab 19.12.1928 -->und wir Ihnen
                        daher kein ge<g ref="#typoHyphen"/>
                        <lb break="no"/>stochenes Exemplar zusenden können; die <seg type="comment"
                                ><orig>fotografischen Abzüge</orig><note xml:id="nixr_wxl_pdc"
                                resp="#pkehrer">Neben der Stichvorlage (<ref
                                    target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=636&amp;werke_id=230&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                    >ASGA B 13, Quelle Cb</ref>) und der Negativkopie der
                                Partiturreinschrift (<ref
                                    target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=635&amp;werke_id=230&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                    >ASGA B 13, Quelle Ca</ref>) war mindestens eine weitere
                                Fotographie im Umlauf, auf deren Basis sich <persName
                                    key="pers.1167">Wilhelm Furtwängler</persName> auf die
                                Uraufführung vorbereitet hatte (Felix Greissle an Arnold Schönberg,
                                Oktober 1928; <ref
                                    target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B116590"
                                    >ASCC 11659</ref>)</note></seg>
                        <lb/>sind augenblicklich in <placeName key="place.2.3">Berlin</placeName>
                        und wir besitzen hier <add place="intralinear">k</add>ein<add
                            place="intralinear">en</add> einzigen.</item>
                    <item>2. <seg type="comment">
                            <orig>Kritiken</orig>
                            <note xml:id="ndmh_t5l_pdc" resp="#pkehrer">Anzahl und Titel unbekannt; Rezensionen aus dem
                                Schönberg-Nachlass: <ref target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=12661&amp;action=view&amp;sortieren=lastChanged%20DESC&amp;vonBis=0-19">Strobel, Dezember 1928</ref>; <ref target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=12665&amp;action=view&amp;sortieren=&amp;vonBis=0-9998">R. K., Dezember 1928</ref>; <ref target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=12664&amp;action=view&amp;sortieren=&amp;vonBis=0-9998">Anonym, Dezember 1928</ref>; <ref target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=12663&amp;action=view&amp;sortieren=&amp;vonBis=0-9998">Marschalk, 4. Dezember 1928</ref>. Weitere: <rs type="bibl" key="zotero-4528359-JXU5L2LK">Schorr 1928</rs>; <rs type="bibl" key="zotero-4528359-5AVNWGPH">Dresdner Neueste Nachrichten
                                    1928b</rs>; <rs type="bibl">
                                    <rs type="bibl" key="zotero-4528359-LR6MYZGR">Dresdner Nachrichten
                                    1928</rs>
                                </rs>; <rs type="bibl" key="zotero-4528359-CFLY6IYU">Huth 1928</rs>; <rs type="bibl" key="zotero-4528359-23Z6BUA8">Schrenk 1928</rs>; <rs type="bibl" key="zotero-4528359-6ATBNHS7">Pringsheim 1928</rs>
                            </note>
                        </seg>
                        der <placeName key="place.2.3">Berliner</placeName>
                        <seg type="comment">
                            <orig>Aufführung</orig>
                            <note xml:id="nblp_rwl_pdc" resp="#pkehrer"><ref target="event.118"/>; <ref target="event.119"/>
                            </note>
                        </seg> gehen Ihnen <lb/>gleichzeitig zu.</item>
                    <item>3. Die <placeName key="place.9.11">Wiener</placeName>
                        <choice>
                            <sic>-</sic>
                            <corr> </corr>
                        </choice>
                        <bibl sameAs="werke.16">Gurrelieder</bibl>-<seg type="comment">
                            <orig>Aufführung</orig>
                            <note xml:id="nifq_yr5_qdc" resp="#pkehrer">
                                <ref target="event.124"/>
                            </note>
                        </seg>
                        <seg type="comment">
                            <orig>findet am <lb/>
                                <date when="1928-01-19">19. Jänner</date> statt</orig>
                            <note xml:id="nppf_3s5_qdc" resp="#pkehrer">In <persName key="pers.3263"
                                    >Schönbergs</persName> Kalender ist die Aufführung sowohl an
                                diesem falschen (<ref
                                    target="https://archive.schoenberg.at/resources/pages/view.php?ref=12800"
                                    >ASCI DC12800</ref>), wie auch am korrekten Datum, dem 18.
                                Jänner 1929 (<ref
                                    target="https://archive.schoenberg.at/resources/pages/view.php?ref=12799"
                                    >ASCI DC12799</ref>), eingetragen</note>
                        </seg>.</item>
                    <item>4. Die <seg type="comment">
                            <orig>
                                <bibl sameAs="werke.62">Suite</bibl>
                            </orig>
                            <note sameAs="letter.17792/#nidl_fqr_pzb"/>
                        </seg> wurde Ihnen am <date when="1928-12-05">5. ds.</date>
                        zugesandt.</item>
                </list>
                <closer>
                    <salute rendition="#r">In vorzüglicher Hochschätzung ergebenst</salute>
                    <lb/>
                    <stamp sameAs="stamp.156" rendition="#r">
                        <orgName key="org.1">UNIVERSAL-EDITION<lb/>AKTIENGESELLSCHAFT</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>P.S. Ihrem Wunsche gemäss lassen <lb/>wir Ihnen die <seg type="comment">
                            <orig>Klavierauszüge</orig>
                            <note sameAs="letter.7221/#ng2s_jlt_qzb"/>
                        </seg> von den <lb/>
                        <persName key="pers.2053">KRENEK</persName>-Einaktern als Ehrenexemplar,
                        <lb/>dagegen die <seg type="comment">
                            <orig>Partitur</orig>
                            <note sameAs="letter.7221/#nr43_5h5_qdc"/>
                        </seg> des „<bibl sameAs="werke.104">Potpourris</bibl>“ <lb/>leihweise zugehen.</p>
                </postscript>
            </div>
        </body>
    </text>
