    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">ARNOLD SCHONBERG</persName>
                        </addrLine>
                        <addrLine>ROQUEBRUNE – CAP MARTIN</addrLine>
                        <addrLine>
                            <placeName key="place.4.6.1">PAVILLON
                            SEVIGNE</placeName>
                        </addrLine>
                    </address>
                    <dateline>
                        <date when="1928-11-13">13.XI.1928</date>
                    </dateline>
                </opener>
                <salute>An die Redaktion von <orgName key="org.191">Pult und
                    Taktstock</orgName>
                </salute>
                <p>da ich die mir gestellten Bedingunge<choice>
                        <sic>e</sic>
                        <corr type="deleted"/>
                    </choice>n <lb/>bezüglich meines, Ihnen am <date when="1928-10-06">6.X.</date>
                    <ref target="letter.1505">gesandten</ref>
                    <bibl sameAs="schriften.45">Artikels</bibl> nicht <lb/>annehme, bitte ich um
                    gefällige sofortige Retournierung <lb/>des <seg type="comment">
                        <orig>Manuskriptes</orig>
                        <note sameAs="letter.1505/#nrt4_4yp_pzb"/>
                    </seg> und bitte zur Kenntnis zu nehmen, dass <lb/>ich die Veröffentlichung
                    verbiete.</p>
                <closer>
                    <salute>Hochachtungsvoll</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold
                        Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
