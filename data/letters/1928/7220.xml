    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <note hand="#unknown" place="mTop">
                    <gap reason="illegible" unit="chars" quantity="1"/>
                </note>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Roquebrune Cap Martin</addrLine>
                        <addrLine>
                            <placeName key="place.4.6.1">Pavillon Sévigné</placeName>
                        </addrLine>
                        <addrLine>Frankreich</addrLine>
                    </address>
                    <dateline>
                        <date when="1928-11-25">25.XI.1928</date>
                    </dateline>
                </opener>
                <salute>Liebe<supplied cert="high">r</supplied> Herr Direktor <persName key="pers.1538">Herzka</persName>,</salute>
                <p rendition="#inline">Sie haben ganz Recht: es ist <lb/>gewiss besser mündlich in
                        <placeName key="place.2.3">Berlin</placeName> über diese Frage zu spre<g ref="#typoHyphen"/>
                    <lb break="no"/>chen. Insbesondere deshalb, weil sie ja nun augenblicklich
                    <lb/>doch ganz unaktuell ist. Ich bin nämlich aus Leibeskräften <lb/>bemüht,
                    mein „<bibl sameAs="schriften.14">Drama</bibl>“ noch vor meiner Rückkehr nach
                        <placeName key="place.2.3">Ber<g ref="#typoHyphen"/>
                        <lb break="no"/>lin</placeName> in einen derartigen Zustand zu bringen dass
                    eine <lb/>Aufführung, wenn nicht noch heuer, so doch nächstes Jahr
                    <lb/>stattfinden kann und komme leider, trotz grösster Energie <lb/>nur langsam
                    vorwärts. Deswegen könnte ich mich mit anderen <lb/>Zukunftsplänen derzeit gar nicht befassen.</p>
                <closer>
                    <salute>Ich hoffe<choice>
                            <sic>;</sic>
                            <corr cert="high">,</corr>
                        </choice> sie also in <placeName key="place.2.3">Be<supplied cert="high">r</supplied>lin</placeName> aus<choice>
                            <sic>d</sic>
                            <corr cert="high">f</corr>
                        </choice>ührlich zu sprechen und <lb/>grüsse Sie herzlichst, Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold
                  Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
