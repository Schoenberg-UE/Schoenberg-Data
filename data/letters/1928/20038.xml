    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4358">W.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1928-01-27">27.
                            Januar 1928</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Charlottenburg.</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.2">Kantstrasse 4</placeName>/IV.</addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir teilen Ihnen höflichst mit, <lb/>dass der Vertrag über „<hi rendition="#u">
                        <bibl sameAs="werke.50">Glückliche Hand</bibl>
                    </hi>“ <lb/>mit dem <seg type="comment">
                        <orig>
                            <orgName key="org.256">Stadttheater</orgName> in <placeName key="place.2.6">Breslau</placeName>
                        </orig>
                        <note xml:id="nlbk_g2s_w2c" resp="#KBleier">
                            <ref target="event.157"/>
                        </note>
                    </seg> nunmehr <lb/>perfekt ist
                    und zeichnen</p>
                <closer rendition="#inline">
                    <salute rendition="#r">mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
