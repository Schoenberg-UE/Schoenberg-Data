    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.1520">Hei</persName>/<persName key="pers.4342">Wi.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1928-03-09">9.
                            März 1928</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Westend,</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee Nr.
                            17</placeName>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p> Wir bestätigen mit ganz besonderem Dank <lb/>Ihre <ref target="letter.7215"
                        >Zeilen</ref> vom <date when="1928-03-07">7. März</date> mit Ihrem <bibl
                        sameAs="schriften.64">Beitrag</bibl> zu <lb/>
                    <persName key="pers.3301">
                        <hi rendition="#g">Schreker’s</hi>
                    </persName> Geburtstag für das <seg type="comment">
                        <orig>Schreker-<lb break="no"/>Heft</orig>
                        <note xml:id="nwqy_h4w_mzb" resp="#pkehrer">
                            <rs type="bibl" key="zotero-4528359-3BVJVASZ">Anbruch 1928</rs>
                            (Exemplar aus dem Schönberg-Nachlass; <ref
                                target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=2651&amp;action=view&amp;sortieren=veroeffentlichungsDatum&amp;vonBis=220-239"
                                >P12</ref>)</note></seg> des „<orgName key="org.7">Anbruch</orgName>“. </p>
                <closer>
                    <salute>Mit ergebenster Empfehlung <lb/>
                        <seg rendition="#r">in vorzüglicher
                     Hochachtung</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
