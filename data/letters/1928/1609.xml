    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Roquebrune Cap Martin</addrLine>
                        <addrLine>
                            <placeName key="place.4.6.1">Pavillon Sévigné</placeName>
                        </addrLine>
                    </address>
                    <dateline>
                        <date when="1928-12-01">1.12.28</date>
                    </dateline>
                    <address>
                        <addrLine>An die</addrLine>
                        <addrLine rendition="#c">
                            <seg type="row">
                                <seg type="column">
                                    <orgName key="org.1">Universal Edition</orgName>
                                </seg>
                                <seg type="column">
                                    <seg rendition="#l">Wien I <lb/>
                                        <placeName key="place.9.11.6.12">Karlsplatz
                                 6</placeName>
                                    </seg>
                                </seg>
                            </seg>
                        </addrLine>
                    </address>
                </opener>
                <p>
                    <note hand="#addressee" place="left">ges. <date when="1928-12-05">5.XII.-28</date>
                    </note>Bitte vielmals mir postwendend eine Partitur meiner
                  <lb/>
                    <bibl sameAs="werke.62">Suite</bibl>
                    <add place="sublinear">für 3 Streicher 3 Bläser und Klavier</add> zu senden, da ich
               diese in <placeName key="place.2.10">Dresden</placeName>
                    <seg type="comment">
                        <orig>dirigieren</orig>
                        <note xml:id="np5j_rnr_pzb" resp="#pkehrer">
                            <p>
                                <ref target="event.45"/>
                            </p>
                            <p>Die Aufführung wurde von <persName key="pers.2082">Hermann
                                    Kutzschbach</persName> geleitet, da <persName key="pers.3263"
                                    >Schönberg</persName> sein Dirigat absagte. Als Gründe führte er
                                seinen abgelaufenen Pass und Zeitknappheit an, wobei insbesondere
                                letztere – bedingt durch intensive Arbeit an <bibl sameAs="werke.65"
                                    >Von heute auf morgen op. 32</bibl> – entscheidend gewesen sein
                                dürfte (Arnold Schönberg an Paul Aron, 3. Dezember 1928; <ref
                                    target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B016116"
                                    >ASCC 1611</ref>)</p>
                        </note>
                    </seg> soll.</p>
                <closer>
                    <salute rendition="#c">Hochachtungsvoll</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <note hand="#addressee">
                    <gap reason="illegible" unit="chars" quantity="1"/>
                </note>
            </div>
