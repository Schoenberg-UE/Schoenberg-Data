    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <note place="mTop" hand="#unknown">letters</note>
                <opener>
                    <stamp sameAs="stamp.47">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName>
                        <lb/>WIEN I·<placeName key="place.9.11.6.12">KARLSPLATZ
                        6</placeName>·MUSIKVEREINSGEBÄUDE·TELEFON U 47-5-85<lb/>TELEGRAMME:
                        MUSIKEDITION WIEN</stamp>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1949-07-06">6.
                            Juli 1949</date>.</dateline>
                    <seg rendition="#r">
                        <persName key="pers.1485">Ha</persName>/<persName key="pers.4370">Oe.</persName>
                    </seg>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 N. Rockingham
                            Ave.</placeName>,</addrLine>
                        <addrLine>
                            <hi rendition="#u">
                                <hi rendition="#g">Los Angeles</hi> 24. Cal</hi>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir erlauben uns, Ihnen mit gleicher Post 10 <seg type="comment">
                        <orig>Exemplare</orig>
                        <note sameAs="letter.17754/#nf4h_rhv_ngc"/>
                    </seg>
                    <lb/>des neuen Verzeichnisses Ihrer Werke zu überreichen. Wir <lb/>freuen uns,
                    dass nun endlich wieder ein übersichtlicher <lb/>Katalog Ihrer in der <orgName key="org.1">Universal-Edition</orgName> erschienen und <lb/>von uns
                    vertretenen Werke vorhanden ist.</p>
                <closer>
                    <salute rendition="#r">Mit besten Empfehlungen <lb/>hochachtungsvoll</salute>
                    <lb/>
                    <seg rendition="#r">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName>
                    </seg>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1485">Hartmann.</persName>
                    </signed>
                    <lb/>
                    <hi rendition="#u">10 Prospekte</hi>
                </closer>
            </div>
        </body>
    </text>
