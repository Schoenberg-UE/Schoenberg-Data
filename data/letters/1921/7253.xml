    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.9">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg 6</placeName>.-Tel. 118.</stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Hertzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        </addrLine>
                        <addrLine>Musikvereinsgebäude</addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>L<supplied cert="high">ie</supplied>ber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">in Eile: in einigen <lb/>Tagen werde ich <seg type="comment">
                        <orig>Ihren Brief</orig>
                        <note xml:id="nzqx_fhh_fxb" resp="#jfranz">
                            <ref target="letter.24298">Universal-Edition an Arnold Schönberg, 16.
                                November 1921 [erschlossen]</ref>
                        </note>
                    </seg> ausführlich beant<g ref="#typoHyphen"/>
                    <lb break="no"/>worten. Jetzt bin ich zu sehr beschäftigt.</p>
                <closer rendition="#inline">
                    <salute>Viele <lb/>Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1921-11-24">24/XI.1921</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
