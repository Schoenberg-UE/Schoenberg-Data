    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.9">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Mödling bei Wien<lb/>
                        <placeName key="place.9.4.1">Bernhardg 6</placeName>.-Tel. 118.</stamp>
                    <dateline>
                        <date when="1921-05-13">13/V.1921</date>
                    </dateline>
                </opener>
                <salute>Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">bitte Herrn <persName key="pers.3640">Steinbauer</persName> –
                        Ueber<g ref="#typoHyphen"/>
                    <lb break="no"/>bringer dieses – ein Exemplar <bibl sameAs="werke.54"
                        >Pierrot</bibl>-Stimmen <lb/>für Rechnung des <orgName key="org.178">Ver. f.
                        P. A.</orgName> – also ermäßigt – <lb/>zu übergeben. Er studiert die <seg
                        type="comment">
                        <orig>2. Besetzung</orig>
                        <note xml:id="nx2v_jk3_yfc" resp="#KBleier">Im <orgName key="org.178">Verein
                                für musikalische Privataufführungen</orgName> fanden zwischen <date
                                when="1921-04-30">30. April </date>und <date when="1921-05-12">12.
                                Mai 1921 </date>vier Aufführungen von <bibl sameAs="werke.54"
                                >Pierrot lunaire op. 21</bibl> in der Besetzung <persName
                                key="pers.3689">Erika Wagner</persName>, <persName key="pers.3662"
                                    >Eduard Steuermann</persName>, <persName key="pers.3960">Franz Wangler</persName>,
                                <persName key="pers.2813">Viktor Polatschek</persName>, <persName
                                key="pers.1947">Rudolf Kolisch</persName>, <persName key="pers.4187"
                                >Wilhelm Winkler</persName> und <persName key="pers.3612">Erwin
                                Stein</persName> bzw. <persName key="pers.3263">Arnold
                                Schönberg</persName> statt. Ein undatiertes Protokoll dokumentiert
                            das Management des Ensembles durch den <orgName key="org.178"
                                >Verein</orgName> für künftige Aufführungen und verpflichtet die
                            Musiker:innen bis <date when="1922-06-30">30. Juni 1922</date> exklusiv
                            in genannter Besetzung an Aufführungen des Werk teilzunehmen. Der
                                <orgName key="org.178">Verein</orgName> verpflichtet sich zudem, die
                            Mitglieder einer namtlich nicht ausgeführten Ersatzbesetzung für
                            mindestens zwei je zehn Konzerten einzusetzen (<rs type="bibl"
                                key="zotero-4528359-N2TCC7T5">Szmolyan 1984</rs>, S. 108; Protokoll
                                <ref target="https://archive.schoenberg.at/resources/?r=5315">ASCI
                                VMP5315</ref>)</note>
                    </seg></p>
                <closer rendition="#inline">
                    <salute>Herzlichen <lb/>Gruß Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <lb/>
                <note place="left" hand="#unknown">Partitur <lb/>&amp; <hi rendition="#u">4
                        Stimmen</hi>
                </note>
                <note place="mBottom" hand="#addressee">Empfangen am <hi rendition="#u">
                        <date when="1921-05-19">19./V.</date>
                    </hi>
                    <lb/>
                    <unclear reason="illegible" cert="low">gz</unclear>
                    <persName key="pers.3640">Steinbauer</persName>
                </note>
                <note place="right" hand="#addressee">K 1000.–</note>
            </div>
