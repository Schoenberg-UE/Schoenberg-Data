    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1932-10-18">18.X.193<unclear reason="illegible" cert="high">3</unclear>
                        </date>
                    </dateline>
                    <address>
                        <addrLine>
                            <placeName key="place.4.4.3.1">Hotel Regina</placeName>
                        </addrLine>
                        <addrLine>Place des Pyramides</addrLine>
                    </address>
                </opener>
                <salute>Lieber D<hi rendition="#sup">r.</hi>
                    <persName key="pers.1750">Kallmus</persName>,</salute>
                <p rendition="#inline">ich bin immer um 1/2 10<hi rendition="#sup #uu">h</hi>
                    <lb/>zu Hause mindestens bis ½ 11.- Meistens auch um <lb/>1<hi rendition="#sup #uu">h</hi> und um 1/2 8<hi rendition="#sup #uu">h</hi>
                </p>
                <p>Ich möchte selbst von Ihnen gerne ehestens <lb/>einige Auskünfte empfangen und
                    bitte Sie daher <lb/>sobald als möglich zu kommen. Wenn Sie anrufen <lb/>kann
                    ich eventuell auch zu anderen Zeiten.</p>
                <closer>
                    <salute>Mit besten Grüßen Ihr</salute>
                    <lb/>
                    <signed rendition="#c">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <pb n="2" facs="2"/>
                <note place="mBottom" hand="#addressee">
                    <hi rendition="#u">
                        <gap reason="illegible" unit="chars" quantity="3"/>
                    </hi>
                    <lb/>
                    <hi rendition="#u">Opéra <unclear reason="illegible" cert="low">9</unclear>6-74</hi>
                    <lb/>
                    <placeName key="place.4.4.9.3">15 Rue de la Paix</placeName>
                </note>
            </div>
