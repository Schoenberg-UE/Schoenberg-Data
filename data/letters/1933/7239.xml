                        <addrLine>
                            <hi rendition="#uu">AUSTRIA</hi>
                        </addrLine>
                    </address>
                    <lb/>
                    <stamp sameAs="stamp.91">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                    </stamp>
                    <stamp sameAs="stamp.33">
                        <placeName key="place.15.15.1">1284, BEACON STREET</placeName>
                        <lb/>PELHAM HALL<lb/>BROOKLINE MASS</stamp>
                </opener>
                <salute>Liebes Fräulein <lb/>
                    <persName key="pers.3067">Rothe</persName>
                    <lb/>Lieber D<hi rendition="#sup #u">r</hi>
                    <persName key="pers.1750">Kalmus</persName>, Lieber Direktor <lb/>
                    <persName key="pers.4190">Winter</persName>, lieber D<hi rendition="#sup #u">r</hi>
                    <persName key="pers.1520">Heinsheimer</persName>
                    <lb/>und alle anderen, die mir noch <lb/>wohlgesinnt sind:</salute>
                <p>Hier meine neue Adresse <lb/>und viele herzlichste Grüße. <lb/>
                    <seg type="comment">
                        <orig>nächstens ein „Journal“</orig>
                        <note xml:id="nppr_zfs_31c" resp="#pkehrer">Diese Ankündigung erfüllte sich
                            erst ein Jahr später mit dem <bibl sameAs="schriften.106">Rundschreiben
                                an
                        Freunde</bibl>
                        </note></seg>
                </p>
                <closer>
                    <salute>Ihr</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.3263">Arnold Schoenberg</persName>
                    </signed>
                    <dateline>
                        <date when="1933-11-21">21/XI.1933</date>
                    </dateline>
                </closer>
