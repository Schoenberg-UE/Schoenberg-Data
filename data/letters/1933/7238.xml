    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <note place="mTop" hand="#pers.1750">
                    <persName key="pers.1750">D Kalm</persName>
                    <gap reason="illegible" unit="words" quantity="1"/> 7/19. 33</note>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schoenberg</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.110">Malkin Conservatory</orgName>
                        </addrLine>
                        <addrLine>Boston Massachusetts</addrLine>
                        <addrLine>
                            <placeName key="place.15.1.4">299 Beacon
                            Street</placeName>
                        </addrLine>
                    </address>
                    <dateline>
                        <placeName key="place.4.4">Paris</placeName>
                        <date when="1933-10-24">24.X.1933</date>
                    </dateline>
                </opener>
                <salute>Liebe <orgName key="org.1">U. E.</orgName>
                </salute>
                <p>An <orgName key="org.92">Hofmeister Leipzig</orgName> habe ich <lb/>verabredet
                    und D<hi rendition="#sup">r</hi>
                    <persName key="pers.1750">Kalmus</persName>
                    <subst>
                        <del rendition="#ow">5</del>
                        <add place="across">3</add>
                    </subst>00 Mark <lb/>bezahlen lassen und bitte Sie den <lb/>Gegenwert (bitte
                    nationalsozialistischen <lb/>Kurs anrechnen!) an meine Tochter <lb/>Frau
                        <persName key="pers.3284">Gertrud Greissle</persName>, <placeName key="place.9.4">Mödling</placeName>
                    <lb/>zu senden.</p>
                <closer>
                    <salute>Herzlichsten Dank und <lb/>Abschiedsgrüße Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
