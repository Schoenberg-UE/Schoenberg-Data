    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.82">
                        <orgName key="org.180">VERLAG<lb/>DREILILIEN</orgName>
                        <lb/>Halensee-Berlin<lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Strasse 22</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Wien</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.1.2">Liechtensteinstr
                            68/70</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieber Herr <persName key="pers.3263">Schönberg</persName> –</salute>
                <p>das Geld an <seg type="comment">
                        <orig>besagten sehr teuren <lb/>und unpraktischen Herrn <persName
                                key="pers.3906">Uher</persName>
                        </orig>
                        <note sameAs="letter.13002/#nvgb_qfz_z5b"/>
                    </seg> ist neu<g ref="#typoHyphen"/>
                    <lb break="no"/>lich abgeschickt worden. Man autographiert <lb/>nämlich die <seg
                        type="comment"><orig>Quartettstimmen</orig><note xml:id="nic2_g3x_x3c"
                            resp="#KBleier">Streicherstimmen zu <bibl sameAs="werke.5">Arnold
                                Schönberg, Pelleas und Meisande op. 5</bibl>
                        </note></seg>; das ist billiger <lb/>und man hat so viel Ex., wie man haben
                    <lb/>will und braucht bei weiterem Materialbedarf <lb/>nur die anderen Stimmen
                    abschreiben lassen! <lb/>Na., nun helpt dat nischt.</p>
                <closer rendition="#r">
                    <salute>Bestens Ihr </salute>
                    <signed>
                        <persName key="pers.2283">Max Marschalk</persName>
                    </signed>
                    <stamp sameAs="stamp.111" rendition="#l">
                        <lb/>Halensee-Berlin, den <date when="1904-10-19">
                            <seg hand="#author">19.10.04.</seg>
                        </date>
                        <lb/>
                        <placeName key="place.2.4.1.1">Georg
                            Wilhelm-Str. 22</placeName>.</stamp>
                </closer>
            </div>
        </body>
