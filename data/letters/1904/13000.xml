    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.82">
                        <orgName key="org.180">VERLAG<lb/>DREILILIEN</orgName>
                        <lb/>Halensee-Berlin<lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Strasse 22</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn <persName key="pers.3263">Arnold <lb/>Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <del rendition="#s" hand="#unknown">Wien</del>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.11.1.2">
                                <del rendition="#s" hand="#unknown">Liechtensteinstr 68/70</del>
                            </placeName>
                            <lb/>
                            <add place="sublinear" hand="#unknown"><seg type="comment"
                                        ><orig>Mödling, <placeName key="place.9.4.2">Brühlerstraße
                                            104</placeName></orig><note xml:id="ndrh_dhx_x3c"
                                        resp="#KBleier"><persName key="pers.3263"
                                            >Schönbergs</persName> Sommeraufenthalt, Adresse der
                                        Eltern <persName key="pers.272">David Josef
                                        Bachs</persName></note></seg>
                            </add>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieber Herr <persName key="pers.3263">Schönberg</persName>.</salute>
                <p rendition="#inline">Die <seg type="comment">
                        <orig>
                            <orgName key="org.144">Rosé</orgName>-<lb/>Stimmen</orig>
                        <note sameAs="letter.13002/#nins_fhb_myb"/>
                    </seg> habe ich erhalten. Um
                        Wendestel<g ref="#typoHyphen"/>
                    <lb break="no"/>len brauchen Sie nicht in
                    Sorge zu sein, das <lb/>machen die <seg type="comment">
                        <orig>Stecher</orig>
                        <note sameAs="letter.13002/#nwbs_1tm_c5b"/>
                    </seg> schon. Bin ich Ihnen
                    <lb/>noch Antworten schuldig? Was machen die <lb/>
                    <bibl sameAs="werke.11">Orchestergesänge</bibl>? Im Uebrigen kann ich <lb/>Ihnen die Geburt eines
                        <rs type="person" key="pers.2295">Sohnes</rs> anzeigen! <lb/>Werden Ihre Lieder
                    im nächsten Winter <lb/>fleissig gesungen werden?<!-- Für den Winter 1904/05 sind keine Aufführungen bekannt --></p>
                <closer>
                    <salute rendition="#r">Beste Grüsse Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.2283">M. M.</persName>
                    </signed>
                    <stamp sameAs="stamp.111">Halensee-Berlin, den <date when="1904-09-14">
                            <seg hand="#author">2. Sept. 04.</seg>
                        </date>
                        <lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Str. 22</placeName>.</stamp>
                </closer>
            </div>
        </body>
    </text>
