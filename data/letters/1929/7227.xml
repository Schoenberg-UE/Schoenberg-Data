    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.25">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>
                  CHARLOTTENBURG 9<lb/>
                        <placeName key="place.2.3.1.8">NUSSBAUM-ALLEE 17</placeName>
                        <lb/>TEL.: WESTEND 2266</stamp>
                    <address>
                        <addrLine>P. T. <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>P. T. <orgName key="org.1">Univ. Ed.</orgName>
                </salute>
                <p rendition="#inline">da ich in der gedruckten <seg type="comment">
                        <orig>Partitur</orig>
                        <note xml:id="novm_4jr_ydc" resp="#pkehrer">
                            <bibl sameAs="werke.64">Arnold Schönberg, Variationen für Orchester op.
                                31</bibl>, Originaldruck (<ref
                                target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=638&amp;werke_id=230&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                >ASGA B 13, Quelle E</ref>)</note>
                    </seg> eine Reihe <lb/>
                    <supplied cert="high">m</supplied>ir zweifelhafter Stellen gefunden habe, bitte
                    ich Sie, mir <lb/>entweder meine <seg type="comment">
                        <orig>Originalpartitur</orig>
                        <note xml:id="nnj3_zjr_ydc" resp="#pkehrer">Partiturreinschrift (<ref
                                target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=634&amp;werke_id=230&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                >ASGA B 13, Quelle C</ref>)</note>
                    </seg> oder die <seg type="comment">
                        <orig>Fotografie</orig>
                        <note xml:id="nqpg_zkr_ydc" resp="#pkehrer">Vermutlich Photokopie der
                            Partiturreinschrift (<ref
                                target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=636&amp;werke_id=230&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                >ASGA B 13, Quelle Cb</ref>)</note>
                    </seg> zu über<g ref="#typoHyphen"/>
                    <lb break="no"/>senden. Ich muss die dauernd bei mir haben, weil ich <lb/>sonst
                    nicht in der Lage bin, zweifelhafte Stellen, wie <lb/>man sie doch bei
                    jedesmaliger Durchsicht findet, zu kontrollieren.</p>
                <closer>
                    <salute>Mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed rendition="#c">
                        <persName key="pers.3263">Arnold
                  Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1929-10-29">29/X.1929</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
