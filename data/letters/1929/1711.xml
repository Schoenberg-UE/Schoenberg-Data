    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.20">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>PROFESSOR AN DER <orgName key="org.197">AKADEMIE DER KÜNSTE ZU
                            BERLIN</orgName>
                    </stamp>
                    <seg type="row">
                        <seg type="column">
                            <address>
                                <addrLine>Berlin-Charlottenburg 9;</addrLine>
                                <addrLine>
                                    <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>
                                </addrLine>
                            </address>
                        </seg>
                        <seg type="column">
                            <date>16.V.<lb/>1929</date>
                        </seg>
                    </seg>
                    <lb/>
                    <address>
                        <addrLine>An die <orgName key="org.1">UE</orgName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.11">Wien</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>liebe <orgName key="org.1">Universal Edition</orgName> (wie soll ich denn
                    <lb/>sagen?)</salute>
                <p>der Verlag <orgName key="org.4">Tischer und Jagenberg</orgName>
                    <seg type="comment">
                        <orig>teilt <lb/>mir mit</orig>
                        <note xml:id="nm1w_q4b_1dc" resp="#KBleier">Tischer &amp; Jagenberg an Arnold Schönberg, 15. Mai
                            1929 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B206134">ASCC 20613</ref>)</note>
                    </seg>, dass <add place="superlinear">er</add> Abrechnungen und Beträge für <date when="1926">1926</date>
                    <lb/>(171,10) und <date when="1927">1927</date> (39.50)<note place="inline" hand="#addressee">bez <date when="1928-06-11">11/6.28</date>. 1/2 <orgName key="org.4">T &amp; J</orgName>. <lb/>S 66.64 Anteil <persName key="pers.3263">Schönberg</persName>
                        <seg type="comment">
                            <orig>verr <date when="1928-07-28">23/7.28</date>.</orig>
                            <note xml:id="nrwz_d13_rzb" resp="#pkehrer">
                                <ref target="document.23454">Kontoauszug, 23. Juli 1928</ref>
                            </note>
                        </seg>
                    </note> an Sie gesandt habe.</p>
                <p>Ich kann aus meinen Aufzeichnungen fürs <lb/>Erste nicht finden, dass mir diese
                    Beträge aus<g ref="#typoHyphen"/>
                    <lb break="no"/>gezahlt worden sind und bitte Sie deshalb, mir <lb/>freundlichst
                    mitzuteilen, ob und wann das gesche<g ref="#typoHyphen"/>
                    <lb break="no"/>hen <add place="superlinear">ist</add> und wo es verrechnet,
                    resp. mir mitgeteilt <lb/>wurde.</p>
                <closer rendition="#inline">
                    <salute>Besten<choice>
                            <sic>n</sic>
                            <corr type="deleted"/>
                        </choice>s dankend, bin ich mit besten <lb/>Grüssen, ergebenst</salute>
                    <signed rendition="#c">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <note place="mBottom" hand="#addressee">f. <persName key="pers.3263">Schönberg</persName>
                    <lb/>
                    <unclear reason="illegible" cert="high">v/</unclear>
                    <orgName key="org.4">T. &amp; J.</orgName> erhalten <lb/>am <lb/>
                    <date when="1926-01-06">6 I. 1926</date> – M 42.15 = S 71.23 <seg type="comment">
                        <orig>überwiesen an <orgName key="org.130">E Horowitz</orgName>
                        </orig>
                        <note xml:id="nff3_j4t_szb" resp="#pkehrer">
                            <ref target="letter.17647">Universal-Edition an Arnold Schönberg, 8. März 1926</ref>. Der
                            Betrag ist in keiner der erhaltenen Abrechnungen nachweisbar</note>
                    </seg>
                    <date when="1926-02-12">12/II 26</date>.</note></div>
