    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4341">Bo.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1929-04-02">2.
                            April 1929</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>, Professor,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Charlottenburg 9.</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Soeben sind die <seg type="comment">
                        <orig>Stimmen</orig>
                        <note xml:id="ned3_hhw_qdc" resp="#pkehrer">Lieferdatum: <date when="1929-04-04">4. April 1929</date>, Auflage: 297 (<rs type="bibl" key="zotero-4528359-LQMNNW3Y">Buchon 2015</rs>, Bd. 5, S.
                        667)</note>
                    </seg> Ihres <lb/>
                    <hi rendition="#u">„<bibl sameAs="werke.63">III. Streichquartettes</bibl>“</hi>
                    aus dem Druck erschie<g ref="#typoHyphen"/>
                    <lb break="no"/>nen und wir lassen Ihnen dieselben mit glei<g ref="#typoHyphen"/>
                    <lb break="no"/>cher Post als Belegexemplar zugehen.</p>
                <closer rendition="#inline">
                    <salute>Wir empfeh<g ref="#typoHyphen"/>
                        <lb break="no"/>len uns <lb/>
                        <seg rendition="#r">mit vorzüglicher Hochachtung</seg>
                    </salute>
                    <signed rendition="#r">
                        <persName key="pers.4341">Bo</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
