    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4358">W.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1929-03-25">25.
                            März 1929</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Charlottenburg</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Als Angestellte der Firma <orgName key="org.1">Universal-<lb break="no"/>Edition
                        A. G.</orgName>, <placeName key="place.9.11">Wien</placeName>, bitte ich Sie
                    höflichst, meinen Irr<g ref="#typoHyphen"/>
                    <lb break="no"/>tum in der <seg type="comment">
                        <orig>Karte</orig>
                        <note xml:id="nxbg_mjl_qwb">
                            <ref target="letter.24383">Universal-Edition an Arnold Schönberg, 21.
                                März 1929 [erschlossen]</ref>
                        </note>
                    </seg> vom <date when="1929-03-21">21. März</date> bezüglich <persName key="pers.971">
                        <hi rendition="#g">Eisler</hi>’s</persName>
                    <lb/>
                    <hi rendition="#u">„<bibl sameAs="werke.175">Zeitungsausschnitte</bibl>“</hi>
                    freundlichst zu entschuldigen. <lb/>Ich habe versehentlich eine unrichtige Karte
                        genom<g ref="#typoHyphen"/>
                    <lb break="no"/>men. </p>
                <closer>
                    <salute rendition="#r">Hochachtungsvoll ergeben</salute>
                </closer>
            </div>
        </body>
    </text>
