    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.3065">Dr. R</persName>/<persName key="pers.4376">A.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1929-01-29">29.
                            Jänner 1929</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Monte Carlo.</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.7.1.1.1">Hotel Bristol</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir lassen Ihnen gleichzeitig die III. <lb/>Korrektur der
                        <bibl sameAs="werke.64">Variationen</bibl>, Partitur mit
                    den <seg type="comment">
                        <orig>fotografischen <lb/>Abzügen</orig>
                        <note xml:id="nwqm_zpv_4dc" resp="#pkehrer">Die Negativkopie der
                            Partiturschrift (<ref target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=635&amp;werke_id=230&amp;herkunft=allewerke">ASGA B 13, Quelle Ca</ref>) enthält mehrere der Beschreibung in
                            diesem Brief entsprechende Eintragungen</note>
                    </seg> Ihres Manuskriptes
                    zugehen. Herr <persName key="pers.1339">Greissle</persName>, der diese
                    <lb/>letzte Korrektur bereits durchgesehen hat, hat in den foto<g ref="#typoHyphen"/>
                    <lb break="no"/>grafischen Abzügen und auch auf Zetteln in den Plattenabzü<g ref="#typoHyphen"/>
                    <lb break="no"/>gen eine Reihe fraglicher Stellen angegeben, um deren freund<g ref="#typoHyphen"/>
                    <lb break="no"/>liche Durchsicht wir bitten. Einen Korrekturabzug der Vor<g ref="#typoHyphen"/>
                    <lb break="no"/>bemerkung und der Orchesterbesetzung <seg type="comment">
                        <orig>sandte Ihnen Herr <persName key="pers.1339">Greissle</persName>
                            <lb/>gleichzeitig mit Ihrem Manuskript</orig>
                        <note xml:id="np53_4nn_sdc" resp="#pkehrer">Felix Greissle an Arnold Schönberg, nach 29. Jänner
                                1929 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B229576">ASCC
                    22957</ref>)</note>
                    </seg>.</p>
                <closer>
                    <salute>Wir empfehlen uns<lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                    <signed rendition="#r">
                        <persName key="pers.3065">R</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
