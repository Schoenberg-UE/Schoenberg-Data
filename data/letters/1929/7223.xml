    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        </addrLine>
                        <addrLine>MONTE CARLO</addrLine>
                        <addrLine>
                            <placeName key="place.7.1.1.1">HOTEL BRISTOL</placeName>
                        </addrLine>
                    </address>
                    <address>
                        <addrLine>An die</addrLine>
                        <addrLine>
                            <orgName key="org.1">UNIVERSAL EDITION</orgName>
                        </addrLine>
                        <addrLine>I. <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>
                        </addrLine>
                        <addrLine>Musi<supplied cert="high">k</supplied>vereinsge<supplied cert="high">b</supplied>äude</addrLine>
                        <addrLine>Autriche <hi rendition="#g">VIENNE – WIEN</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>PT <orgName key="org.1">UE</orgName>,</salute>
                <p rendition="#inline">es sind mehrere Monate her, dass ich <lb/>Ihnen die <seg type="comment">
                        <orig>Dr<choice>
                                <sic>8</sic>
                                <corr cert="high">u</corr>
                            </choice>ckvorlage</orig>
                        <note sameAs="letter.1512/#nojc_wc2_ndc"/>
                    </seg> zur <bibl sameAs="werke.32">Instrumentation</bibl> des <lb/>
                    <persName key="pers.252">Bach</persName>-<bibl sameAs="werke.182">Präludiums und
                        Fuge</bibl>
                    <ref target="letter.1509">geschickt</ref> habe. Aber <lb/>bis heute höre ich
                    nichts von
                    Aufführungen, Ma<g ref="#typoHyphen"/>
                    <lb break="no"/>terialanfertigung, Partiturstich etc. Nirgends <lb/>ist das Werk
                    angekündigt: was ist da los. Ich <lb/>nehme an, dass die Ueberlassung zur
                    Publikation <lb/>Ihnen nicht ganz unangenehm war: aber ich weiss <lb/>nicht aus
                    welchem Grunde Sie den Beginn der <lb/>Erträgnisse dieses Werkes so lange
                        hinausschieben<supplied cert="high">.</supplied>
                </p>
                <p>Ich bitte, mir recht bald darüber zu schreiben.</p>
                <closer>
                    <salute>Inzwischen bin ich, hochachtungsvoll</salute>
                    <dateline rendition="#l">
                        <date when="1929-02-08">8.II.1929</date>
                    </dateline>
                    <signed rendition="#c">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
