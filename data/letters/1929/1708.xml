    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.25">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/> CHARLOTTENBURG 9<lb/>
                        <placeName key="place.2.3.1.8">NUSSBAUM-ALLEE 17</placeName>
                        <lb/>TEL.: WESTEND 2266</stamp>
                    <address>
                        <addrLine>An den <orgName key="org.180">DREILILIEN
                            VERLAG</orgName>
                        </addrLine>
                        <addrLine>z. H. d.</addrLine>
                    </address>
                    <dateline rendition="#c">
                        <date when="1929-05-10">10.5.29</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.2283">Max Marschalk</persName>
                        </addrLine>
                        <addrLine rendition="#r">Berlin</addrLine>
                        <addrLine rendition="#r">Hal<choice>
                                <sic>l</sic>
                                <corr type="deleted"/>
                            </choice>ensee, <placeName key="place.2.3.3.2">Ha<supplied cert="high">l</supplied>berstädterst 6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter <rs type="person" key="pers.2283">Herr</rs>, </salute>
                <p>Da ich seit geraumer Zeit von Ihnen weder <lb/>Geld noch Abrechnung erhalten
                    habe, so bitte <lb/>ich Sie höflichst mir beides so bald als <lb/>möglich zu
                    senden!</p>
                <closer>
                    <salute rendition="#c">Hochachtungsvoll</salute>
                </closer>
            </div>
        </body>
    </text>
