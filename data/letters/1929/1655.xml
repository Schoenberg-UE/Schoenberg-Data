    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">ARNOLD SCHOENBERG</persName>
                        </addrLine>
                        <addrLine>MONTE CARLO</addrLine>
                        <addrLine>
                            <placeName key="place.7.1.1.1">HOTEL BRISTOL</placeName>
                        </addrLine>
                    </address>
                    <dateline>
                        <date when="1929-01-15">15.I.1929</date>
                    </dateline>
                    <address>
                        <addrLine>
                            An die Redaktion des <metamark function="done" hand="#unknown">⎣</metamark>
                            <orgName key="org.7">Anbruch</orgName>
                        </addrLine>
                        <addrLine>Wien, I. <placeName key="place.9.11.6.12">Karlsplatz
                            6</placeName>
                        </addrLine>
                        <addrLine>
                            Musikvereinsgebäude
                        </addrLine>
                    </address>
                </opener>
                <salute>Geehrte Redaktion des <orgName key="org.7">Anbruch</orgName>
                </salute>
                <p>
                    <persName key="pers.688">
                        <hi rendition="#g">Casella</hi>
                    </persName> ist mir in <del rendition="#s">
                        <gap reason="illegible" quantity="1" unit="words"/>
                    </del> andere<del rendition="#s">
                        <gap reason="illegible" quantity="1" unit="chars"/>
                    </del>r <lb/>Hinsicht viel zu sympathisch, als dass ich ihm auf <lb/>
                    <bibl sameAs="schriften.117">Theoretisches</bibl> antworten wollte.</p>
                <closer>
                    <salute>Hochachtungsvoll</salute>
                </closer>
                <postscript>
                    <p>Diesen Brief bitte ich im <orgName key="org.7">Anbruch</orgName> zu
                            veröffentli<g ref="#typoHyphen"/>
                        <lb break="no"/>chen.</p>
                </postscript>
            </div>
        </body>
