    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.31">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/> I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>·
                  <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition, Wien. A. B. C. Code 5<hi rendition="#sup">th.</hi> Ed. Mosse Code.<lb/>Telefon U-47-5-85 Serie.
                  Bank-Konto: <orgName key="org.199">Zentral-Europä-<lb/>ische Länderbank
                     Wien</orgName>. Postsparkassen-Kto. 57557.<lb/>Wien<seg hand="#author">, am
                        <date when="1929-05-27">27. Mai 1929</date>.</seg>
                    </stamp>
                    <lb/>
                    <persName key="pers.1750">Dr. K</persName>/<persName key="pers.4363">No.</persName>
                    <lb/>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Charlottenburg 9</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee
                        17</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Herr <persName key="pers.3924">R. Vandelle</persName>, <placeName key="place.4.4.4.1">Rue Jacob 11 Paris 6<hi rendition="#sup">e</hi>
                    </placeName> sendet uns einen <lb/>Teil seiner <seg type="comment">
                        <orig>Uebersetzung</orig>
                        <note xml:id="ngr1_dpb_mgc" resp="#KBleier">Zu
                            Lebzeiten <persName key="pers.3263">Schönbergs</persName> erschien keine
                            französische Übersetzung der <bibl sameAs="schriften.1">Harmonielehre</bibl>
                        </note>
                    </seg>
                    <!-- nicht erhalten -->Ihrer <bibl sameAs="schriften.1">Harmonielehre</bibl> mit
                    der Bitte, dass Sie <lb/>dieselbe begutachten mögen. Wir erlauben uns daher
                    Ihnen diese Ueber<g ref="#typoHyphen"/>
                    <lb break="no"/>setzung und zwar:</p>
                <list>
                    <item>Preface Seite 1–5</item>
                    <item>Theorie ou Système de Reprèsentation Seite 1–10 und</item>
                    <item>Uebersetzung von Seite 87 des Originaltextes (Seite 1–7)</item>
                </list>
                <p>sowie einen <seg type="comment">
                        <orig>Brief</orig>
                        <note xml:id="nagy_cx4_tzb" resp="#pkehrer">Die erhaltene Korrespondenz
                            beginnt mit Arnold Schönberg an Romuald Vandelle, 11. Juni 1929 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B017226">ASCC
                                1722</ref>)</note>
                    </seg> des Herrn <persName key="pers.3924">Vandelle</persName> zu
                    übermitteln.</p>
                <closer>Wir sehen Ihrer Rückäusserung mit Interesse entgegen und <lb/>zeichnen
                  <lb/>
                    <salute rendition="#r">in vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">D<hi rendition="#sup">r</hi>
                        <persName key="pers.1750">
                  Kalmus</persName>
                    </signed>
                    <lb/>
                    <hi rendition="#u">Beilagen!</hi>
                </closer>
            </div>
        </body>
    </text>
