    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.164">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                        <lb/>WIEN<lb/> I. <placeName key="place.9.11.6.12">Karlsplatz 6</placeName>,
                        (Musikvereinsgebäude)</stamp>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine>Herrn <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#u">
                                <hi rendition="#g">Wien</hi> XIII.</hi>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.11.5.1">Gloriettegasse 43</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1917-08-14">14.
                            August 1917</date>.</dateline>
                </opener>
                <salute>Lieber Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Ihr Zusatz in Punkto der weiteren Aufführun<g ref="#typoHyphen"/>
                    <lb break="no"/>gen seitens <orgName key="org.38">Breitkopf &amp;
                        Härtel</orgName> geht in Ord<g ref="#typoHyphen"/>
                    <lb break="no"/>nung. – Den von Ihnen erwähnten <seg type="comment">
                        <orig>Titelblatt<g ref="#typoHyphen"/>
                            <lb break="no"/>entwurf</orig>
                        <note sameAs="letter.488/#nc1y_jwm_xfc"/>
                    </seg> zu „<bibl sameAs="schriften.12">Jakobsleiter</bibl>“ habe ich <hi rendition="#u">nicht</hi>
                    <lb/>erhalten. – Den zweiten Korrekturabzug wird <lb/>die Druckerei hoffentlich
                    in wenigen Tagen <lb/>liefern und wenn alles klappt, kann das Buch <lb/>anfangs
                        <date when="1917-09">September</date> erscheinen.</p>
                <closer>
                    <salute>Mit herzlichen Grüssen <lb/>
                        <seg rendition="#c">Ihr ganz ergebener</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1538">Hertzka</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
