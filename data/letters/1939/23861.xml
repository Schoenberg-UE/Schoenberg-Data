    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Sehr verehrter <rs type="person" key="pers.3263">Meister</rs>!</salute>
                <p>Bezugnehmend auf den letzten Satz <lb/>Ihres <ref target="letter.3146">Schreibens</ref> möchte ich Ihnen sagen, <lb/>dass Herr Direktor <persName key="pers.4190">Winter</persName> noch in <placeName key="place.9.11">Wien</placeName> ist. <lb/>Dr. <persName key="pers.1750">Kalmus</persName>,
                    Dr. <persName key="pers.3065">Roth</persName> und Kapellmeister <persName key="pers.3612">Stein</persName>
                    <lb/>befinden sich bei unserer <placeName key="place.3.1">Londoner</placeName>
                        Vertre<g ref="#typoHyphen"/>
                    <lb break="no"/>tung und Dr. <persName key="pers.1520">Heinsheimer</persName> in <placeName key="place.15.8">New
                        York</placeName>.</p>
                <closer>
                    <salute>Mit vielen herzlichen Grüssen, auch <lb/>an Ihre liebe <rs type="person" key="pers.3297">Frau</rs>
                        <lb/>
                        <seg rendition="#r">Ihre</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3067">B Rothe</persName>
                    </signed>
                    <lb/>
                    <salute hand="#pers.4190">Allerherzlichste Grüße <lb/>von Ihrem</salute>
                    <lb/>
                    <signed rendition="#c">
                        <persName key="pers.4190">Hugo
                            Winter</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
