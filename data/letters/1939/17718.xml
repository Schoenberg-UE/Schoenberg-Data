    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.17">
                        <orgName key="org.1">Universal-Edition·A. G.</orgName>
                        <lb/>WIEN·I·<placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                        <lb/>Musikvereinsgebäude / Tel. U 47-5-85<lb/> LEIPZIG·<placeName key="place.2.20.8">KARLSTRASSE 10</placeName>
                        <lb/>TELEGRAMM-ADRESSE: MUSIKEDITION, WIEN·POSTSPARKASSEN·KONTO WIEN
                        57557</stamp>
                    <lb/>
                    <persName key="pers.4342">Wi.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1939-05-22">22.
                            Mai 1939</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 North Rockingham Avenue</placeName>
                        </addrLine>
                        <addrLine>Brentwood Park</addrLine>
                        <addrLine>
                            <hi rendition="#uda">
                                <hi rendition="#g">Los Angeles</hi>, Calif.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>In der <ref target="document.17718">Beilage</ref> übermitteln wir Ihnen Abschrift
                    <lb/>eines Briefes der <orgName key="org.23">AMP</orgName> vom <date when="1939-04-12">12. April</date> in Angelegenheit der Ver<g ref="#typoHyphen"/>
                    <lb break="no"/>rechnung der Aufführungsgebühren, <add place="intralinear">sowie eine Liste über verrechnete
                            <lb/>Aufführungsgebühren.</add>
                </p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">mit vorzüglicher
                            Hochachtung</seg>
                    </salute>
                    <lb/>
                    <seg rendition="#r">
                        <orgName key="org.1">UNIVERSAL-EDITION A.
                            G.</orgName>
                    </seg>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                    <lb/>
                    <ref target="document.17718">2 Beilagen</ref>
                </closer>
                <note place="left" hand="#unknown">
                    <hi rendition="#circle">1</hi>
                </note>
            </div>
        </body>
