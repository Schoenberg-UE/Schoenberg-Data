    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>/<persName key="pers.4345">Re</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1930-10-10">10.
                            Oktober 1930</date>.</dateline>
                    <address>
                        <addrLine>Herrn <add place="intralinear">Prof</add>
                        </addrLine>
                        <addrLine rendition="#c">
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g">
                                <hi rendition="#uda">Meran</hi>
                            </hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.9.1">Hotel
                                Corso</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr! <add place="intralinear">
                        <rs type="person" key="pers.3263">Prof.</rs>
                    </add>
                </salute>
                <p>Auf Veranlassung <!-- nicht nachweisbar -->von Herrn <seg
                        type="comment"><orig>Generalmusik<g ref="#typoHyphen"/><lb break="no"/>direktor <persName key="pers.1737">Kabasta</persName>
                        </orig><note xml:id="njsy_lws_yhc" resp="#KBleier">Vgl. Arnold Schönberg an
                            Oswald Kabasta, 6. Oktober 1930 (<ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B019687">ASCC
                                1968</ref>). <ref target="event.264"/></note></seg>lassen wir Ihnen gleichzeitig per <note place="right" hand="#unknown">ges.
                            <persName key="pers.4345">Re</persName>
                    </note>
                    <lb/>Eilpost eine Partitur Ihrer
                        „<bibl sameAs="werke.2">
                        <hi rendition="#u">Kammersinfonie</hi>
                    </bibl>“ <lb/>leihweise zugehen und empfehlen uns</p>
                <closer rendition="#r">
                    <salute>mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.4190">W</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
