    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4341">Bo.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1930-03-04">4.
                            März 1930</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                            <hi rendition="#g">,</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Charlottenburg</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.8">Nussbaumallee 17</placeName>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Soeben ist Ihr <bibl sameAs="werke.66">Klavierstück op. 33a</bibl>
                    <lb/>aus dem <seg type="comment">
                        <orig>Druck</orig>
                        <note xml:id="nxfb_1xp_f1c" resp="#KBleier">Lieferdatum: <date when="1930-03-01">1. März 1930</date>, Auflage: 500 (<rs type="bibl" key="zotero-4528359-LQMNNW3Y">Buchon 2015</rs>, Bd. 5, S.
                            668)</note>
                    </seg> erschienen und wir lassen Ihnen <lb/>mit gleicher Post 3 Ehrenexemplare zugehen.</p>
                <closer>Wir empfehlen uns <lb/>
                    <salute rendition="#r">hochachtungsvoll</salute>
                </closer>
                <signed rendition="#r">
                    <persName key="pers.4341">Bo</persName>
                </signed>
            </div>
        </body>
    </text>
