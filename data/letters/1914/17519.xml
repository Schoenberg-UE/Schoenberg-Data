    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.97">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG <lb/>
                        <placeName key="place.2.20.9">Sternwartenstr. 15–21</placeName>
                        <lb/>WIEN<lb/>
                  I·<placeName key="place.9.11.6.18">Reichsratsstrasse
                     9</placeName>
                        <lb/>Telegramm-Adresse: Musikedition, Wien<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 22877·Bank-Konto: <orgName key="org.199">k·k·privil·österr.<lb/>Länderbank, Wien</orgName>·Postsparkassen-Konto:
                  57557.<lb/>Wien <seg hand="#author">
                            <date when="1914-02-09">9. Februar 1914</date>.</seg>
                    </stamp>
                    <stamp>Buchhaltung</stamp>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine rendition="#c">Herrn Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.2.3">Berlin</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir überreichen Ihnen inliegend Abrech<g ref="#typoHyphen"/>
                    <lb break="no"/>nungen
               per II. Halbjahr <date when="1913">1913</date> über Ihre bei uns er<g ref="#typoHyphen"/>
                    <lb break="no"/>schienenen Werke, welche laut nachfolgender
                  Aufstel<g ref="#typoHyphen"/>
                    <lb break="no"/>lung einen Debet-Saldo von
               zusammen <lb/>
                    <seg rendition="#c">
                        <hi rendition="#uda">K 6799.89</hi>
                    </seg>
                    <lb/>aufweisen.</p>
                <p>Ihre Eingänge aus Tantièmen betragen <lb/>laut Abrechnung No. 29<subst>
                        <del rendition="#ow">4</del>
                        <add place="across">8</add>
                    </subst>, 295, K 377.88, hiervon sind <lb/>im Sinne unseres neuen Vertrages K 350.– als Rück<g ref="#typoHyphen"/>
                    <lb break="no"/>zahlung auf den Vorschuß zu
               verrechnen. Den Rest von <lb/>
                    <hi rendition="#u">K 27.88</hi> überwiesen wir Ihnen
               gleichzeitig per Post<g ref="#typoHyphen"/>
                    <lb break="no"/>anweisung.</p>
                <closer>
                    <salute>Wir ersuchen höfl. um Empfangsanzeige <lb/>und empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <stamp sameAs="stamp.85" rendition="#r">
                        <orgName key="org.1">Universal Edition
                     Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.1538">Hertzka</persName>
                    </signed>
                </closer>
            </div>
