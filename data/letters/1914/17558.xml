    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine>Herrn <persName key="pers.3263">Arnold
                     Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#g">Murnau</hi>
                            <add place="sublinear">
                                <placeName key="place.2.25.1">Seidelstr 6</placeName>
                     Bayern</add>
                        </addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <address>
                        <addrLine>Wohlgeboren Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g">Murnau</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Im Besitze Ihrer gesch. <seg type="comment">
                        <orig>Karte</orig>
                        <note xml:id="ng1p_p5n_xcc" resp="#pkehrer">
                            <ref target="letter.23845">Arnold Schönberg an Universal-Edition, 24.
                                Juli 1914 [erschlossen]</ref>
                        </note>
                    </seg> vom <date when="1914-07-24">24. d. M.</date>
                    <lb/>haben wir noch <date when="1914-07-27">Samstag</date> ein Exemplar der
                        <bibl sameAs="werke.24">George-<lb break="no"/>Lieder</bibl> an Herrn
                        <persName key="pers.1774">Kaudinsky</persName> abgesandt. Vom Textbuch
                    <lb/>zum <bibl sameAs="schriften.94">Monodram</bibl> erhalten Sie mit gleicher
                    Post einen <lb/>Abzug. Wegen der genauen Grösse und der Schrift<g ref="#typoHyphen"/>
                    <lb break="no"/>muster für das <bibl sameAs="werke.7">Monodram</bibl> haben wir
                    an <orgName key="org.65">Geidel</orgName> ge<g ref="#typoHyphen"/>
                    <lb break="no"/>schrieben. Die Reproduktions-art für den Titel <lb/>werden wir
                        <add place="superlinear">erst</add> nach Erhalt der <seg type="comment">
                        <orig>Zeichnung</orig>
                        <note sameAs="letter.17551/#nl14_psv_qdc"/>
                    </seg>
                    bestimmen <lb/>können.</p>
                <closer>
                    <stamp sameAs="stamp.60">Wien, am <date when="1914-07-27">
                            <seg hand="#author">27. JULI</seg> 191<seg hand="#author">4</seg>
                        </date>
                        <lb/>I. <placeName key="place.9.11.6.17">Reichsratsstraße 9</placeName>.<lb/>Hochachtungsvoll<add place="sublinear">ergeben</add>
                        <lb/>
                        <seg hand="#author">f </seg>
                        <orgName key="org.1">„Universal-Edition“ A.-G</orgName>
                        <lb/>(Jos. Aibl Verlag, G. m. b.
               H.)</stamp>
                    <signed rendition="#r">Dr <persName key="pers.1750">
                  Kalmus</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
