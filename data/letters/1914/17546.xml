    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.97">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG <lb/>
                        <placeName key="place.2.20.9">Sternwartenstr.
                            15–21</placeName>
                        <lb/>WIEN<lb/>I·<placeName key="place.9.11.6.18">Reichsratsstrasse
                            9</placeName>
                        <lb/>Telegramm-Adresse: Musikedition, Wien<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 22877·Bank-Konto: <orgName key="org.199">k·k·privil·österr.<lb/>Länderbank, Wien</orgName>·Postsparkassen-Konto: 57557.<lb/>
                        <lb/>Wien <seg hand="#author">
                            <date when="1914-06-13">13. Juni 1914</date>
                        </seg>
                    </stamp>
                    <lb/>
                    <persName key="pers.4381">GP</persName>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.2.23.1">Berlin-Südende</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir senden Ihnen gleichzeitig in Express-Paketen <lb/>das gesamte Orchester-Material
                  <add place="superlinear">der <bibl sameAs="werke.16">Gurrelieder</bibl>
                    </add> mit
               Ausnahme des Streich-<lb break="no"/>Quintetts und der Schlagwerk-Partituren, die am
               Montag <lb/>nachfolgen. Die Partitur geht gleichzeitig als Wert-<lb break="no"/>Paket.</p>
                <closer>Wir zeichnen <salute rendition="#r">hochachtungsvoll <lb/>ergeben <lb/>
                    </salute>
                    <stamp sameAs="stamp.44" rendition="#r">
                        <seg hand="#author">f</seg>
                        <orgName key="org.1">„Universal-Edition“
                  Aktiengesellschaft</orgName>
                    </stamp>
                    <signed rendition="#r">D<hi rendition="#sup">r</hi>
                        <persName key="pers.1750">
                     Kalmus</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rendition="#u">NB!</hi> Wir fügen Abzug <lb/>der Texte zu den <bibl sameAs="werke.24">George-<lb break="no"/>Liedern</bibl> bei mit der
                        <lb/>Bitte um Rücksendung <lb/>nach Durchsicht. – <lb/>Von <placeName key="place.8.1">Amsterdam</placeName> traf <lb/>heute Bestätigung der
                        <lb/>Materialabmachung <lb/>ein. Die Proben sollen <lb/>am <date when="1914-06-22">22.</date>
                        <date when="1914-06-23">23.</date>
                        <date when="1914-06-24">24.</date> u. <date when="1914-06-26">26.</date>
                        stattfinden – <lb/>Umschlagabzug zum Textbuch <lb/>des <bibl sameAs="schriften.94">Monodrams</bibl> anbei</p>
                </postscript>
            </div>
        </body>
    </text>
