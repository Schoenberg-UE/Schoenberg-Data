    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.24">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>
                        <placeName key="place.15.8.15">209 West 57<hi rendition="#sup">th</hi>
                            Street</placeName>
                        <lb/>New York<lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/> I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>·
                        <lb/>Musikvereinsgebäude</stamp>
                    <lb/>
                    <persName key="pers.4384">Dr. W.</persName>/<persName key="pers.4342">Wi.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-02-23">23.
                            Februar 1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Charlottenburg, 2</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.5">Steinplatz 2</placeName>, Pension
                            Bavaria</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Herr Dr. <persName key="pers.1520">Heinsheimer</persName> kommt anläß<g ref="#typoHyphen"/>
                    <lb break="no"/>lich der <seg type="comment">
                        <orig>Premiere</orig>
                        <note xml:id="nu4p_mr2_32c" resp="#KBleier">
                            <ref target="event.138"/>
                        </note>
                    </seg> der <bibl sameAs="werke.119">Oper</bibl> von <persName key="pers.4048">Kurt <hi rendition="#g">Weill</hi>
                    </persName> nach <placeName key="place.2.3">Berlin</placeName> und <lb/>möchte
                    sich bei dieser Gelegenheit erlauben, Ihnen seine Auf<g ref="#typoHyphen"/>
                    <lb break="no"/>wartung zu machen. Er bittet sie höflichst, ihm ins Hotel
                        <placeName key="place.2.3.10.6">EXCELSIOR</placeName>
                    <lb/>schreiben oder telephonieren zu lassen, ob Ihnen sein Besuch am
                    <lb/>Nachmittag des <date when="1927-03-01">1.</date> oder im Laufe des <date when="1927-03-02">2.</date> oder <date when="1927-03-03">3. März</date>
                    erwünscht ist <lb/>und zu welcher Zeit Sie ihn empfangen würden.</p>
                <closer>
                    <salute rendition="#r">Mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.128" rendition="#r">
                        <orgName key="org.1">Universal-Edition
                        Actiengesellschaft</orgName>.
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <persName key="pers.4392">H</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
