    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.3612">S</persName>/<persName key="pers.4348">P.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-05-27">27. Mai
                        1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u #g">Charlottenburg
                            2</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.5">Steinplatz
                                2</placeName>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir bestätigen mit bestem Dank den Empfang Ihres <ref target="letter.1317">Schrei<g ref="#typoHyphen"/>
                        <lb break="no"/>bens</ref> vom <date when="1927-05-21">21. ds.</date> aus dem wir mit Vergnügen ersehen haben,
                    dass Sie <lb/>Anfang <date when="1927-06">Juni</date> nach <placeName key="place.9.11">Wien</placeName> kommen. Wir freuen uns, dann mit Ihnen
                    alle <lb/>fraglichen Angelegenheiten besprechen zu können.</p>
                <closer>
                    <salute rendition="#r">Mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.4190">W</persName>
                    </signed>
                    <lb/>
                    <signed rendition="#c">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
