    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4378">Dr. H.</persName>/<persName key="pers.4382">We.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, den <date when="1927-06-15">15. Juni 1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#c">b. <persName key="pers.3452">Seligmann</persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Wien, IV.</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.11.12.5">Bruckner<subst>
                                    <del rendition="#ow">gasse</del>
                                    <add place="across">strasse</add>
                                </subst> 6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>In der Anlage übersenden wir Ihnen <lb/>die Kopie eines
                    Schreibens<!-- nicht nachweisbar -->, das wir im Sinne unserer Unterredung<!-- Aufenthalt in Wien von 2.6. bis 18.6.1927 -->
                    <lb/>heute an Frau <persName key="pers.785">Julia Culp</persName> gerichtet
                    haben, und empfehlen uns</p>
                <closer rendition="#r">
                    <salute>mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.1750">DK</persName>
                    </signed>
                    <signed>
                        <persName key="pers.4190">W</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
