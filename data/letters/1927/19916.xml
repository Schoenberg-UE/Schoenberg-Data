    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.3612">S</persName>/<persName key="pers.4348">P.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-05-19">19. Mai
                        1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Charlottenburg
                            2,</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.5">Steinplatz
                                2</placeName>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wunschgemäss lassen wir Ihnen je 2 Partituren <lb/>Ihrer <seg type="comment">
                        <orig>Bearbeitungen 2 <persName key="pers.252">Bach</persName>’scher
                                Choralvorspiele</orig>
                        <note sameAs="letter.17625/#nyb3_hj1_dwb"/>
                    </seg>
                    mit <lb/>gleicher Post zugehen.</p>
                <closer>
                    <salute rendition="#r">Mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <signed rendition="#c">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <gap reason="illegible" unit="chars" quantity="1"/>
                    </signed>
                </closer>
            </div>
        </body>
