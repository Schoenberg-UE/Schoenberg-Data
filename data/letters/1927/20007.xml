    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.3067">R</persName>/<persName key="pers.4362">M.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-11-17">17. November 1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.2.3.1">BERLIN-CHARLOTTENBURG</placeName>.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir haben wunschgemäss an Frau <persName key="pers.1105">Marya <lb/>
                        <hi rendition="#g">Freund</hi>
                    </persName> Ihre <seg type="comment">
                        <orig>Aufsätze</orig>
                        <note xml:id="nunb_j2v_jzb" resp="#pkehrer">
                            <bibl sameAs="schriften.41">Arnold Schönberg, Gesinnung oder
                                Erkenntnis</bibl>; <bibl sameAs="schriften.42">Arnold Schönberg,
                                Mechanische Musikinstrumente</bibl>
                        </note>
                    </seg> aus dem <seg type="comment">
                        <orig>Jahrbuch</orig>
                        <note sameAs="letter.21789/#ncdh_l15_qwb"/>
                    </seg> und „<orgName key="org.191">Pult <lb/>und Taktstock</orgName>“ gesandt.
                    Das <seg type="comment">
                        <orig>„Waldtauben“</orig>
                        <note xml:id="nyly_lsl_3gc" resp="#KBleier">
                            <bibl sameAs="werke.146">Arnold Schönberg/Erwin Stein, Gurre-Lieder</bibl>: Lied der Waldtaube; <ref target="event.72"/>
                        </note>
                    </seg>-Material <lb/>ist in der Besetzung für
                    Kammerorchester nach <placeName key="place.4.4">Paris</placeName>
                    <lb/>gesandt worden.</p>
                <closer>
                    <salute>Mit besten Empfehlungen begrüssen wir Sie <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                </closer>
            </div>
        </body>
    </text>
