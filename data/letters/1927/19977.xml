    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.1750">Dr. K</persName>/<persName key="pers.4374">L.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1927-09-16">16. September
                        1927</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.9.11.9">
                                    <hi rendition="#g">Wien</hi>,
                                    VI.</placeName>,</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Der <orgName key="org.51">Verband deutscher Bühnen<g ref="#typoHyphen"/>
                        <lb break="no"/>schriftsteller und Bühnenkomponisten</orgName>, <placeName key="place.2.3">Berlin</placeName>, hat uns Formulare <lb/>für
                    Beitritterklärung eingesandt, die wir ausgefüllt retour<g ref="#typoHyphen"/>
                    <lb break="no"/>niert haben. Zu Ihrer Information erlauben wir uns Ihnen
                        gleich<g ref="#typoHyphen"/>
                    <lb break="no"/>zeitig die Satzungen des
                    Verbandes zu übermitteln, aus denen <lb/>hervorgeht, dass nicht die
                    Mitgliedschaft von einem abendfül<g ref="#typoHyphen"/>
                    <lb break="no"/>lenden
                    Werk abhängig gemacht wird, wohl aber die Unterschei<g ref="#typoHyphen"/>
                    <lb break="no"/>dung zwischen ordentliche und ausserordentliche Mitglieder.
                    <lb/>Da der einzige Unterschied zwischen ordentlichen und ausser<g ref="#typoHyphen"/>
                    <lb break="no"/>ordentlichen Mitgliedern aber nur in dem
                    Beteiligungsrecht <lb/>an der Mitgliederversammlung und in dem passiven
                    Wahlrecht <lb/>besteht, so glauben wir, dass dieser Unterschied praktisch für
                    <lb/>Sie nicht von Bedeutung ist.</p>
                <closer>
                    <salute rendition="#r">In vorzüglicher Hochachtung</salute>
                    <lb/>
                    <hi rendition="#u">1 Beilage<!-- nicht erhalten --></hi>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.4190">W</persName>
                    </signed>
                    <signed rendition="#r">
                        <persName key="pers.1750">DK</persName>
                    </signed>
                </closer>
            </div>
