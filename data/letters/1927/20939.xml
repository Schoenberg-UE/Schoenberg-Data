    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>HERRN und Frau Professor <persName key="pers.3263">Arnold
                    Schönberg</persName>
                </salute>
                <p>ZU EHREN VON MRS. <persName key="pers.765">ELIZABETH S. COOLIDGE</persName> SOWIE
                    DER KOMPONISTEN <lb/>UND MITWIRKENDEN DER ZWEI KAMMERKONZERTE VERANSTALTEN
                        <persName key="pers.1538">EMIL</persName> UND <lb/>
                    <persName key="pers.1539">YELLA
                        HERTZKA</persName> IN IHREM HEIM, GRINZING, <placeName key="place.9.11.3.1">KAASGRABEN 19</placeName> (TEL. 15-5-52), <lb/>SONNTAG, DEN <date when="1927-09-18">18. SEPTEMBER</date>,
                    4 UHR NACHM. BEI GÜNSTIGER WITTERUNG <lb/>EINE GARDEN-PARTY UND LADEN SIE ZU
                    DERSELBEN HÖFLICHST EIN</p>
                <closer>U. A. w. g.<dateline>
                        <placeName key="place.9.11">WIEN</placeName>, <date notBefore="1927-09-01" notAfter="1927-09-17">ANFANGS SEPTEMBER
                            1927</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
