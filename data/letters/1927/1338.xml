    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.9.6.1">Hotel Werzer</placeName>
                        </addrLine>
                        <addrLine>Pörtschach a/See</addrLine>
                    </address>
                    <dateline>
                        <date when="1927-07-02">2.VII.1927</date>
                    </dateline>
                </opener>
                <salute>P. T. <orgName key="org.1">U.E.</orgName>
                </salute>
                <p rendition="#inline">mit bestem Dank bestätige <lb/>ich den Empfang telegrafisch
                    gesendeter <lb/>1500.– (fünfzehnhundert Schilling) auf <lb/>meinen
                    vorgestrigen <ref target="letter.1333">Brief</ref>.</p>
                <p>Zu Ihrer heutigen <ref target="letter.19927">Anfrage</ref>: <lb/>die 500 Mark
                    bitte ich meinem <lb/>
                    <hi rendition="#u">
                        <rs type="person" key="pers.3281">Sohn</rs>
                    </hi> oder <hi rendition="#u">Herrn <persName key="pers.1339">Greissle</persName>
                    </hi> in Schillingen <lb/>auszuzahlen gegen deren
                    Bestätigung. </p>
                <closer>
                    <salute>Mit besten Grüßen</salute>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
