    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.1485">LH</persName>/<persName key="pers.4374">L.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1927-07-28">28. Juli 1927</date>
                    </dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda #g">
                                <placeName key="place.9.6">Pörtschach</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir bestätigen mit <lb/>bestem Danke den Empfang der
                    Probeseite<!-- =Herstellungkartei: am selben Tag an Waldheim --> Ihres <bibl
                        sameAs="werke.63">Streich<g ref="#typoHyphen"/>
                        <lb break="no"/>quartetts</bibl> und haben zur Kenntnis genommen, dass Sie
                    im <lb/>allgemeinen mit der Ausführung zufrieden sind. Ihre <lb/>übrigen
                    Weisungen bezüglich des Stiches haben wir der <lb/>
                    <rs type="org" key="org.186">Druckerei</rs> weitergegeben und hoffen, dass wir
                    Ihnen nun <lb/>bald die Abzüge der ganzen Partitur werden einsenden
                    <lb/>können.</p>
                <closer>
                    <salute>Wir begrüssen Sie mit <lb/>besten Empfehlungen <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.4190">W</persName>
                    </signed>
                    <lb/>
                    <signed>
                        <unclear reason="illegible" cert="high">
                            <persName key="pers.1485">ELH</persName>
                        </unclear>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
