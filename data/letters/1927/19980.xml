    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.4190">Dir. W</persName>/<persName key="pers.4349">Hb</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-09-28">28. September 1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">
                                <hi rendition="#g">Wien</hi>, VI.</hi>
                        </addrLine>
                        <addrLine rendition="#r">Pens. Schneider, <placeName key="place.9.11.9.6">Getreidemarkt 7</placeName>.</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Vor Ueberweisung der Monatsrate fragen wir bei <lb/>Ihnen höfl. an, ob wir diese
                    an Ihre frühere Adresse nach <placeName key="place.2.3">Berlin</placeName>
                        über<g ref="#typoHyphen"/>
                    <lb break="no"/>weisen sollen oder ob Sie den
                    Betrag in <placeName key="place.9.11">Wien</placeName> zu erhalten wünschen.</p>
                <closer rendition="#r">
                    <salute>Mit vorzüglicher Hochachtung</salute>
                    <table rows="6" cols="2" rendition="#smaller">
                        <row>
                            <cell>Monatsrate per <date when="1927-12">Dezember 1927</date>
                            </cell>
                            <cell/>
                        </row>
                        <row>
                            <cell>per R.M. 500.– d. s. ....</cell>
                            <cell>S. 840.–</cell>
                        </row>
                        <row>
                            <cell>abzüglich der Ihnen am <lb/>
                                <date when="1927-08-05">5. August 1927</date> zu viel</cell>
                            <cell/>
                        </row>
                        <row>
                            <cell>überwiesenen ...........</cell>
                            <cell>
                                <hi rendition="#u">
                                    <ellipsis>
                                        <metamark function="ellipsis">〃</metamark>
                                        <supplied>S.</supplied>
                                    </ellipsis> 660.–</hi>
                            </cell>
                        </row>
                        <row>
                            <cell>verbleiben ....</cell>
                            <cell>
                                <hi rendition="#u">S. 180.–</hi>
                            </cell>
                        </row>
                    </table>
                    <signed>
                        <persName key="pers.4190">W</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
