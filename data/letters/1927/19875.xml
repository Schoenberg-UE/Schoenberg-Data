    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-01-27">27.
                            Jänner 1927</date>.</dateline>
                    <persName key="pers.4349">Hb</persName>
                    <address>
                        <addrLine>Wohlgeb.</addrLine>
                        <addrLine rendition="#c">Herrn Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Berlin-Charlottenburg 2</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.5">Steinpl. 2</placeName>, Pension
                            Bavaria</addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir überwiesen Ihnen heute per <orgName key="org.254">Post<g ref="#typoHyphen"/>
                        <lb break="no"/>scheckamt, Leipzig</orgName>, den per <date when="1927-02-01">1. Februar 1927</date> fällig werdenden Betrag von <lb/>
                    <seg rendition="#c">
                        <hi rendition="#u">R.M. 500.– i. W. Reichsmark Fünfhundert</hi>
                    </seg>
                    <lb/>dessen Empfang Sie uns gefl. bestätigen wollen.</p>
                <closer rendition="#r">
                    <salute>Wir empfehlen uns mit dem Ausdrucke <lb/>vorzüglichster
                        Hochachtung</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.1750">DK</persName>
                    </signed>
                    <signed>
                        <persName key="pers.4190">W</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
