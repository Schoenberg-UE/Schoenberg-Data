    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.22">
                        <add place="superlinear">Arnold Schönberg</add>
                        <lb/>
                        <placeName key="place.4.7.1">CALIFORNIE PALACE</placeName>
                        <lb/>Cannes<lb/>Même Administration<lb/>PLAZA ATHÉNÉE<lb/>PARIS</stamp>
                    <dateline>
                        <date when="1927-12-23">23.XII.1927</date>
                    </dateline>
                </opener>
                <salute>P. T. <orgName key="org.1">U.E.</orgName> –</salute>
                <p rendition="#inline">Ich <ref target="letter.20019">telegrafierte</ref> Ihnen am
                        <date when="1927-12-19">19. XII</date>:</p>
                <p>„Erbitte 1000 Mark Vorschuss auf Halbjahres<g ref="#typoHyphen"/>
                    <lb break="no"/>abrechnung oder Barrückzahlung <date when="1928-02">Februar</date>“</p>
                <p>Auf dieses Telegramm haben Sie mir <lb/>keine Antwort gegeben.</p>
                <p>Ich begnüge mich damit, das zu konstatieren <lb/>und werde mein weiteres
                    Verhalten darauf ein<g ref="#typoHyphen"/>
                    <lb break="no"/>richten. </p>
                <closer>
                    <signed rendition="#c">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
