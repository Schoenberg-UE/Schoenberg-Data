    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>rp 1.46 = <persName key="pers.3263">schoenberg</persName>
                            pension</addrLine>
                        <addrLine>bavaria <placeName key="place.2.3.1.5">steinplatz 2</placeName>
                            charlottenburg =</addrLine>
                    </address>
                </opener>
                <p>stellen ihnen gewuenschte tausend mark bereitwilligst zur <lb/>verfuegung jedoch
                    bis zur ordnung schwebender divergenzen auf <lb/>konto neuer werke im anschluss
                    auf fr<choice>
                        <sic>l</sic>
                        <corr cert="high">u</corr>
                    </choice>eher zugesagte zahlungen <lb/>betrag wird bei zustandegekommener
                    verstaendigung altes <choice>
                        <sic>r</sic>
                        <corr cert="high">k</corr>
                    </choice>onto <lb/>uebertragen erbitte<choice>
                        <sic>e</sic>
                        <corr type="deleted"/>
                    </choice> dr<choice>
                        <sic>e</sic>
                        <corr cert="high">a</corr>
                    </choice>htzustimmung</p>
                <closer rendition="#inline">
                    <address>
                        <addrLine>= <rs type="org" key="org.1">musikedition wien</rs>.+</addrLine>
                    </address>
                </closer>
                <pb n="2" xml:id="p.2"/>
                <note hand="#addressee">Umgekehrt <subst>
                        <del rendition="#ow">einverstanden 1000 auf alte Werke</del>
                        <add place="across">1000 auf alte Werke einverstanden</add>
                    </subst>
                    <del rendition="#s">
                        <gap reason="illegible" quantity="1" unit="words"/>
                    </del>
                    <lb/>
                    <subst>
                        <del rendition="#s">erst</del>
                        <add place="superlinear">jedoch</add>
                    </subst>
                    <add place="sublinear">auf neue zu übertragen</add>
                    <del rendition="#s">bar</del>
                    <del rendition="#s">übertragbar auf</del> wenn <add place="superlinear">wir
                        im</add>
                    <add place="sublinear">im Sommer</add>
                    <subst>
                        <del rendition="#s">keine Einigung</del>
                        <add place="sublinear">nicht einigen</add>
                    </subst>
                </note>
            </div>
        </body>
