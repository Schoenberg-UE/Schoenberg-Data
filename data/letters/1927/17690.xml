    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.26">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/> I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>.
                        <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition, Wien. A. B. C. Code
                            5<hi rendition="#sup">th</hi> Ed. Mosse Code.<lb/>Telefon N<hi rendition="#sup #uu">o</hi>.57-5-85 Serie. Bank-Konto: <orgName key="org.199">Zentral-Europä-<lb/>ische Länderbank Wien</orgName>.
                        Postsparkassen-Kto. 57557.</stamp>
                    <persName key="pers.3067">R</persName>/<persName key="pers.4362">M.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1927-04-06">6. April
                        1927</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">
                                <placeName key="place.2.3.1">BERLIN-CHARLOTTENBURG</placeName>.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir erhielten <add place="superlinear">
                        <hi rendition="#u">im Laufe des letzten Jahres</hi>
                    </add> von verschiedenen Seiten aus <placeName key="place.15">Amerika</placeName>
                    <lb/>Anfragen wegen einer Aufführung Ihrer „<hi rendition="#u">
                        <bibl sameAs="werke.16">GURRELIEDER</bibl>
                    </hi>“. Sie hat<g ref="#typoHyphen"/>
                    <lb break="no"/>ten seinerzeit den Wunsch geäussert, eine solche amerikanische
                    <lb/>Aufführung selbst zu dirigieren. Nachdem inzwischen sehr viel <lb/>Zeit
                    vergangen ist, möchten wir, bevor wir nach <placeName key="place.15">Amerika</placeName> ant<g ref="#typoHyphen"/>
                    <lb break="no"/>worten, bei Ihnen anfragen, ob Sie diesen Wunsch noch immer
                    <lb/>haben oder ob Sie eventuell auch mit der <seg type="comment">
                        <orig>Aufführung</orig>
                        <note sameAs="letter.17657/#nufj_b52_3gc"/>
                    </seg> dieses <lb/>Werkes unter einem anderen Dirigenten <add place="intralinear">
                        <metamark/>
                    </add>
                    <note place="mBottom">
                        <metamark/> im letzten Falle handelt <lb/>es sich um <persName key="pers.2932">Reiner</persName> in <placeName key="place.15.19">Cin<g ref="#typoHyphen"/>
                            <lb break="no"/>cinnati</placeName>-</note> einverstanden wären.</p>
                <closer> Wir wären Ihnen für gefällige Rückäusserung hierüber <lb/>sehr verbunden und <salute>empfehlen uns <lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">pp <persName key="pers.3067">Rothe</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
