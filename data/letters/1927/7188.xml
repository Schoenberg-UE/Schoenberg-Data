    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <stamp sameAs="stamp.166">
                    <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                    <lb/>PROFESSOR AN DER
                        <orgName key="org.197">AKADEMIE DER KÜNSTE ZU BERLIN</orgName>
                </stamp>
                <pb n="2" xml:id="p.2"/>
                <note place="mTop" hand="#unknown">Erl. 17 XI. 27</note>
                <salute>P. T. <orgName key="org.1">UE</orgName>.</salute>
                <p rendition="#inline">bitte freundl. sofort express <lb/>an Frau <persName key="pers.1105">Marya Freund</persName>, Paris XVI. <lb/>
                    <placeName key="place.4.4.7.1">4 Rue Mission Marchand</placeName> je ein
                    <lb/>Exemplar meiner Aufsätze <list>
                        <item>1. <seg type="comment">
                                <orig>Jahrbuch</orig>
                                <note sameAs="letter.21789/#ncdh_l15_qwb"/>
                            </seg>: „<bibl sameAs="schriften.41">Gesinnung
                                oder Gewissen</bibl>“ <add place="superlinear" hand="#unknown">Erkenntnis</add>
                        </item>
                        <item>2. <orgName key="org.191">Pult u. Tktst.</orgName> „<bibl sameAs="schriften.42">Mechanische Musik<g ref="#typoHyphen"/>
                                <lb break="no"/>instrumente</bibl>“</item>
                    </list> zu senden.</p>
                <closer rendition="#inline">
                    <salute>Besten Dank</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <hi rendition="#u">NB</hi> In <placeName key="place.4.4">Paris</placeName>
                        mache ich <seg type="comment">
                            <orig>
                                <bibl sameAs="werke.22">Waldtaube</bibl>
                                <lb/>in reducierter Instrumentation</orig>
                            <note xml:id="nikx_vwb_kzb" resp="#pkehrer">Aus Arnold Schönberg an
                                Marya Freund, 1. November 1927 (<ref
                                    target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B013905"
                                    >ASCC 1390</ref>), geht hervor, dass damit die Fassung für
                                Kammerorchester gemeint ist</note>
                        </seg>. Haben Sie Orch-Material <lb/>
                        <seg rendition="#r">her geschickt??</seg>
                    </p>
                </postscript>
            </div>
        </body>
    </text>
