    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.20">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>PROFESSOR AN DER <orgName key="org.197">AKADEMIE DER KÜNSTE ZU
                            BERLIN</orgName>
                    </stamp>
                    <address>
                        <addrLine>CANNES</addrLine>
                        <addrLine>
                            <placeName key="place.4.7.1">Californie Palace</placeName>
                        </addrLine>
                    </address>
                    <dateline>
                        <date when="1927-12-26">26<choice>
                                <sic>!</sic>
                                <corr cert="high">.</corr>
                            </choice>XII.1927</date>
                    </dateline>
                </opener>
                <salute>PT <orgName key="org.1">UE</orgName>,</salute>
                <p rendition="#inline"> eben genötigt, Zahlungen mittelst <orgName key="org.126">Postsparkasse</orgName>
                    <lb/>zu leisten, fällt mir ein, dass ich bis jetzt keine <lb/>Verständigung
                    darüber erhalten habe, ob die gewisse <lb/>500 Mark-Zahlung von Ihnen auf mein
                        Postsparkassen-<lb break="no"/>Konto in diesem Monat schon erfolgt ist.</p>
                <p>Darf ich Sie eventuell bitten, die Zahlung auf dem <lb/>raschesten Weg zu
                    leisten, damit die Auszahlung <lb/>meiner Scheks keine Verzögerung erleidet?</p>
                <closer>
                    <salute>Mit besten Neujahrswünschen, Ihr</salute>
                    <lb/>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <note place="right" hand="#unknown">
                    <date when="1927-12-22">22. XII</date>
                    <!-- steno -->
                    <hi rendition="#st">Überweisung</hi> S 840.- M 500.–</note>
            </div>
        </body>
