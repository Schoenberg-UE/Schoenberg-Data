    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.47">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName>
                        <seg hand="#author">A. G.</seg>
                        <lb/>WIEN I·<placeName key="place.9.11.6.12">KARLSPLATZ
                        6</placeName>·MUSIKVEREINSGEBÄUDE·TELEFON U 47-5-85<lb/>TELEGRAMME:
                        MUSIKEDITION WIEN</stamp>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, den <date when="1951-07-10">10. Juli 1951</date>
                    </dateline>
                    <seg rendition="#r">
                        <persName key="pers.3263">H</persName>/<persName key="pers.3067">R</persName>
                    </seg>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schoenberg</persName>
                        </addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 N. Rockingham Ave.</placeName>
                        </addrLine>
                        <addrLine>
                            <hi rendition="#u">Los Angeles 49, California</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>,</salute>
                <p>Ihr <ref target="letter.7449">Brief</ref> an Herrn <persName key="pers.3204">Schlee</persName> vom <date when="1951-07-03">3. Juli</date> trifft soeben
                    hier <lb/>ein. Wir versuchen, Herrn <persName key="pers.3204">Schlee</persName>
                    auf seiner Urlaubsreise zu <lb/>erreichen und bitten Sie, sich noch einige Tage
                    gedulden zu <lb/>wollen, bis eine Antwort erfolgen kann.</p>
                <closer>
                    <salute>Mit besten Empfehlungen<lb/>
                        <seg rendition="#r">hochachtungsvoll</seg>
                    </salute>
                    <lb/>
                    <signed rendition="#r">i. V. Dr.
                            <gap reason="illegible" unit="words" quantity="1"/>
                    </signed>
                    <lb/>
                    <seg rendition="#r">
                        <orgName key="org.1">UNIVERSAL-EDITION A.G.</orgName>
                    </seg>
                </closer>
            </div>
        </body>
