    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <persName key="pers.1520">Hei</persName>/<persName key="pers.4351">Fi.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, am <date when="1936-07-06">6. Juli 1936</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold <hi rendition="#g">Schoenberg</hi>
                            </persName>,</addrLine>
                        <addrLine>
                            <placeName key="place.15.7.3.1">116 N. Rockingham
                            Ave.</placeName>,</addrLine>
                        <addrLine>Brentwood Park</addrLine>
                        <addrLine>
                            <hi rendition="#uda">Los Angeles – Calif.</hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter <rs type="person" key="pers.3263">Meister</rs>!</salute>
                <p>Wir bitten Sie um die Freundlichkeit die beiliegen<g ref="#typoHyphen"/>
                    <lb break="no"/>den beiden Formulare<!-- nicht nachweisbar --> für die
                        <placeName key="place.4.4">Pariser</placeName>
                    <orgName key="org.156">Societe des Auteurs</orgName>, welche <lb/>sich auf das
                    Tantiemeninkasso für die „<bibl sameAs="werke.7">Erwartung</bibl>“ in <placeName
                        key="place.16.1">Brüssel</placeName>
                    <lb/>beziehen, zu unterschreiben und zwar in jener Spalte, wo Herr <persName
                        key="pers.4127">
                        <lb/>Weterings</persName>, der Übersetzer, bereits seinen Namen
                    hingeschrieben <lb/>hat. Wir bitten Sie um die Freundlichkeit, uns die Formulare
                    <lb/>dann wieder zurückzusenden und zeichnen</p>
                <closer rendition="#r">
                    <salute>mit vorzüglicher Hochachtung</salute>
                </closer>
            </div>
        </body>
    </text>
