    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.82">
                        <orgName key="org.180">VERLAG<lb/>DREILILIEN</orgName>
                        <lb/>Halensee-Berlin<lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Strasse 22</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold <lb/>Schönberg</persName>
                        </addrLine>
                        <addrLine>Wien IX</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.1.2">Liechtensteinstr.
                                <lb/>68/70</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>L. H. <persName key="pers.3263">Sch.</persName>
                </salute>
                <p rendition="#inline">Ihre <lb/>
                    <bibl sameAs="werke.41">Lieder</bibl> sind ein<g ref="#typoHyphen"/>
                    <lb break="no"/>getroffen. Leichter <lb/>zugänglich
                    – ? – o <lb/>Irrtum. Ich habe <lb/>überhaupt noch keinen <lb/>Zugang
                    entdeckt, nicht <lb/>mal einen schweren. Wei<g ref="#typoHyphen"/>
                    <lb break="no"/>teres <ref target="letter.12377">brieflich</ref>. </p>
                <closer rendition="#c">
                    <salute>Mit besten Grüssen</salute>
                    <lb/>Ihres <signed>
                        <persName key="pers.2283">M M.</persName>
                    </signed>
                    <lb/>
                    <stamp sameAs="stamp.111" rendition="#l">Halensee-Berlin, den <date when="1903-05-26">
                            <seg hand="#author">23.11. 03</seg>
                        </date>
                        <lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Str.
                        22.</placeName>
                    </stamp>
                </closer>
            </div>
        </body>
