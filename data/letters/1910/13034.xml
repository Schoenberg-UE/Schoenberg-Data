    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <note place="left" hand="#unknown">13/1 nicht bekannt<lb/>Schema nicht <gap reason="illegible" unit="words" quantity="1"/>
                        <lb/>zurück<lb/>
                        <placeName key="place.2.4.1">Halensee</placeName></note>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>
                            <del rendition="#s" hand="#unknown">Wien XIII</del>
                        </addrLine>
                        <addrLine>
                            <del rendition="#s" hand="#unknown">
                                <placeName key="place.9.11.5.3">Hietzinger
                                    Hauptstraße 11<supplied cert="high">3</supplied>
                                </placeName>
                            </del>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>L. H. <persName key="pers.3263">Sch.</persName>
                </salute>
                <p rendition="#inline">Entschuldigen <lb/>Sie! Ich bin in Not jetzt <lb/>noch
                    unhöflicher als sonst. <lb/>Ein Umzug mit allerlei <lb/>Schwierigkeiten hat mich
                    <lb/>ganz aus dem Balance<g ref="#typoHyphen"/>
                    <lb break="no"/>ment gebracht. Die <seg type="comment">
                        <orig>Stimmen</orig>
                        <note xml:id="nskz_gbk_bvb">
                            <p>
                                <bibl sameAs="werke.5">Arnold Schönberg, Pelleas und Melisande op.
                                    5</bibl>
                            </p>
                            <p>Handschriftliches Stimmenmaterial der Uraufführung, teilweise
                                autograph, verschollen (<ref target="https://bit.ly/3RyXHSa">ASGA B
                                    10, Quelle E*</ref>)</p></note>
                    </seg>
                    <lb/>können Sie kriegen, wofern <lb/>sie <persName key="pers.1112">Fried</persName> der sie, glaube ich <lb/>hat, nicht bald gebraucht.
                    <lb/>Ueber Ihre Rückerwerbungs<g ref="#typoHyphen"/>
                    <lb break="no"/>wünsche werde ich mich dem<g ref="#typoHyphen"/>
                    <lb break="no"/>nächst äussern. Bitte meine <lb/>neue Adresse zu vermerken.
                    <lb/>Halensee, <placeName key="place.2.4.1.2">Halberstädterstr. 6</placeName>
                </p>
                <closer rendition="#c">
                    <salute>Besten Gruss</salute> Ihr <signed>
                        <persName key="pers.2283">Max <lb/>Marschalk</persName>
                    </signed>
                    <dateline>
                        <date when="1910-09-29">29.9.10</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
