    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>Herrn Prof. </addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Wien XIII</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.5.3">Hietzinger Hauptstraße
                                <lb/>113</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>L. H. <persName key="pers.3263">Sch.</persName>
                </salute>
                <p>
                    <persName key="pers.1112">Fried</persName> beginnt mit den <seg type="comment">
                        <orig>Proben</orig>
                        <note xml:id="noyr_h4d_ddc" resp="#KBleier">
                            <p>Zu <ref target="event.8"/>
                            </p>
                            <p><persName key="pers.1112">Oskar Fried</persName> berichtet von einer
                                Gesamtprobe und weiteren Probenterminen (Oskar Fried an Arnold
                                Schönberg, 12. Oktober 1910; <ref
                                    target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B208752"
                                    >ASCC 20975</ref>)</p></note>
                    </seg>
                    <lb/>und kann die <seg type="comment">
                        <orig>Stimmen</orig>
                        <note sameAs="letter.13034/#nskz_gbk_bvb"/>
                    </seg>
                    <lb/>nicht entbehren.</p>
                <closer rendition="#c">
                    <salute>Besten Gruss</salute>
                    <lb/>Ihr <signed>
                        <persName key="pers.2283">M. M.</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1910-09-30">30.9.10</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
