    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.52">
                        <orgName key="org.180">VERLAG<lb/>DREILILIEN</orgName>
                        <lb/>Halensee-Berlin<lb/>
                        <placeName key="place.2.4.1.1">Georg Wilhelm-Str. 22</placeName>
                        <lb/>den <date when="1910-05-11">
                            <seg hand="#author">11. Mai.10.</seg>
                            190</date>
                    </stamp>
                    <address>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#u">Wien</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.9.11.1.2">Liechtensteinstr.
                                68/70.</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute rendition="#c">Lieber Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>In Beantwortung Ihres <ref target="letter.582">Briefes</ref> vom <date when="1910-04-24">24. April</date> teile ich Ihnen mit, <lb/>dass Herr
                        <persName key="pers.2367">Messner</persName> auf Ihren Vorschlag nicht eingehen
                    will: er nimmt <lb/>an, dass Sie ausserdem Ihre alte Schuld verrechnet haben
                    wollen.</p>
                <closer rendition="#c">
                    <salute>Mit besten Grüssen</salute>
                    <lb/>Ihr <signed>
                        <persName key="pers.2283">Max
                    Marschalk</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
