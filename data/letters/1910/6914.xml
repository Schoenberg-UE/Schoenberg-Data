    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII.<lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER HAUPTSTRASSE
                        113</placeName>
                    </stamp>
                </opener>
                <salute>Lieber Herr Direktor <persName key="pers.1538">Herzka</persName>, </salute>
                <p rendition="#inline">ich höre nichts <lb/>mehr von Ihnen!</p>
                <list>
                    <item>I. Was ist mit dem <orgName key="org.184">Volksopern</orgName>
                        <seg type="comment">
                            <orig>Vertrag</orig>
                            <note xml:id="nrdp_234_jdc" resp="#KBleier">Bezüglich <bibl
                                    sameAs="werke.7"> Arnold Schönberg, Erwartung op. 17</bibl>; es
                                kam keine Aufführung an der <orgName key="org.184"
                                    >Volksoper</orgName> in <placeName key="place.9.11"
                                    >Wien</placeName> zustande</note>
                        </seg>? <lb/>(Bitte machen Sie den schleunigst!!)</item>
                    <item>II. Was ist mit <bibl sameAs="werke.2">Kammersinf</bibl>.-Part-Druck</item>
                    <item>III. <seg type="comment">
                            <orig>Wann kommen <bibl sameAs="werke.9">Klavier-Stücke</bibl>
                            </orig>
                            <note xml:id="nlzt_d3b_tcc" resp="#KBleier">Lieferdatum: <date when="1910-10-07">7. Oktober 1910</date>, Auflage: 500 (<rs type="bibl" key="zotero-4528359-LQMNNW3Y">Buchon 2015</rs>, Bd.
                                5, S. 667)</note>
                        </seg>
                    </item>
                    <item>IV. <ellipsis>
                            <metamark function="ellipsis">〃 〃</metamark>
                            <supplied>Wann kommen </supplied>
                        </ellipsis>
                        <seg type="comment">
                            <orig>
                                <bibl sameAs="werke.47">Orchester</bibl>
                                <ellipsis>
                                    <metamark function="ellipsis">〃</metamark>
                                    <supplied>Stücke</supplied>
                                </ellipsis>
                            </orig>
                            <note xml:id="nqqm_sdg_q2c" resp="#KBleier">Publikation im Verlag
                                    <orgName key="org.43">C. F. Peters</orgName> Anfang <date when="1912-04">April 1912</date>, Auflage: 50; gleichzeitig
                                erschien eine Studienpartitur, Auflage: 200 (<rs type="bibl" key="zotero-4528359-KJUPSPQ5">ASGA B 12</rs>, S. 8; <rs type="bibl" key="zotero-4528359-JPEJQXBG">Giering 2025</rs>, S.
                                54)</note>
                        </seg>
                    </item>
                    <item>V <ellipsis>
                            <metamark function="ellipsis">〃</metamark>
                            <supplied>Wann</supplied>
                        </ellipsis> entscheiden Sie sich über die <lb/>
                        <bibl sameAs="schriften.1">Harmonielehre</bibl>?</item>
                    <item>VI. Wurden die <bibl sameAs="werke.26">Streichquartett</bibl>-Stimmen
                        <lb/>nach <placeName key="place.14.1">Budapest</placeName> an <orgName
                            key="org.145">Rozsavölgyi</orgName>
                        <seg type="comment">
                            <orig>geschickt</orig>
                            <note xml:id="nmkz_zrs_ncc" resp="#KBleier">Empfangsbestätigung:
                                Rózsavölgyi &amp; Co an Arnold Schönberg, 10. September 1910 (<ref
                                    target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B217166"
                                    >ASCC 21716</ref>)</note>
                        </seg>?</item>
                    <item>VII. Was ist mit <persName key="pers.1804">Karbach</persName>?</item>
                    <item>VIII. <ellipsis>
                            <metamark function="ellipsis">〃 〃</metamark>
                            <supplied>Was ist mit</supplied>
                        </ellipsis>
                        <placeName key="place.13.1">Prag</placeName>?</item>
                    <item>IX. <ellipsis>
                            <metamark function="ellipsis">〃 〃 〃</metamark>
                            <supplied>Was ist mit</supplied>
                        </ellipsis> den <bibl sameAs="werke.11">Orchesterlieder</bibl>-Stimmen?</item>
                    <pb n="2" xml:id="p.2"/>
                    <item>X. Was ist mit der Copie <lb/>des <bibl sameAs="werke.17">Gurre-Lieder</bibl>
                            Clav. Auszuges
                        <lb/>II. Theil?</item>
                </list>
                <p>Bitte um Antwort.</p>
                <closer>
                    <salute>Ergebenst und herzlichst Gruß </salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
