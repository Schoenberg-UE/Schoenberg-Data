    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII.<lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER HAUPTSTRASSE 113</placeName>
                    </stamp>
                    <dateline>
                        <date when="1910-12-27">27/12. 1910</date>
                    </dateline>
                </opener>
                <salute>Lieber Herr Direktor <persName key="pers.1538">Herzka</persName>, </salute>
                <p rendition="#inline">bitte veranlassen <lb/>Sie sofort die Absendung von <list>
                        <item>
                            <bibl sameAs="werke.9">op 11 Klavierstücken</bibl>
                        </item>
                        <item>
                            <bibl sameAs="werke.26">op 10 Streichquartett Fis moll</bibl>
                        </item>
                    </list>
                    <seg type="comment">
                        <orig>an <persName key="pers.2208">R. Louis</persName>
                        </orig>
                        <note xml:id="nu35_skt_ncc" resp="#KBleier">
                            <persName key="pers.2208">Rudolf Louis</persName> erbat die Partituren
                            als Rezensent der Münchner Neuesten Nachrichten zur Vorbereitung auf
                                <ref target="event.27"/> (Rudolf Louis an Arnold Schönberg, 25.
                            Dezember 1910; <ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B213425">ASCC
                                21342</ref>; <rs type="bibl" key="zotero-4528359-KWZ4CGK2">Louis
                                1911</rs>)</note></seg></p>
                <milestone unit="section" rendition="#hr"/>
                <p>
                    <persName key="pers.4001">Webern</persName> hat irrtümlicherweise seine <lb/>
                    <seg type="comment">
                        <orig>Korrekturen</orig>
                        <note xml:id="nenm_qlh_tcc" resp="#KBleier">Zu <bibl sameAs="werke.11"
                                >Arnold Schönberg, Sechs Lieder für Gesang und Orchester op.
                                8</bibl> (Anton Webern an Arnold Schönberg, 4. Dezember 1910; <ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B218406">ASCC
                                21840</ref>; Anton Webern an Arnold Schönberg, 24. Dezember 1910;
                                <ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B218419"
                                >ASCC 21841</ref>)</note>
                    </seg> an Sie geschickt (statt an mich!) <lb/>Die müssen Sie mir schicken, denn
                    ich trage <lb/>seine Ausbesserungen in mein Exemplar ein <lb/>und sehe nach, ob
                    er nicht etwas ausgebessert hat, <lb/>das ich verändert haben will.</p>
                <closer>
                    <salute>Herzl Gruß </salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
