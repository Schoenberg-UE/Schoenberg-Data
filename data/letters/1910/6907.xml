    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII.<lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER HAUPTSTRASSE
                        113</placeName>
                    </stamp>
                </opener>
                <lb/>
                <salute>Verehrter Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">ich habe die <lb/>
                    <supplied cert="high">St</supplied>immen
                    meines <bibl sameAs="werke.26">Quartettes</bibl> zur Anfertigung <lb/>von zwei
                    Abschriften einem Schreiber überge<g ref="#typoHyphen"/>
                    <lb break="no"/>ben und
                    ihm 20 Heller für die Seite <lb/>zugesagt. Das ist nicht viel, denn er kann
                    <lb/>kaum mehr als zwei Seiten in der <lb/>Stunde schreiben; das machen die
                    Stichworte <lb/>in den beiden letzten Sätzen. Diese Stimme <lb/>wird dadurch
                    komplicierter als ein <lb/>Klaviersatz und hat <hi rendition="#uu">20!</hi>
                    Zeilen auf der <lb/>
                    <supplied cert="high">Se</supplied>ite!! Sie sind doch
                    hoffentlich damit <lb/>einverstanden.</p>
                <p>Ich werde ihn dann mit der Rechnung zu <lb/>Ihnen schicken.</p>
                <p>Sind Sie mit dem <add place="superlinear">Maschin-</add><hi rendition="#u"><seg type="comment"><orig>Schreiber</orig><note sameAs="letter.6904/#nlcc_cb5_zfc"/></seg></hi> einverstanden?</p>
                <closer rendition="#c">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
