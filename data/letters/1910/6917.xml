    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.124">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                    </stamp>
                </opener>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>, </salute>
                <p rendition="#inline"> bitte wollen Sie <lb/>Herrn <persName key="pers.2817"
                        >Polnauer</persName> (<seg type="comment">
                        <orig>Hörer</orig>
                        <note xml:id="ne2n_wsx_1gc" resp="#TMuxeneder">Schüler <persName
                                key="pers.3263">Schönbergs</persName>, die in zeitlichem Umfeld am
                                <orgName key="org.117">Musikhistorischen Institut </orgName>der
                                <orgName key="org.293">Universität Wien </orgName>bei <persName
                                key="pers.51">Guido Adler</persName> studierten: <persName
                                key="pers.1640">Karl Horwitz</persName>, <persName key="pers.1694"
                                >Zdzisław Jachimecki</persName>, <persName key="pers.1702">Heinrich
                                Jalowetz</persName>, <persName key="pers.2065">Viktor
                                Krüger</persName>, <persName key="pers.2817">Josef
                                Polnauer</persName>, <persName key="pers.4001">Anton
                                Webern</persName>, <persName key="pers.4098">Egon
                            Wellesz</persName></note>
                    </seg> des Prof <persName key="pers.51">Adler</persName>) für <lb/>das <hi
                        rendition="#u">
                        <orgName key="org.117"> Musikhistorische Institut</orgName>
                    </hi> ein Exemplar <lb/>der <bibl sameAs="werke.9">Klavierstücke</bibl> und ein
                    Exemplar des <lb/>
                    <bibl sameAs="werke.26">Quartetts op 10</bibl>
                    <choice>
                        <sic>zu</sic>
                        <corr type="deleted"/>
                    </choice> „spenden“.</p>
                <closer rendition="#inline">
                    <salute>Herzl Gruß</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
