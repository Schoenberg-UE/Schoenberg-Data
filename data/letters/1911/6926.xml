    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII.<lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER HAUPTSTRASSE
                        113</placeName>
                    </stamp>
                    <address>
                        <addrLine>Herrn Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.24">Wipplingerstr. 32</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Geehrter Herr <rs type="person" key="pers.1538">Direktor</rs>, </salute>
                <p rendition="#inline">Bitte: <list>
                        <item>I. ist die <bibl sameAs="werke.5">Pelleas</bibl>
                            <seg type="comment">
                                <orig>Partitur</orig>
                                <note sameAs="letter.12379/#neg4_pby_b5b"/>
                            </seg> von <persName key="pers.1112">Fried</persName> schon gekommen?</item>
                        <item>II. ist die Kopie des <bibl sameAs="werke.17">Gurre-Lieder</bibl>
                            Clavier Auszugs schon <lb/>fertig? Ich brauche die dringendst. <note place="mBottom" hand="#addressee">
                                <hi rendition="#u">erl</hi>
                            </note>
                        </item>
                    </list>
                </p>
                <closer>
                    <salute>Ergebenst</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
