    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII.<lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER HAUPTSTRASSE
                        113</placeName>
                    </stamp>
                </opener>
                <salute>P. T.</salute>
                <p rendition="#inline">Ich habe express an Herrn <persName key="pers.1112">Fried</persName>
                    <lb/>geschickt:</p>
                <list rendition="#inline">
                    <item>1) Clav. Auszug <bibl sameAs="werke.17">Gurre Lieder</bibl>
                        <lb/>unvollständig!!!</item>
                    <item>2) <seg type="comment">
                            <orig>Partitur</orig>
                            <note xml:id="nmsr_hmg_q2c" resp="#KBleier">Partiturreinschrift, autograph (<ref target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=616&amp;werke_id=228&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke">ASGA B 12, Quelle B</ref>)</note>
                        </seg>
                        <bibl sameAs="werke.47">Orchesterstücke</bibl>
                    </item>
                    <item>3.) Klavier Auszug <bibl sameAs="werke.70">Kammersinfonie</bibl>.</item>
                </list>
                <milestone unit="section" rendition="#hr"/>
                <p>Bitte sofort per <hi rendition="#uu">express</hi>
                    <lb/>zu schicken:</p>
                <table rows="6" cols="2">
                    <row>
                        <cell>1. <hi rendition="#u">Partitur</hi>
                        </cell>
                        <cell rows="2">
                            <bibl sameAs="werke.2">Kammersinfo</bibl>
                        </cell>
                    </row>
                    <row>
                        <cell>2. <hi rendition="#u">Stimmen</hi>
                        </cell>
                    </row>
                    <milestone unit="section" rendition="#hr"/>
                    <row>
                        <cell>3. <bibl sameAs="werke.12">Orchesterlieder</bibl>
                        </cell>
                        <cell>(6) Klavier Ausz</cell>
                    </row>
                    <row>
                        <cell>
                            <ellipsis>
                                <metamark function="ellipsis">〃</metamark>
                                <supplied>
                                    <bibl sameAs="werke.11">Orchesterlieder</bibl>
                                </supplied>
                            </ellipsis>
                        </cell>
                        <cell>(6) Partituren</cell>
                    </row>
                    <row>
                        <cell>4. (womöglich!)</cell>
                        <cell>Fortsetzung <bibl sameAs="werke.17">Gurre
                                Lieder</bibl>
                        </cell>
                    </row>
                </table>
                <p>aber ohne dadurch Pakett zu <lb/>verzögern!</p>
                <p>Ferner sofort <add place="superlinear">dem <hi rendition="#uu">
                            <persName key="pers.1112">Fried</persName>
                        </hi>
                    </add> telegrafieren<pb n="2" xml:id="p.2"/>ob er in <placeName key="place.2.3">Berlin</placeName> die <bibl sameAs="werke.47">Orchesterstücke</bibl> <lb/><seg type="comment">
                        <orig>kopieren</orig>
                        <note xml:id="nkwz_llg_q2c" resp="#KBleier">Oskar Fried an Universal-Edition, 27. April 1911 (<ref target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B208804">ASCC
                                20880</ref>)</note>
                    </seg> lassen soll. Auf Kosten <lb/>der <orgName key="org.1">Universal Edition</orgName>!</p>
                <p>Das dürfte schätzungsweise <lb/>höchstens 40–45 Mark kosten
                    <lb/>(wahrscheinlich weniger!)</p>
                <p>Waere im Interesse meiner <lb/>Werke dringend nötig!</p>
                <closer>
                    <salute rendition="#c">Hochachtungsvoll</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
                <postscript>
                    <p>
                        <ref target="document.20878">Karte</ref> von <persName key="pers.1112">Fried</persName>
                        wünsche <lb/>zurück.</p>
                </postscript>
            </div>
        </body>
