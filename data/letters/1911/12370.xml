    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.83">
                        <subst>
                            <del rendition="#s">
                                <orgName key="org.194">Verlag Helianthus</orgName>
                            </del>
                            <add place="superlinear">
                                <stamp sameAs="stamp.50">
                                    <orgName key="org.180">VERLAG DREILILIEN</orgName>.</stamp>
                            </add>
                        </subst>, Berlin <lb/>
                        <placeName key="place.2.4.1">Berlin-Halensee</placeName>.</stamp>
                    <address>
                        <addrLine>Herrn Professor</addrLine>
                        <addrLine>
                            <persName key="pers.3263">Arnold Schönberg</persName>
                        </addrLine>
                        <addrLine>Zehlendorf-Wannseebahn</addrLine>
                        <addrLine>Machnower Chaussee „<placeName key="place.2.38.2">Villa
                                Lepcke</placeName>“.</addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener>
                    <address>
                        <addrLine>Herrn Professor <persName key="pers.3263">Arnold
                            Schönberg</persName>
                        </addrLine>
                        <addrLine rendition="#r">z. Z. <placeName key="place.2.38.2">Zehlendorf</placeName>
                        </addrLine>
                    </address>
                </opener>
                <salute rendition="#c">Sehr geehrter Herr <rs type="person" key="pers.3263">Professor</rs>!</salute>
                <p>Wir teilen Ihnen höflichst mit, dass <lb/>wir Ihre Lieder heut an Frau <persName key="pers.4247">Luise Wolff</persName>
                    <lb/>abgesandt haben.</p>
                <closer rendition="#r">
                    <salute>Hochachtungsvoll</salute>
                    <lb/>per <stamp sameAs="stamp.50">
                        <orgName key="org.180">VERLAG DREILILIEN</orgName>.</stamp>
                    <lb/>
                    <signed>
                        <persName key="pers.4222">W.</persName>
                    </signed>
                    <stamp sameAs="stamp.109" rendition="#l">
                        <placeName key="place.2.4.1">Berlin-Halensee</placeName>, den <date when="1911-11-06">
                            <seg hand="#author">6. 11. </seg>19<subst>
                                <del rendition="#ow">0</del>
                                <add place="across">1</add>
                            </subst>
                            <seg hand="#author">1.</seg>
                        </date>
                    </stamp>
                </closer>
            </div>
