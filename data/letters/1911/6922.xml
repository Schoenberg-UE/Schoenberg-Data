    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII.<lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER HAUPTSTRASSE
                        113</placeName>
                    </stamp>
                    <address>
                        <addrLine>Herrn Direktor </addrLine>
                        <addrLine>
                            <persName key="pers.1538">
                                <hi rendition="#u">Emil
                                Herzka</hi>
                            </persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.24">Wipplingerstr 32</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Geehrter Herr <rs type="person" key="pers.1538">Direktor</rs>, </salute>
                <p rendition="#inline">ich brauche dringend eine Kopie <lb/>der ersten paar Seiten
                    meiner <bibl sameAs="schriften.1">Harmonielehre</bibl>. Nur <lb/>von dem
                    „Vorrede“ überschriebenen Kapitel. Ich <lb/>glaube das sind <hi rendition="#u">8</hi> Seiten. Ich bin eben an der Ar<g ref="#typoHyphen"/>
                    <lb break="no"/>beit und muss das einstweilen zurücklassen. Also bitte: <lb/>so
                    rasch, wie möglich.</p>
                <p>Es sind in dem bei Ihnen liegenden Exemplar viele <lb/>Fehler drin, die
                    unbegreiflich scheinen. Bitte aber alles <lb/>so schreiben zu lassen, wie es
                    dort steht. Ich werde schon selbst <lb/>enträtseln, welches der wahre Sinn
                    ist.</p>
                <closer rendition="#inline">
                    <salute>Bester Gruß</salute>
                    <signed rendition="#r">
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
                <dateline rendition="#l">
                    <date when="1911-01-18">
                        <supplied cert="high">1</supplied>8/1. 1911</date>
                </dateline>
            </div>
        </body>
