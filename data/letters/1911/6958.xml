    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.6">
                        <persName key="pers.3263">Arnold Schönberg</persName>,
                        Berlin-Zehlendorf-Wannseebahn <lb/> Machnower Chaussee, <placeName key="place.2.38.2">Villa Lepcke</placeName>. </stamp>
                    <address>
                        <addrLine>Herr Direktor <persName key="pers.1538">Emil Herzka</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal-Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.18">Reichsratsstraße 9</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute> Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>, </salute>
                <p rendition="#inline">bitte schicken Sie an</p>
                <p>
                    <persName key="pers.4230">
                        <supplied cert="high">Er</supplied>ich Wolff</persName>, Komponist, Berlin
                    Wilmersdorf, <placeName key="place.2.4.5">Landhausstr. 53</placeName></p>
                <table>
                    <row>
                        <cell>2 <del rendition="#s">
                                <gap reason="illegible" quantity="1" unit="chars"/>
                            </del> Exemplare meiner <bibl sameAs="werke.9">Klavierstücke op 11</bibl>. und <note place="inline" hand="#addressee">2911</note>
                        </cell>
                        <cell rows="2">frei!</cell>
                    </row>
                    <row>
                        <cell>1 <ellipsis>
                                <metamark function="ellipsis">〃</metamark>
                                <supplied>Exemplare meiner</supplied>
                            </ellipsis>
                            <bibl sameAs="werke.11">Orchesterlieder op 8</bibl>
                            <note place="inline" hand="#addressee">3041/6</note>
                        </cell>
                    </row>
                </table>
                <p rendition="#c">
                    <del rendition="#s">ebenso</del> ferner <note place="across" hand="#addressee">ges.</note>(frei) an</p>
                <p>Herrn <persName key="pers.1302">Georg Gräner</persName>, Berlin N, <placeName key="place.2.3.5.2">Bernholm Str. 87</placeName>, Musikschriftsteller
                    <lb/>(Sie haben wohl dessen <bibl sameAs="schriften.109">Artikel</bibl> in <seg type="comment">
                        <orig>Pan</orig>
                        <note xml:id="nm4z_1xg_cbc" resp="#pkehrer">
                            <rs type="bibl" key="zotero-4528359-P27VJU7T">Pan 1911b</rs>;
                            Exemplar aus dem Schönberg-Nachlass (<ref target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=1143&amp;action=view&amp;sortieren=lastChanged%20DESC&amp;vonBis=0-19">P14</ref>)</note>
                    </seg> von <date when="1911-11-01">1/11</date>
                    über mich gelesen?) <note place="right" hand="#addressee">3370</note>
                </p>
                <p rendition="#c">und an </p>
                <p>Herrn <persName key="pers.876">H. W. Draber</persName>, Musikschriftsteller,
                    Wannsee, Alsenstr. 26/27 <lb/>sofort nach Erscheinen je ein Exemplar meiner
                        <bibl sameAs="schriften.1">Harmonielehre</bibl>.</p>
                <p>Ihren lieben <seg type="comment">
                        <orig>Brief</orig>
                        <note xml:id="nh4m_ljm_hwb">
                            <ref target="letter.24209">Universal-Edition an Arnold Schönberg,
                                zwischen 17. und 28. November 1911 [erschlossen]</ref>
                        </note>
                    </seg> beantworte ich in den allernächsten Tagen. Bei dieser Gelegen<g ref="#typoHyphen"/>
                    <lb break="no"/>heit will ich nur noch fragen, ob Sie genug Exemplare des <bibl sameAs="werke.26">II. Quartetts</bibl> (Partitur) noch <lb/>haben. Sie
                    wissen es sind heuer <seg type="comment">
                        <orig>3 Aufführungen</orig>
                        <note xml:id="nmln_spb_rcc" resp="#KBleier"><ref target="event.10"/>; <ref target="event.76"/>; <ref target="event.75"/></note>
                    </seg> davon: <placeName key="place.4.4">Paris</placeName>, <placeName key="place.13.1">Prag</placeName> und <placeName key="place.14.1">Budapest</placeName>.</p>
                <closer>
                    <salute>V<supplied cert="high">iele</supplied> herzliche Grüße, hoffentlich sehe
                        ich Sie bald in <placeName key="place.2.3">Berlin</placeName>. Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1911-11-28">28./11. 1911</date>
                    </dateline>
                </closer>
            </div>
        </body>
    </text>
