    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.4">
                        <persName key="pers.3263">ARNOLD SCHÖNBERG</persName>
                        <lb/>WIEN, XIII. <lb/>
                        <placeName key="place.9.11.5.3">HIETZINGER
                            HAUPTSTRASSE 113</placeName>
                    </stamp>
                </opener>
                <salute>P.T.</salute>
                <metamark function="done" hand="#addressee" spanTo="#ixg_kpf_vvb"/>
                <p>Anbei die
                    ersten 40 Seiten „<bibl sameAs="werke.5">Pelleas</bibl>“
                    <lb/>Korrektur.</p>
                <p>Erbitte bald zur 2<hi rendition="#sup">
                        <hi rendition="#uu">tn</hi>
                    </hi>
                    Revision.</p>
                <anchor type="done" xml:id="ixg_kpf_vvb"/>
                <milestone unit="section" rendition="#hr"/>
                <metamark function="done" hand="#addressee" spanTo="#g2l_ppf_vvb"/>
                <p>Text für Titelblatt liegt bei. <lb/>Copyright??</p>
                <anchor type="done" xml:id="g2l_ppf_vvb"/>
                <milestone unit="section" rendition="#hr"/>
                <p>Korrektur der <bibl sameAs="schriften.1">Harmonielehre</bibl> Beispiele
                    <lb/>folgt in einigen Tagen.</p>
                <milestone unit="section" rendition="#hr"/>
                <p>Bitte die 2<hi rendition="#sup">
                        <hi rendition="#uu">te</hi>
                    </hi> Korrektur in <hi rendition="#uu">2</hi> Exem<g ref="#typoHyphen"/><lb break="no"/><supplied cert="high">p</supplied>laren machen zu lassen.</p>
                <p>Ebenso die 1. Korrekt. –</p>
                <p>Fortsetzung <bibl sameAs="schriften.1">Harmonielehre</bibl> in 2–3
                    <lb/>Tagen</p>
                <closer>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
