    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.99">
                        <orgName key="org.1">UNIVERSAL-EDITION A.-G.</orgName>
                        <lb/>WIEN, I. <placeName key="place.9.11.6.12">KARLSPLATZ 6</placeName>
                        (Musikvereinsgebäude)</stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine>Berlin-Charlottenburg 2,</addrLine>
                        <addrLine>
                            <placeName key="place.2.3.1.5">Steinplatz 2</placeName>, Pension
                            Bavaria.</addrLine>
                    </address>
                    <pb n="2" xml:id="p.2"/>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1926-05-29">29.
                            Mai 1926</date>.</dateline>
                    <persName key="pers.1485">LH</persName>/<persName key="pers.4342">Wi.</persName>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Professor <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#uda">Berlin-Charlottenburg 2,</hi>
                        </addrLine>
                        <addrLine rendition="#r">
                            <placeName key="place.2.3.1.5">Steinplatz 2</placeName>, Pension
                            Bavaria.</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wie senden Ihnen gleichzeitig die <lb/>Abzüge der nachgestochenen <seg type="comment">
                        <orig>3 Seiten</orig>
                        <note xml:id="nvmw_tfk_3fc" resp="#KBleier">II. [Anhang] Kanon für Streichquartett, III. [Anhang]
                            Legitimation als Kanon</note>
                    </seg> zu Ihrem <bibl sameAs="werke.61">op. 28</bibl>
                    <lb/>samt dem dazugehörigen <seg type="comment">
                        <orig>Manuskript</orig>
                        <note sameAs="letter.17656/#nu1p_2gq_hfc"/>
                    </seg> ein. Wir hoffen, <lb/>nun
                    auch bald die <seg type="comment">
                        <orig>Abzüge</orig>
                        <note sameAs="letter.17669/#nxsv_1p2_3fc"/>
                    </seg> des 4. Chores aus <bibl sameAs="werke.60">op. 27</bibl> sowie <lb/>die Abzüge von <bibl sameAs="werke.61">op. 28</bibl> zurückzuerhalten und zeichnen</p>
                <closer>
                    <salute rendition="#r">mit vorzüglicher Hochachtung</salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">
                        D<hi rendition="#sup">r</hi>
                        <persName key="pers.1750">Kalmus</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
