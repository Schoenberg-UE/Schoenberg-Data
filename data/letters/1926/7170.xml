    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Lieber Herr <rs type="person" key="pers.1538">Direktor</rs>,</salute>
                <p rendition="#inline">ich bestätige <lb/>mit herzlichstem Dank für die rasche
                    <lb/>Erledigung den Empfang der mir <lb/>von Ihnen telegrafisch geschickten 600
                    <lb/>(sechshundert) Schilling.</p>
                <closer>
                    <salute rendition="#r">Herzliche Grüße</salute>
                    <signed rendition="#r">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1926-09-08">8/9.1926</date>
                    </dateline>
                </closer>
                <note place="mBottom" hand="#addressee">X </note>
            </div>
        </body>
