    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>
                            <persName key="pers.3263">Schönberg</persName>
                        </addrLine>
                        <addrLine>Charlottenburg 2</addrLine>
                        <addrLine>
                            <placeName key="place.2.3.1.5">Steinplatz 2</placeName>
                        </addrLine>
                        <addrLine>Pension Bavaria</addrLine>
                    </address>
                    <dateline>
                        <date when="1926-01-08">8/I.192<choice>
                                <sic>5</sic>
                                <corr cert="high">6</corr>
                            </choice>
                        </date>
                    </dateline>
                </opener>
                <salute>Lieber Dr <persName key="pers.1520">Heinsheimer</persName>,</salute>
                <p rendition="#inline">in einer <lb/>mir gestern zugestellten <ref target="document.23437">Abrechnung</ref> der <orgName key="org.1">U.E.</orgName>
                    <lb/>vermisse ich <lb/>
                    <seg rendition="#c">
                        <hi rendition="#u">schon wieder!</hi>
                    </seg>
                    <lb/>
               die Gutschrift meines <bibl sameAs="schriften.41">Artikels</bibl>
                    <lb/>für das <seg type="comment">
                        <orig>Jahrbuch</orig>
                        <note sameAs="letter.21789/#ncdh_l15_qwb"/>
                    </seg>: 250 Mark!</p>
                <p>Bitte teilen Sie mir umgehend <lb/>die Gutschrift und Richtigstellung <lb/>des
                    Saldos bestätigt von Herrn <persName key="pers.4190">Winter</persName>
                    <lb/>mit.</p>
                <p>Diesmal sind Sie schuld!</p>
                <closer>
                    <salute>Beste Grüße</salute>
                    <signed>
                        <persName key="pers.3263">Schönberg</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
