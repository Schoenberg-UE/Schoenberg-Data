    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <salute>Liebes Fräulein <persName key="pers.3067">Rothe</persName>,</salute>
                <p rendition="#inline">bitte freundlichst meinem <lb/>Sohn <persName key="pers.3281">Georg</persName> von dieser Liste folgendes auszufolgen</p>
                <list>
                    <item>1. <!-- <bibl sameAs="werke.21">Arnold Schönberg, Lied der Waldtaube</bibl> -->
                        <hi rendition="#u" hand="#addressee">
                            <metamark function="done" hand="#addressee" spanTo="#z4w_gy3_dzb"
                                />5333<anchor type="done" xml:id="z4w_gy3_dzb"/>
                        </hi>, <!-- <note xml:id="ncty_tw3_dzb" resp="#pkehrer">
                                <bibl sameAs="werke.54">Arnold Schönberg, Pierrot lunaire. Dreimal sieben Gedichte aus
                                    Albert Girauds „Lieder des Pierrot Lunaire“ op. 21</bibl>
                                (Studienpartitur)</note> -->
                        <hi rendition="#u" hand="#addressee">
                            <metamark function="done" hand="#addressee" spanTo="#uyl_hy3_dzb"
                                />5336<anchor type="done" xml:id="uyl_hy3_dzb"/>
                        </hi> , <!-- <note xml:id="nnyt_sx3_dzb" resp="#pkehrer">
                                <bibl sameAs="werke.52">Arnold Schönberg, Sechs kleine Klavierstücke
                                    op. 19</bibl></note> -->
                        <hi rendition="#u" hand="#addressee">
                            <metamark function="done" hand="#addressee" spanTo="#xbx_hy3_dzb"
                                />5069<anchor type="done" xml:id="xbx_hy3_dzb"/>
                        </hi> als meine <hi rendition="#u">Frei-Exemplare</hi>.</item>
                    <item>2. Von den restlichen angegebenen Noten, die mit <lb/>ein bis <subst>
                            <del rendition="#ow">zw</del>
                            <add place="across">dr</add>
                        </subst>ei # versehenen jedoch bis zu einem <lb/>Höchstbetrage von <hi rendition="#u">Ladenpreis 100 Sch.</hi>
                    </item>
                </list>
                <p>diese <add place="superlinear">àd 2 genannten</add> Noten bitte ich nach Abzug
                        <hi rendition="#u">meines</hi>
                    <lb/>Rabattes (33 1/3 %) auf meinem Konto zu belasten.</p>
                <closer rendition="#r">
                    <salute>Besten Dank im Voraus <lb/>u herzl. Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1926-11-20">20/XI.1926</date>
                    </dateline>
                </closer>
                <note place="right">## <persName key="pers.2257">Malipiero, Fr.</persName>
                    <bibl sameAs="werke.156">Stornelli e Ballate</bibl>. 193</note>
            </div>
