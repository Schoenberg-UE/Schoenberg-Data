    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <address>
                        <addrLine>= <rs type="org" key="org.1">musikedition wien</rs> =</addrLine>
                    </address>
                </opener>
                <p>
                    <seg type="comment">
                        <orig>dratet <rs type="org" key="org.92">vertreters</rs> adresse</orig>
                        <note xml:id="nm32_t4h_yyb" resp="#pkehrer">In Arnold Schönberg an Tischer
                            &amp; Jagenberg, 1. Februar 1926 (<ref
                                target="https://repo.schoenberg.at/urn:nbn:at:at-asc-B005925">ASCC
                                592</ref>), hatte sich <persName key="pers.3263"
                                >Schönberg</persName> nach einer Tantiemenzahlung erkundigt, die
                            verschollene Antwortkarte hatte ihn vermutlich an den <orgName
                                key="org.92">Friedrich Hofmeister Musikverlag</orgName>
                            verwiesen</note>
                    </seg> ferner ob beide pakete <seg type="comment">
                        <orig>manuskripte</orig>
                        <note xml:id="nf13_2wp_hfc" resp="#KBleier">
                            <p>
                                <bibl sameAs="werke.60">Arnold Schönberg, Vier Stücke für gemischten
                                    Chor op. 27</bibl>: Der Wunsch des Liebhabers op. 27/4;
                                Reinschrift. Stichvorlage für den Originaldruck (<ref
                                    target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=908&amp;werke_id=286&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                    >ASGA B 18/2, Quelle C</ref>).</p>
                            <p>
                                <bibl sameAs="werke.61">Arnold Schönberg, Drei Satiren für
                                    gemischten Chor op. 28</bibl>: Der neue Klassizismus op. 28/3;
                                Reinschrift und Stichvorlage (<ref
                                    target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=923&amp;werke_id=289&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke"
                                    >ASGA B 18/2, Quelle C</ref>)</p>
                        </note>
                    </seg>
                    <lb/>erhalten erledigt rasch und vollstaendig <seg type="comment">
                        <orig>
                            <persName key="pers.1339">greissle</persName>
                        </orig>
                        <note sameAs="letter.1179/#nhc3_n22_3gc"/>
                    </seg> und <lb/>sendet <seg type="comment">
                        <orig>jahrbuch</orig>
                        <note sameAs="letter.21789/#ncdh_l15_qwb"/>
                    </seg> = </p>
                <closer rendition="#inline">
                    <address>
                        <addrLine>
                            <persName key="pers.3263">schoenberg</persName> +</addrLine>
                    </address>
                </closer>
                <note place="mBottom" hand="#addressee">
                    <!-- steno -->
                    <hi rendition="#st">
                        <placeName key="place.2.3">Berliner</placeName>
                        Auslieferungsstelle <gap reason="illegible" unit="words" quantity="1"/>
                        <orgName key="org.85">Protze</orgName>
                        <lb/>Beide Sendungen Man. erhalten
                        Brief folgt</hi>
                </note>
