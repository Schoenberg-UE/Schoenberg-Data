    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.18">
                        <persName key="pers.3263">Arnold Schönberg</persName>
                        <lb/>Charlottenburg 2<lb/>
                        <placeName key="place.2.3.1.5">Steinpl. 2 Pens. Bavaria</placeName>
                    </stamp>
                    <dateline>
                        <date when="1926-06-24">24.VI 1926</date>
                    </dateline>
                </opener>
                <salute>P. T Redaktion des <orgName key="org.7">Anbruch</orgName>,</salute>
                <p rendition="#inline">ich bitte Sie, in <lb/>der nächsten Nummer des <orgName
                        key="org.7">Anbruch</orgName> folgende <lb/>Mitteilung zu <seg
                        type="comment">
                        <orig>veröffentlichen</orig>
                        <note xml:id="nv3t_l4f_czb" resp="#pkehrer">
                            <rs type="bibl" key="zotero-4528359-59S7BSLV">Anbruch 1926a</rs>, S.
                            342 (Exemplar aus dem Schönberg-Nachlass; <ref
                                target="https://archive.schoenberg.at/library/eintrag.php?id_eintrag=162&amp;action=view&amp;sortieren=veroeffentlichungsDatum&amp;vonBis=180-199"
                                >P12</ref>)</note>
                    </seg>:</p>
                <p rendition="#ll">
                    <persName key="pers.3263">Arnold Schönberg</persName> hat an das Komité <lb/>der
                        <orgName key="org.93">Internationalen Gesellschaft für neue Musik</orgName>
                    <lb/>
                    <supplied cert="high">d</supplied>as Ersuchen gerichtet, seinen Namen von
                    der <lb/>Liste der Ehrenmitglieder dieser Gesellschaft <lb/>zu streichen. <note hand="#author" place="mBottom">
                        <hi rendition="#u">Bitte ohne jeden Kommentar</hi>
                    </note>
                </p>
                <p>Ich bitte um freundliche Bestätigung dieses  <lb/>Briefes und Mitteilung, wann
                    die Nummer mit  <lb/>dieser Erklärung erscheinen wird.</p>
                <closer rendition="#r">
                    <salute>Hochachtungsvoll</salute>
                    <lb/>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <note place="mBottom" hand="#unknown">
                        <gap reason="illegible" unit="chars" quantity="1"/>
                    </note>
                </closer>
            </div>
        </body>
    </text>
