    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.105">
                        <orgName key="org.1">UNIVERSAL-EDITION, A.-G.</orgName>
                        <lb/>
                        <orgName key="org.96">Jos·Aibl Verlag, G. m. b. H.</orgName>
                        <lb/>LEIPZIG<lb/>
                        <placeName key="place.2.20.8">Karlstrasse 10</placeName>
                        <lb/>WIEN<lb/> I·<placeName key="place.9.11.6.12">Karlsplatz 6</placeName>.
                        <lb/>Musikvereinsgebäude<lb/>Telegr. Adr.: Musikedition, Wien, A. B. C. Code
                            5<hi rendition="#sup">th.</hi> Ed. Mosse Code.<lb/>Telefon N<hi rendition="#sup #uu">o</hi> 51351, 51352. Bank-Konto: <orgName key="org.199">Zentral-Europä-<lb/>ische Länderbank Wien</orgName>.
                        Postsparkassen-Kto. 57557.<lb/>Wien</stamp>
                    <stamp>Ab <date when="1926-05-05">5. Mai 1926</date> neue
                            Telefonnummer:<lb/>Serie 57-5-85</stamp>
                    <persName key="pers.1485">LH</persName>/<persName key="pers.4342">Wi.</persName>
                    <dateline>
                        <placeName key="place.9.11">Wien</placeName>, <date when="1926-08-06">6.
                            August 1926</date>.</dateline>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine rendition="#c">Prof. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>,</addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #uda">
                                <placeName key="place.6.1">Dubrownik</placeName>,</hi>
                        </addrLine>
                        <addrLine rendition="#r">Hauptpostlagernd.</addrLine>
                    </address>
                </opener>
                <salute>Sehr verehrter Meister <persName key="pers.3263">Schönberg</persName>!</salute>
                <p>Wir bestätigen den Empfang des <seg type="comment">
                        <orig>Manuskrip<g ref="#typoHyphen"/>
                            <lb break="no"/>tes</orig>
                        <note xml:id="nbhg_z1b_dzb" resp="#KBleier">Kopistenabschrift der Partiturreinschrift B 
                            (<ref target="https://archive2.schoenberg.at/compositions/quellen_einzelansicht.php?id_quelle=1754&amp;werke_id=531&amp;id_gatt=&amp;id_untergatt=&amp;herkunft=allewerke">ASGA B
                                    23/2, Quelle B<hi rendition="#sup">k</hi>
                            </ref>)
                        </note>
                    </seg>
                    Ihrer <bibl sameAs="werke.62">Suite op. 29</bibl>, Seite 1–108 samt einer
                    Vorlage für <lb/>den Titel, Vortragsanweisungen, Inhaltsverzeichnis und beson<g ref="#typoHyphen"/>
                    <lb break="no"/>deren Stichanweisungen. Von den Stimmen
                    haben wir bis <lb/>jetzt 2 Sätze der 3. Klarinetten erhalten, die restlichen
                    <lb/>Stimmen versprach Herr <persName key="pers.1339">Greissle</persName> für die
                    nächsten Tage.</p>
                <p>Die Abzüge der Inhaltverzeichnisse von <lb/>
                    <bibl sameAs="werke.60">op. 27</bibl> und <bibl sameAs="werke.61">op. 28</bibl>
                    haben wir ebenfalls erhalten und bereits <lb/>der <rs type="org" key="org.186">Druckerei</rs> zum <seg type="comment">
                        <orig>Druck</orig>
                        <note xml:id="nhcb_lxk_3fc" resp="#KBleier">Laut <orgName key="org.1">UE</orgName>-Herstellungskartei gingen <bibl sameAs="werke.60">Vier
                                Stücke für gemischten Chor op. 27</bibl> am <date when="1926-06-29">29. Juni 1926</date> zum Druck an <orgName key="org.186">Waldheim-Eberle</orgName>, <bibl sameAs="werke.61">Drei Satiren für
                                gemischten Chor op. 28</bibl> am <date when="1926-08-10">10. August
                                1926</date>
                        </note></seg> übergeben.</p>
                <closer>
                    <salute>Wir empfehlen uns <lb/>
                        <seg rendition="#r">mit vorzüglicher
                            Hochachtung</seg>
                    </salute>
                    <lb/>
                    <stamp sameAs="stamp.46" rendition="#r">
                        <orgName key="org.1">Universal-Edition
                        Actiengesellschaft</orgName>
                    </stamp>
                    <lb/>
                    <signed rendition="#r">Dr <persName key="pers.1750">Kalmus</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
