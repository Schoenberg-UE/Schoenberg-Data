    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.103">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName> A.-G.<lb/>Wien, I.
                            <placeName key="place.9.11.6.12">Karlsplatz 6</placeName> ·
                        Leipzig, <placeName key="place.2.20.8">Karlstr.
                        10</placeName>
                        <lb/>Postscheck-Konto Leipzig 89133<lb/>Fernsprecher: 21241
                        und 12642 </stamp>
                    <address>
                        <addrLine>Herrn</addrLine>
                        <addrLine>Dr. <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine>Berlin-Charlottenburg</addrLine>
                        <addrLine>
                            <placeName key="place.2.3.1.5">Steinplatz
                            2</placeName>.</addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <opener>
                    <address>
                        <addrLine>
                            <hi rendition="#u">Herrn Dr. <persName key="pers.3263">Arnold
                                    Schönberg</persName>, <placeName key="place.2.3.1">Berlin - Charlottenburg</placeName>.</hi>
                        </addrLine>
                    </address>
                </opener>
                <p>Wir bestätigen den Eingang Ihres <lb/>
                    <ref target="letter.667">Briefes</ref> vom
                        <date when="1926-02-03">3./2.</date> und teilen Ihnen mit, dass wir <lb/>den
                    Betrag von der Firma <orgName key="org.4">Tischer &amp; Jagenberg</orgName> be<g ref="#typoHyphen"/>
                    <lb break="no"/>reits am <date when="1926-01-06">6.
                        Januar</date> durch Postscheckkonto erhalten <lb/>und direkt der <orgName key="org.1">Universal-Edition</orgName>, <placeName key="place.9.11">Wien</placeName> überwiesen <lb/>haben. Wir haben Ihren <ref target="letter.667">Brief</ref>, sowie die <seg type="comment">
                        <orig>Karte</orig>
                        <note sameAs="letter.594/#nm32_t4h_yyb"/>
                    </seg> der
                    <lb/>Firma <orgName key="org.4">Tischer &amp; Jagenberg</orgName> direkt nach
                        <placeName key="place.9.11">Wien</placeName> weiter<g ref="#typoHyphen"/>
                    <lb break="no"/>geleitet.</p>
                <closer rendition="#r">
                    <salute>Hochachtungsvoll</salute>
                    <stamp sameAs="stamp.147">
                        <orgName key="org.1">UNIVERSAL-EDITION</orgName> A.-G.</stamp>
                    <lb/>
                    <signed>
                        <unclear reason="illegible" cert="high">
                            <persName key="pers.4390">Busch</persName>
                        </unclear>
                    </signed>
                    <signed>
                        <gap reason="illegible" unit="chars" quantity="1"/>
                    </signed>
                    <dateline rendition="#l">
                        <placeName key="place.2.20">Leipzig</placeName>, den <date when="1926-01-05">5. <choice>
                                <sic>Januar</sic>
                                <corr cert="high">Februar</corr>
                            </choice> 1926</date>.</dateline>
                    <seg rendition="#l">
                        <persName key="pers.4388">Mö.</persName>/<persName key="pers.4389">L.</persName>
                    </seg>
                </closer>
            </div>
