    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.150">
                        <orgName key="org.7">MUSIKBLÄTTER<lb/>DES
                        ANBRUCH</orgName>
                        <lb/>HALBMONATSSCHRIFT F. MODERNE MUSIK·HERAUSGEGEB. V. D.
                            <orgName key="org.1">UNIVERSAL-EDITION A. G.</orgName>
                        <lb/>TELEPHON
                        NUMMER: 45-33 UND 32-28<lb/>BANKKONTO: <orgName key="org.199">LÄNDERBANK
                            WIEN</orgName>
                        <lb/>TELEGR.-ADR.: MUSIKEDITION
                        WIEN<lb/>SCHRIFTLEITUNG:<lb/>DR. <persName key="pers.3240">OTTO
                            SCHNEIDER</persName>
                        <lb/>WIEN, I. <placeName key="place.9.11.6.12">KARLSPLATZ NR. 6</placeName>
                        <lb/>SPRECHZEIT DER
                        SCHRIFTLEITUNG:<lb/>DIENSTAG UND FREITAG VON 11–12<lb/>FEIERTAGE
                        AUSGENOMMEN<lb/>WIEN <seg hand="#author">
                            <date when="1919-07-11">11. Juli
                                1919</date>
                        </seg>
                    </stamp>
                    <address>
                        <addrLine>Wohlgeboren</addrLine>
                        <addrLine rendition="#c">Herrn <persName key="pers.3263">Arnold <hi rendition="#g">Schönberg</hi>
                            </persName>
                        </addrLine>
                        <addrLine rendition="#r">
                            <hi rendition="#g #uda">
                                <placeName key="place.9.4">Mödling</placeName>
                            </hi>
                        </addrLine>
                    </address>
                </opener>
                <salute>Sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>,</salute>
                <p>nach Rücksprache mit unserem Herrn Direktor <persName key="pers.1538">Hertzka</persName>
                    <lb/>teile ich Ihnen mit, dass wir leider mit unseren Vorarbeiten <lb/>für die
                    Musikzeitschrift schon so weit vorgeschritten sind, <lb/>dass es technisch schon
                    eine Unmöglichkeit ist, Ihren weitgehenden <lb/>Wünschen Rechnung zu tragen. Wir
                    würden es dennoch mit grosser <lb/>Freude begrüssen, stellten Sie uns von Fall
                    zu Fall einen <lb/>Beitrag zur Verfügung, lässt sich auch die unsererseits so
                    gern <lb/>gesehene rege Beziehung nicht verwirklichen. Wir geben der
                    <lb/>angenehmen Erwartung Ausdruck, dass Sie uns für die ersten <lb/>Nummern
                    bereits Material einsenden, und sehen Ihren diesbezüglichen <lb/>eventuellen
                    Mitteilungen mit besonderem Interesse entgegen.</p>
                <closer>
                    <salute>Ich empfehle mich Ihnen, sehr geehrter Herr <persName key="pers.3263">Schönberg</persName>, <lb/>
                        <seg rendition="#r">mit dem Ausdruck der
                            ergebensten <lb/>Hochachtung</seg>
                    </salute>
                    <signed rendition="#r">Dr <persName key="pers.3240">Otto
                        Schneider</persName>
                    </signed>
                </closer>
            </div>
        </body>
