    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <dateline>
                        <date when="1932-07-04">4.VII. 1932</date>
                    </dateline>
                </opener>
                <salute>Lieber Herr <persName key="pers.3263">Schönberg</persName>!</salute>
                <p> Vielen Dank für Ihren <ref target="letter.2253">Brief</ref>. Ich bestätige ihn
                    <lb/>sofort, wie Sie es wünschen, ohne Ihnen einstweilen <lb/>mehr sagen zu
                    können. Ich werde aber darauf dringen, <lb/>
                    <supplied cert="high">da</supplied>ß
                    in den nächsten Tagen geantwortet wird oder <lb/>selbst nochmals antworten. </p>
                <closer>
                    <salute rendition="#c">Herzlichste Grüße
                    <lb/>Ihr </salute>
                    <signed rendition="#r">
                        <persName key="pers.3612">Stein</persName>
                    </signed>
                </closer>
            </div>
        </body>
    </text>
