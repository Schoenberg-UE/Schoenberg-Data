    <text>
        <body>
            <div type="letter">
                <pb n="1" xml:id="p.1"/>
                <opener>
                    <stamp sameAs="stamp.91">
                        <persName key="pers.3263">ARNOLD
                        SCHÖNBERG</persName>
                        <lb/>BERLIN W 50<lb/>
                        <placeName key="place.2.3.9.1">NÜRNBERGER PLATZ 3</placeName>
                        <lb/>TEL. B4 BAVARIA 44 66</stamp>
                    <address>
                        <lb/>
                        <addrLine>Herr Direktor <persName key="pers.4190">Winter</persName>
                        </addrLine>
                        <addrLine>
                            <orgName key="org.1">Universal Edition</orgName>
                        </addrLine>
                        <addrLine>Wien I.</addrLine>
                        <addrLine>
                            <placeName key="place.9.11.6.12">Karlsplatz
                            6</placeName>
                        </addrLine>
                    </address>
                </opener>
                <pb n="2" xml:id="p.2"/>
                <salute>Lieber Herr Direktor <persName key="pers.4190">Winter</persName>,</salute>
                <p rendition="#inline">bitte zahlen Sie <lb/>freundlichst den angekündigten Betrag
                    auf <lb/>mein Konto bei der <orgName key="org.213">Deutschen Bank u. <del rendition="#s">Depositen</del>
                        <lb/>
                        <del rendition="#s">Kasse</del> Disconto Gesellschaft</orgName>,
                    Depositen Kasse K. <lb/>Berlin W50 <placeName key="place.2.3.9.2">Schaperstrasse
                        1</placeName> oder auf mein <lb/>Postscheckkonto <hi rendition="#u">
                        <placeName key="place.2.3">Berlin</placeName>
                    </hi> 121518 – wie
                    es Ihnen <lb/>bequemer ist.</p>
                <closer rendition="#inline">
                    <salute>Beste Grüße Ihr</salute>
                    <signed>
                        <persName key="pers.3263">Arnold Schönberg</persName>
                    </signed>
                    <dateline rendition="#l">
                        <date when="1932-10-16">16.X.1932</date>
                    </dateline>
                </closer>
            </div>
        </body>
